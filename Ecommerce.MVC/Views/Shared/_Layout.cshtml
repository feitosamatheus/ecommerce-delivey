    @await RenderSectionAsync("Scripts", required: false)
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        $(document).on('click', '.js-acompanhar-pedidos', function () {
            addLoading("Carregando...");

            setTimeout(() => {
                window.location.href = '/Pedido/EmAndamento';
            }, 800);
        });

        $(document).on('click', '.js-acompanhar-pedidos-login', function () {
            $.ajax({
                url: '/Cliente/BuscarModalAutenticacaoCliente',
                method: 'GET',
                cache: false,
                beforeSend: function () {
                    addLoading("Carregando...");
                },
                success: function (html) {
                    $('#conteudo-dinamico').empty();
                    $('#conteudo-dinamico').html(html);

                    const modalLoginEl    = document.getElementById('modal-cliente-auth');
                    const modalLogin = bootstrap.Modal.getOrCreateInstance(modalLoginEl);
                    modalLogin.show();
                },
                error: function () {
                    $body.html('<div class="text-danger p-3">Não foi possível carregar seus dados agora.</div>');
                },
                complete: function () {
                    removeLoading();
                }
            });
        });

        $(document).on('click', '.js-abrir-carrinho-mobile', function () {

            const modal = bootstrap.Modal.getOrCreateInstance(
                document.getElementById('modalCarrinhoMobile')
            );

            modal.show();
        });

        $(document).on('click', '.btn-toggle-password', function () {
            const targetId = $(this).data('target');
            const input = document.getElementById(targetId);

            if (!input) return;

            const icon = $(this).find('i');

            if (input.type === 'password') {
                input.type = 'text';
                icon.removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                input.type = 'password';
                icon.removeClass('fa-eye-slash').addClass('fa-eye');
            }
        });

        window.appUser = {
            primeiroNome: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(primeiroNome))
        };

        $(document).ready(function () {
            const urlParams = new URLSearchParams(window.location.search);
            const precisaTrocarSenha = @Json.Serialize(ViewBag.ExibirModalTrocaSenha ?? false);

            function toBool(v) {
                if (v == null) return false;
                v = String(v).toLowerCase();
                return v === '1' || v === 'true' || v === 'yes' || v === 'y';
            }

            function limparUrl() {
                const cleanUrl = window.location.origin + window.location.pathname;
                window.history.replaceState({}, document.title, cleanUrl);
            }

            if (urlParams.has('confirmado')) {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalSucessoPedido')).show();
                limparUrl();
            }

            if (precisaTrocarSenha) {
                abrirModalSenha(true);
            }

            if (urlParams.has('itemAdicionado')) {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalSucessoProduto')).show();
                limparUrl();
            }

            if (urlParams.has('acessoNegado')) {
                bootstrap.Modal.getOrCreateInstance(document.getElementById('modalAcessoNegado')).show();
                limparUrl();
            }

            if (urlParams.has('abrirPedidos')) {
                const isDesktop = window.matchMedia('(min-width: 1200px)').matches;

                // Remove o parâmetro da URL para não reabrir em refresh/volta
                limparUrl();

                if (!isDesktop) {
                    // Mobile/tablet: vai para a página de pedidos
                    window.location.replace('/Pedido/Index');
                    return;
                }

                // Desktop: abre modal
                addLoading("Carregando...");

                setTimeout(() => {
                    $.ajax({
                    url: '/Pedido/BuscarModalPedidosEmAndamento',
                    method: 'GET',
                    success: function (html) {
                        $('#conteudo-dinamico').empty().html(html);
                        bootstrap.Modal
                        .getOrCreateInstance(document.getElementById('modalPedidosEmAndamento'))
                        .show();
                    },
                    error: function (xhr) {
                        // se você tiver SweetAlert:
                        // uiNotify.toast.error(xhr.responseText || 'Erro ao carregar pedidos.');
                        alert(xhr.responseText || 'Erro ao carregar pedidos.');
                    },
                    complete: function () {
                        removeLoading();
                    }
                    });
                }, 800);
            }


            $(document).on('submit', '#formAlterarSenhaUnificado', function (e) {
                e.preventDefault();

                $('#alterarSenhaAlert').addClass('d-none').text('');

                const $form = $(this);
                const $btn = $('#btnSalvarNovaSenha');
                const $alert = $('#alterarSenhaAlert');

                const data = {
                    //SenhaAtual: $('#senhaAtual').val(), 
                    NovaSenha: $('#novaSenha').val()
                };

                if (data.NovaSenha !== $('#confirmarNovaSenha').val()) {
                    $alert.text("As senhas não coincidem!").removeClass('d-none');
                    return;
                }

                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm"></span> Salvando...');

                $.ajax({
                    url: '/Cliente/AlterarSenha',
                    method: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(data),
                    headers: {
                        // Envia o Token de segurança no cabeçalho para o .NET Core validar
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (response) {
                        if (response.success) {
                            const modalElement = document.getElementById('modalAlterarSenhaGenerico');
                            const inst = bootstrap.Modal.getInstance(modalElement);
        
                            if (inst) {
                                inst.hide();
                            }

                            Swal.fire({
                                icon: 'success',
                                title: 'Sucesso!',
                                text: response.message,
                                confirmButtonColor: '#B26528',
                            }).then((result) => {
                                if (result.isConfirmed) {
                                    $('#formAlterarSenhaUnificado')[0].reset();
                                    $('#alterarSenhaAlert').addClass('d-none');
                
                                    $btn.prop('disabled', false).text('Salvar nova senha');
                                }
                            });

                        } else {
                            $alert.text(response.message).removeClass('d-none');
                            $btn.prop('disabled', false).text('Salvar nova senha');
                        }
                    },
                    error: function () {
                        $alert.text("Erro de comunicação com o servidor.").removeClass('d-none');
                        $btn.prop('disabled', false).text('Salvar nova senha');
                    }
                });
            });
        });
        
        function abrirModalSenha(ePrimeiroAcesso = false) {
                const modalEl = document.getElementById('modalAlterarSenhaGenerico');
                const titulo = document.getElementById('tituloModalSenha');
                const subtitulo = document.getElementById('subtituloModalSenha');
                const containerFechar = document.getElementById('containerBtnFechar');

                if (ePrimeiroAcesso) {
                    titulo.innerText = "Primeiro Acesso";
                    subtitulo.innerText = "Para sua segurança, é necessário definir uma nova senha no seu primeiro acesso.";
                    containerFechar.classList.add('d-none'); // Esconde o "X"
        
                    // Configura o modal para não fechar clicando fora ou ESC
                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl, {
                        backdrop: 'static',
                        keyboard: false
                    });
                    modal.show();
                } else {
                    titulo.innerText = "Alterar Senha";
                    subtitulo.innerText = "Preencha os campos abaixo para atualizar sua senha de acesso.";
                    containerFechar.classList.remove('d-none'); // Mostra o "X"
        
                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                }
            }
    
        async function recarregarCarrinhoEFooter() {
            await Promise.all([
                recarregarCarrinhoAjax(),
                recarregarFooterAjax(),
                recarregarCarrinhoMobileAjax()
            ]);
        }

        async function recarregarCarrinhoAjax() {
            try {
                const response = await fetch('/Carrinho/Renderizar', {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    throw new Error('Não foi possível recarregar o carrinho.');
                }

                const html = await response.text();
                const container = document.getElementById('carrinho-container');

                if (container) {
                    container.innerHTML = html;
                }
            } catch (error) {
                console.error('Erro ao atualizar carrinho:', error);
            }
        }

        async function recarregarFooterAjax() {
            try {
                const response = await fetch('/Home/RenderizarFooter', {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                });

                if (!response.ok) {
                    throw new Error('Não foi possível recarregar o footer.');
                }

                const html = await response.text();
                const container = document.getElementById('footer-container');

                if (container) {
                    container.innerHTML = html;
                }
            } catch (error) {
                console.error('Erro ao atualizar footer:', error);
            }
        }

         async function recarregarCarrinhoMobileAjax() {
            const modalContent = document.getElementById('modalCarrinhoMobileContent');
            if (!modalContent) return;

            const response = await fetch('/Carrinho/RenderizarCarrinhoMobile', {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!response.ok) {
                throw new Error('Não foi possível recarregar o carrinho mobile.');
            }

            const html = await response.text();
            modalContent.innerHTML = html;
        }
    </script>
</body>
</html>
