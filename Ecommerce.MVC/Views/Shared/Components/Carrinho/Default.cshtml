@using System.Globalization
@using Ecommerce.MVC.Models.Carrinhos
@model CarrinhoViewModel

<style>
    .bc-cart-container {
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        background: #fff;
        overflow: hidden;
    }

    .bc-cart__header {
        border-bottom: 1px solid #f0f0f0;
        padding-bottom: 1rem;
    }

    .bc-cart__items-wrapper {
        /* min-height: 280px; */
        max-height: 55vh;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 8px;
        scrollbar-width: thin;
        scrollbar-color: #e9e9e9 #f8f9fa;
    }

        .bc-cart__items-wrapper::-webkit-scrollbar {
            width: 6px;
        }

        .bc-cart__items-wrapper::-webkit-scrollbar-button {
            display: none;
            width: 0;
            height: 0;
        }

        .bc-cart__items-wrapper::-webkit-scrollbar-track {
            background: #f8f9fa;
            border-radius: 10px;
        }

        .bc-cart__items-wrapper::-webkit-scrollbar-thumb {
            background: #e6a23c;
            border-radius: 10px;
            border: 1px solid #f8f9fa;
        }

            .bc-cart__items-wrapper::-webkit-scrollbar-thumb:hover {
                background: #d39130;
            }

    .bc-cart__item {
        padding: 12px 0;
        border-bottom: 1px dashed #eee;
    }

        .bc-cart__item:last-child {
            border-bottom: none;
        }

    .bc-cart__item-name {
        font-size: 0.95rem;
        color: #2d3436;
        line-height: 1.2;
    }

    .bc-cart__item-price {
        font-size: 0.9rem;
        color: #2d3436;
    }

    .bc-cart__acc-list {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 8px 12px;
        margin-top: 6px;
    }

    .bc-cart__acc-item {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #636e72;
        padding: 2px 0;
    }

    .bc-cart__summary {
        background: #fdfdfd;
        border-radius: 12px;
    }

    .bc-cart__total-row {
        font-size: 1.15rem;
        color: #2d3436;
        margin-top: 8px;
        padding-top: 8px;
        border-top: 2px solid #f0f0f0;
    }

    .btn-checkout {
        border-radius: 50px;
        padding: 12px;
        /* font-weight: 700; */
        letter-spacing: 0.5px;
        transition: all 0.3s ease;
        /*background: #edcd9a;*/
        background-color:  #D98C1A;;
    }

    .btn-checkout:hover {
        background: rgb(217, 140, 26) !important;
        color:#fff !important;
    }

    .btn-login-cart {
        gap: 8px;
        /* color: #4b2c20 !important;*/
        color: white;
    }

        .btn-login-cart:hover {
            background: #f8f9fa !important;
            /* transform: translateY(-2px); */
            color: #4b2c20 !important;
        }

        .bc-cart__actions {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 10px;
            justify-content: space-between;
        }

        .bc-cart__qty-group {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border: 1px solid #ececec;
            border-radius: 12px;
            background: #fafafa;
        }

        .bc-cart__qty-text {
            font-size: 0.78rem;
            font-weight: 700;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

        .bc-cart__qty-input {
            width: 56px;
            height: 32px;
            border: 1px solid #ddd;
            border-radius: 8px;
            text-align: center;
            font-size: 0.92rem;
            font-weight: 600;
            background: #fff;
            color: #2d3436;
            outline: none;
            transition: all 0.2s ease;
        }

        .bc-cart__qty-input:focus {
            border-color: #D98C1A;
            box-shadow: 0 0 0 3px rgba(217, 140, 26, 0.15);
        }

        .bc-cart__qty-input {
            appearance: auto;
        }

        .bc-cart__remove-btn {
            width: 40px;
            height: 40px;
            border: 1px solid #f3d1d1;
            background: #fff5f5;
            color: #c0392b;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .bc-cart__remove-btn:hover {
            background: #fdecec;
            border-color: #e7b8b8;
            color: #a5281b;
        }
        
</style>

<div class="col-12">
    <div class="bc-panel p-4 bc-cart-container bc-cart--sticky">
        <div class="bc-cart__header d-flex align-items-center justify-content-between mb-3">
            <h5 class="mb-0">
                <i class="fa-solid fa-bag-shopping me-2" style="color: #edcd9a;"></i>
                <span class="text-dark">Meu Carrinho</span>
            </h5>
            <span class="badge bg-light text-dark rounded-pill">@Model.Itens.Count</span>
        </div>

        @if (Model.EstaVazio)
        {
            <div class="bc-cart__items-wrapper d-flex flex-column align-items-center justify-content-center">
                <i class="fa-solid fa-cart-plus mb-3 opacity-25" style="font-size: 3rem;"></i>
                <div class="text-muted fw-medium">Seu carrinho está vazio</div>
            </div>
        }
        else
        {
            <div class="bc-cart__items-wrapper mb-4">
                @foreach (CarrinhoItemViewModel item in Model.Itens)
                {
                    <div class="bc-cart__item">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="pe-2">
                                <div class="fw-bold bc-cart__item-name">@item.Nome</div>

                                
                            </div>

                            <div class="fw-bold bc-cart__item-price">
                                @item.Total.ToString("C", new CultureInfo("pt-BR"))
                            </div>
                            
                        </div>
                        <div class="bc-cart__actions mt-2">
                            <div class="bc-cart__qty-group">
                                <span class="bc-cart__qty-text">Qtd</span>
                                <input type="number"
                                    min="1"
                                    value="@item.Quantidade"
                                    class="bc-cart__qty-input js-qtd-carrinho"
                                    data-item-id="@item.ItemId" />
                            </div>

                            <button type="button"
                                    class="bc-cart__remove-btn js-remover-item-carrinho"
                                    data-item-id="@item.ItemId"
                                    title="Remover item">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </div>
                        @if (item.Acompanhamentos.Any())
                        {
                            <ul class="list-unstyled bc-cart__acc-list">
                                @foreach (var a in item.Acompanhamentos)
                                {
                                    <li class="bc-cart__acc-item">
                                        <span><i class="fa-solid fa-plus small me-1 opacity-50"></i>@a.Nome</span>
                                        <span>@a.Preco.ToString("C", new CultureInfo("pt-BR"))</span>
                                    </li>
                                }
                            </ul>
                        }
                        
                        @if (!string.IsNullOrWhiteSpace(item.Observacao))
                        {
                            <div class="small text-muted mt-1">
                                <i class="fa-regular fa-comment-dots me-1 opacity-75"></i>
                                <span>@item.Observacao</span>
                            </div>
                        }
                    </div>
                }
            </div>
        }

        <div class="bc-cart__summary mb-4">
            <div class="d-flex justify-content-between text-muted small mb-1">
                <span>Subtotal</span>
                <span>@Model.Subtotal.ToString("C", new CultureInfo("pt-BR"))</span>
            </div>
            <div class="d-flex justify-content-between fw-bold bc-cart__total-row">
                <span>Total</span>
                <span class="text-dark">@Model.Total.ToString("C", new CultureInfo("pt-BR"))</span>
            </div>
        </div>

        @if (!Model.EstaVazio)
        {
            if (User.Identity.IsAuthenticated)
            {
                <button class="btn w-100 btn-checkout shadow-sm" style="background: #D98C1A; color: rgb(255, 255, 255); font-weight: 700;"
                        @(Model.EstaVazio ? "disabled" : "")
                        data-carrinho-id="@Model.CarrinhoId"
                        id="btnConfirmarAddProduto">
                    FINALIZAR PEDIDO
                </button>
                
            }
            else
            {
                <button type="button"
                        class="btn w-100 d-flex align-items-center justify-content-center fw-bold btn-login-cart btn-checkout"
                        id="btn-abrir-login">
                    <i class="fa-solid fa-circle-user fs-5 me-2"></i>
                    ENTRAR PARA FINALIZAR
                </button>
            }
        }
    </div>
</div>

<script>

    $(document).on('click', '#btnConfirmarAddProduto', function () {
        addLoading("Carregando...");

        $.ajax({
            url: '/Pedido/BuscarModalFinalizarPedido',
            method: 'GET',
            success: function (html) {
                $('#conteudo-dinamico').empty();
                $('#conteudo-dinamico').html(html);

                const el = document.getElementById('modalFinalizarPedido');
                const modal = bootstrap.Modal.getOrCreateInstance(el);

                modal.show();

                if (window.wizardInitFinalizarPedido)
                    window.wizardInitFinalizarPedido();
                removeLoading();
            },
            error: function (xhr) {
                alert(xhr.responseText || 'Erro ao carregar o modal.');
                removeLoading();
            }
        });
    });

    $(document).on('focus', '.js-qtd-carrinho', function () {
        $(this).data('valor-original', $(this).val());
    });

    $(document).on('blur', '.js-qtd-carrinho', function () {
        const input = $(this);
        const valorOriginal = input.data('valor-original');
        let quantidade = parseInt(input.val());
        const itemId = input.data('item-id');

        if (!quantidade || quantidade < 1) {
            quantidade = 1;
            input.val(1);
        }

        if (String(valorOriginal) === String(quantidade)) {
            return;
        }

        //addLoading("Atualizando carrinho...");

        $.ajax({
            url: '/Carrinho/AtualizarQuantidade',
            type: 'POST',
            data: {
                itemId: itemId,
                quantidade: quantidade
            },
            success: function (response) {
                if (response.sucesso) {
                    recarregarCarrinhoEFooter();
                    removeLoading();
                } else {
                    alert(response.mensagem || 'Não foi possível atualizar a quantidade.');
                    removeLoading();
                }
            },
            error: function (xhr) {
                alert(xhr.responseText || 'Erro ao atualizar quantidade.');
                removeLoading();
            }
        });
    });

    $(document).on('click', '.js-remover-item-carrinho', function () {
        const botao = $(this);
        const itemId = botao.data('item-id');

        Swal.fire({
            title: 'Remover item?',
            text: 'Este item será removido do carrinho.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sim, remover',
            cancelButtonText: 'Cancelar'
        }).then((result) => {
            if (!result.isConfirmed) return;

            addLoading("Removendo item...");

            $.ajax({
                url: '/Carrinho/RemoverItem',
                type: 'POST',
                data: {
                    itemId: itemId
                },
                success: function (response) {
                    if (response.sucesso) {
                        //location.reload();
                        recarregarCarrinhoEFooter();
                        removeLoading();
                    } else {
                        Swal.fire('Erro', response.mensagem || 'Não foi possível remover o item.', 'error');
                        removeLoading();
                    }
                },
                error: function (xhr) {
                    Swal.fire('Erro', xhr.responseText || 'Erro ao remover item.', 'error');
                    removeLoading();
                }
            });
        });
    });

</script>