@using System.Globalization
@using Ecommerce.MVC.Models.Carrinhos
@model CarrinhoViewModel

<style>
    /* ============================
       CART MOBILE (ISOLADO)
       ============================ */

    .cart-mobile .bc-cart-container {
        border-radius: 20px; 
        box-shadow:none;
        background: #fff;
    }

    .cart-mobile .bc-cart__items-wrapper {
        max-height: 55vh;
        overflow-y: auto;
    }

    .cart-mobile .bc-cart__item {
        padding: 12px 0;
        border-bottom: 1px dashed #eee;
    }

    .cart-mobile .bc-cart__item-name {
        font-size: 0.95rem;
    }

    .cart-mobile .bc-cart__summary {
        background: #fdfdfd;
        border-radius: 12px;
    }

    .cart-mobile .bc-cart__total-row {
        font-size: 1.1rem;
        border-top: 2px solid #f0f0f0;
    }

    .cart-mobile .btn-checkout {
        border-radius: 50px;
        padding: 12px;
        background: #D98C1A;
        transition: 0.3s;
    }

        .cart-mobile .btn-checkout:hover {
            background: #d39130;
            color: #fff;
        }

    .modal.fade.modal-swap {
        transition: opacity .25s ease, transform .25s ease;
    }

        .modal.fade.modal-swap.show {
            transform: translateY(0);
        }

    .modal.fade.modal-swap {
        transform: translateY(20px);
    }

    .cart-mobile .bc-cart__acc-list {
        background-color: #f8f9fa;
        border-radius: 10px;
        padding: 8px 12px;
        margin-top: 8px;
    }

    .cart-mobile .bc-cart__acc-item {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #636e72;
        padding: 2px 0;
    }

    .cart-mobile .cart-mobile__actions {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        justify-content: space-between;
    }

    .cart-mobile .cart-mobile__qty-group {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border: 1px solid #ececec;
        border-radius: 12px;
        background: #fafafa;
    }

    .cart-mobile .cart-mobile__qty-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        line-height: 1;
    }

    .cart-mobile .cart-mobile__qty-input {
        width: 52px;
        height: 32px;
        border: 1px solid #ddd;
        border-radius: 8px;
        text-align: center;
        font-size: 0.92rem;
        font-weight: 600;
        background: #fff;
        color: #2d3436;
        outline: none;
        transition: all 0.2s ease;
        box-shadow: none;
    }

    .cart-mobile .cart-mobile__qty-input:focus {
        border-color: #D98C1A;
        box-shadow: 0 0 0 3px rgba(217, 140, 26, 0.15);
    }

    /* .cart-mobile .cart-mobile__qty-input::-webkit-outer-spin-button,
    .cart-mobile .cart-mobile__qty-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .cart-mobile .cart-mobile__qty-input[type=number] {
        -moz-appearance: textfield;
    } */
    .cart-mobile .cart-mobile__qty-input {
        appearance: auto;
    }

    .cart-mobile .cart-mobile__remove-btn {
        width: 38px;
        height: 38px;
        border: 1px solid #f3d1d1;
        background: #fff5f5;
        color: #c0392b;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .cart-mobile .cart-mobile__remove-btn:hover {
        background: #fdecec;
        border-color: #e7b8b8;
        color: #a5281b;
    }

    .cart-mobile .cart-mobile__remove-btn:active {
        transform: scale(0.98);
    }

    .cart-mobile .bc-cart__item-price {
        white-space: nowrap;
        font-size: 0.95rem;
        color: #2d3436;
    }
</style>

<div class="modal-header border-0 d-flex align-items-center justify-content-between">
    <div class="text-start d-flex align-items-start">
        <h5 class="modal-title fw-bolder mb-0" style="color: #3c1e0a; font-weight: bold !important; font-size: 1rem; margin-bottom: 0.5rem !important;">
            <i class="fa-solid fa-bag-shopping me-2" style="color: #edcd9a;"></i>
            <span style="color: #4A2A15;">Meu Carrinho</span>
            <span class="badge bg-light text-dark rounded-pill">@Model.Itens.Count</span>
        </h5>
    </div>
    <button type="button" class="btn-close-custom" title="Fechar" data-bs-dismiss="modal" aria-label="Fechar" style="position: static; font-size: 1.5rem;">&times;</button>
</div>

<div class="modal-body p-0">
    <!-- 🔥 WRAPPER EXCLUSIVO -->
    <div class="cart-mobile">

        <div class="col-12">
            <div class="bc-cart-container p-4 pt-3">

                @if (Model.EstaVazio)
                {
                    <div class="bc-cart__items-wrapper d-flex flex-column align-items-center justify-content-center">
                        <i class="fa-solid fa-cart-plus mb-3 opacity-25" style="font-size: 3rem;"></i>
                        <div class="text-muted fw-medium">Seu carrinho está vazio</div>
                    </div>
                }
                else
                {
                    <div class="bc-cart__items-wrapper mb-4">
                        @foreach (var item in Model.Itens)
                        {
                            <div class="bc-cart__item">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div class="pe-2 flex-grow-1">
                                        <div class="fw-bold bc-cart__item-name">@item.Nome</div>
                                    </div>

                                    <div class="fw-bold bc-cart__item-price text-end">
                                        @item.Total.ToString("C", new CultureInfo("pt-BR"))
                                    </div>
                                </div>
                                <div class="cart-mobile__actions">
                                    <div class="cart-mobile__qty-group">
                                        <span class="cart-mobile__qty-label">Qtd</span>
                                        <input type="number"
                                            min="1"
                                            value="@item.Quantidade"
                                            class="cart-mobile__qty-input js-qtd-carrinho-mobile"
                                            data-item-id="@item.ItemId" />
                                    </div>

                                    <button type="button"
                                            class="cart-mobile__remove-btn js-remover-item-carrinho-mobile"
                                            data-item-id="@item.ItemId"
                                            title="Remover item">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                                
                                @if (item.Acompanhamentos.Any())
                                {
                                    <ul class="list-unstyled bc-cart__acc-list mt-2">
                                        @foreach (var a in item.Acompanhamentos)
                                        {
                                            <li class="bc-cart__acc-item">
                                                <span><i class="fa-solid fa-plus small me-1 opacity-50"></i>@a.Nome</span>
                                                <span>@a.Preco.ToString("C", new CultureInfo("pt-BR"))</span>
                                            </li>
                                        }
                                    </ul>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.Observacao))
                                {
                                    <div class="small text-muted mt-1">
                                        <i class="fa-regular fa-comment-dots me-1 opacity-75"></i>
                                        <span>@item.Observacao</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }

                <div class="bc-cart__summary mb-4">
                    <div class="d-flex justify-content-between text-muted small mb-1">
                        <span>Subtotal</span>
                        <span>@Model.Subtotal.ToString("C", new CultureInfo("pt-BR"))</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold bc-cart__total-row">
                        <span>Total</span>
                        <span>@Model.Total.ToString("C", new CultureInfo("pt-BR"))</span>
                    </div>
                </div>

                @if (!Model.EstaVazio)
                {
                    if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn w-100 btn-checkout shadow-sm js-confirmar-add-produto-mobile" style="background: #D98C1A; color: rgb(255, 255, 255); font-weight: 700;"
                                @(Model.EstaVazio ? "disabled" : "")
                                data-carrinho-id="@Model.CarrinhoId">
                            FINALIZAR PEDIDO
                        </button>

                    }
                    else
                    {
                        <button type="button"
                                class="btn w-100 d-flex align-items-center justify-content-center fw-bold btn-login-cart btn-checkout js-login-carrinho-mobile">
                            <i class="fa-solid fa-circle-user fs-5 me-2"></i>
                            ENTRAR PARA FINALIZAR
                        </button>
                    }
                }

            </div>
        </div>

    </div>
    <!-- 🔥 FIM WRAPPER -->
</div>


<script>
    $(document).on('click', '.js-confirmar-add-produto-mobile', function () {
        $.ajax({
            url: '/Pedido/BuscarModalFinalizarPedido',
            method: 'GET',
            beforeSend: function () {
                addLoading("Carregando...");
            },
            success: function (html) {
                const $conteudo = $('#conteudo-dinamico');
                $conteudo.empty().html(html);

                const el = document.getElementById('modalFinalizarPedido');
                const modal = bootstrap.Modal.getOrCreateInstance(el);

                modal.show();

                if (window.wizardInitFinalizarPedido) {
                    window.wizardInitFinalizarPedido();
                }
            },

            error: function (xhr) {
                alert(xhr.responseText || 'Erro ao carregar o modal.');
            },

            complete: function () {
                removeLoading();
            }
        });
    });

    $(document).on('click', '.js-login-carrinho-mobile', function () {
        const modalCarrinhoEl = document.getElementById('modalCarrinhoMobile');

        function carregarEExibirLogin() {
            $.ajax({
                url: '/Cliente/BuscarModalAutenticacaoCliente',
                method: 'GET',
                cache: false,
                beforeSend: function () {
                    addLoading("Carregando...");
                },
                success: function (html) {
                    $('#conteudo-dinamico').empty();
                    $('#conteudo-dinamico').html(html);

                    const modalLoginEl    = document.getElementById('modal-cliente-auth');
                    const modalLogin = bootstrap.Modal.getOrCreateInstance(modalLoginEl);
                    modalLogin.show();
                },
                error: function () {
                    $body.html('<div class="text-danger p-3">Não foi possível carregar seus dados agora.</div>');
                },
                complete: function () {
                    removeLoading();
                }
            });
        }

        const modalCarrinho = modalCarrinhoEl ? bootstrap.Modal.getInstance(modalCarrinhoEl) : null;

        if (modalCarrinho && modalCarrinhoEl.classList.contains('show')) {
            modalCarrinhoEl.addEventListener('hidden.bs.modal', carregarEExibirLogin, { once: true });
            modalCarrinho.hide();
        } else {
            carregarEExibirLogin();
        }
    });

    let resizeTimeout = null;

    $(window).on('resize', function () {
        clearTimeout(resizeTimeout);

        resizeTimeout = setTimeout(() => {
            fecharCarrinhoSeDesktop();
        }, 150); // debounce leve
    });

    function fecharCarrinhoSeDesktop() {
        if (window.innerWidth >= 1200) {
            const modalEl = document.getElementById('modalCarrinhoMobile');
            if (!modalEl) return;

            const modalInstance = bootstrap.Modal.getInstance(modalEl);
            if (modalInstance) {
                modalInstance.hide();
            }
        }
    }

    $(document).on('focus', '.js-qtd-carrinho-mobile', function () {
        $(this).data('valor-original', $(this).val());
    });

    $(document).on('blur', '.js-qtd-carrinho-mobile', function () {
        const input = $(this);
        const valorOriginal = input.data('valor-original');
        let quantidade = parseInt(input.val());
        const itemId = input.data('item-id');

        if (!quantidade || quantidade < 1) {
            quantidade = 1;
            input.val(1);
        }

        if (String(valorOriginal) === String(quantidade)) {
            return;
        }

        //addLoading("Atualizando carrinho...");

        $.ajax({
            url: '/Carrinho/AtualizarQuantidade',
            type: 'POST',
            data: {
                itemId: itemId,
                quantidade: quantidade
            },
            success: function (response) {
                if (response.sucesso) {
                    recarregarCarrinhoEFooter();
                    removeLoading();
                } else {
                    alert(response.mensagem || 'Não foi possível atualizar a quantidade.');
                }
            },
            error: function (xhr) {
                alert(xhr.responseText || 'Erro ao atualizar quantidade.');
            },
            complete: function () {
                removeLoading();
            }
        });
    });

    $(document).on('click', '.js-remover-item-carrinho-mobile', function () {
        const botao = $(this);
        const itemId = botao.data('item-id');

        if (!confirm('Deseja remover este item do carrinho?')) {
            return;
        }

        addLoading("Removendo item...");

        $.ajax({
            url: '/Carrinho/RemoverItem',
            type: 'POST',
            data: {
                itemId: itemId
            },
            success: function (response) {
                if (response.sucesso) {
                    //location.reload();
                     recarregarCarrinhoEFooter();
                } else {
                    alert(response.mensagem || 'Não foi possível remover o item.');
                }
            },
            error: function (xhr) {
                alert(xhr.responseText || 'Erro ao remover item.');
            },
            complete: function () {
                removeLoading();
            }
        });
    });
</script>