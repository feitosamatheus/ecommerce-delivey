@using System.Globalization
@using Ecommerce.MVC.Models.Carrinhos
@model CarrinhoViewModel

<style>
    /* ============================
       CART MOBILE (ISOLADO)
       ============================ */

    .cart-mobile .bc-cart-container {
        border-radius: 20px; 
        box-shadow:none;
        background: #fff;
    }

    .cart-mobile .bc-cart__items-wrapper {
        max-height: 55vh;
        overflow-y: auto;
    }

    .cart-mobile .bc-cart__item {
        padding: 12px 0;
        border-bottom: 1px dashed #eee;
    }

    .cart-mobile .bc-cart__item-name {
        font-size: 0.95rem;
    }

    .cart-mobile .bc-cart__summary {
        background: #fdfdfd;
        border-radius: 12px;
    }

    .cart-mobile .bc-cart__total-row {
        font-size: 1.1rem;
        border-top: 2px solid #f0f0f0;
    }

    .btn-checkout-mobile {
        border-radius: 6px;
        padding: 12px;
        background: #B26528;
        transition: 0.3s;
    }

        .btn-checkout-mobile:hover {
            background: #8E4F1E;
            color: #fff;
        }

    .modal.fade.modal-swap {
        transition: opacity .25s ease, transform .25s ease;
    }

        .modal.fade.modal-swap.show {
            transform: translateY(0);
        }

    .modal.fade.modal-swap {
        transform: translateY(20px);
    }

    .cart-mobile .bc-cart__acc-list {
        background-color: #f8f9fa;
        border-radius: 10px;
        padding: 8px 12px;
        margin-top: 8px;
    }

    .cart-mobile .bc-cart__acc-item {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: #636e72;
        padding: 2px 0;
    }

    .cart-mobile .cart-mobile__actions {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
        justify-content: space-between;
    }

    .cart-mobile .cart-mobile__qty-group {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 6px 10px;
        border: 1px solid #ececec;
        border-radius: 6px;
        background: #fafafa;
    }

    .cart-mobile .cart-mobile__qty-label {
        font-size: 0.74rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        line-height: 1;
    }

    .cart-mobile .cart-mobile__qty-input {
        width: 52px;
        height: 32px;
        border: 1px solid #ddd;
        border-radius: 8px;
        text-align: center;
        font-size: 0.92rem;
        font-weight: 600;
        background: #fff;
        color: #2d3436;
        outline: none;
        transition: all 0.2s ease;
        box-shadow: none;
    }

    .cart-mobile .cart-mobile__qty-input:focus {
        border-color: #D98C1A;
        box-shadow: 0 0 0 3px rgba(217, 140, 26, 0.15);
    }

    /* .cart-mobile .cart-mobile__qty-input::-webkit-outer-spin-button,
    .cart-mobile .cart-mobile__qty-input::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    .cart-mobile .cart-mobile__qty-input[type=number] {
        -moz-appearance: textfield;
    } */
    .cart-mobile .cart-mobile__qty-input {
        appearance: auto;
    }

    .cart-mobile .cart-mobile__remove-btn {
        width: 38px;
        height: 38px;
        border: 1px solid #f3d1d1;
        background: #fff5f5;
        color: #c0392b;
        border-radius: 6px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
    }

    .cart-mobile .cart-mobile__remove-btn:hover {
        background: #fdecec;
        border-color: #e7b8b8;
        color: #a5281b;
    }

    .cart-mobile .cart-mobile__remove-btn:active {
        transform: scale(0.98);
    }

    .cart-mobile .bc-cart__item-price {
        white-space: nowrap;
        font-size: 0.95rem;
        color: #2d3436;
    }
</style>


<div class="modal-header pb-3 d-flex justify-content-between align-items-center mb-1" style="border-bottom: 1px solid #f0f0f0;">
    @* <div style="line-height: 4px;">
        <h5 class="modal-title fw-bold mb-0" style="color:#3c1e0a;">Adicionar ao pedido</h5>
        <small class="text-muted">Escolha os complementos ideais</small>
    </div> *@
    <div class="text-start d-flex align-items-center">
        <h5 class="modal-title fw-bolder mb-0">
            <i class="fa-solid fa-bag-shopping me-2" style="color: #edcd9a;"></i>
            <span style="color: #4A2A15;">Meu Carrinho</span>
            <span class="badge bg-light text-dark rounded-pill" style="position: relative; top: -1px;">@Model.Itens.Count</span>
        </h5>
    </div>
    <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Fechar">
        <i class="fa-solid fa-xmark"></i>
    </button>
</div>

<div class="modal-body p-0">
    <!-- 🔥 WRAPPER EXCLUSIVO -->
    <div class="cart-mobile">

        <div class="col-12">
            <div class="bc-cart-container px-3 pb-4 pt-3">

                @if (Model.EstaVazio)
                {
                    <div class="bc-cart__items-wrapper d-flex flex-column align-items-center justify-content-center py-5">
                        <i class="fa-solid fa-cart-plus mb-3 opacity-25" style="font-size: 3rem;"></i>
                        <div class="text-muted fw-medium">Seu carrinho está vazio</div>
                    </div>
                }
                else
                {
                    <div class="bc-cart__items-wrapper mb-4">
                        @foreach (var item in Model.Itens)
                        {
                            @* <div class="bc-cart__item mb-2" style="    background: #fbfbfb;
                                padding: 10px;
                                border-radius: 9px; border:none;">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div class="pe-2 flex-grow-1">
                                        <div class="fw-bold bc-cart__item-name">@item.Nome</div>
                                    </div>

                                    <div class="fw-bold bc-cart__item-price text-end">
                                        @item.Total.ToString("C", new CultureInfo("pt-BR"))
                                    </div>
                                </div>
                                <div class="cart-mobile__actions">
                                    <div class="cart-mobile__qty-group">
                                        <span class="cart-mobile__qty-label">Qtd</span>
                                        <input type="number"
                                            min="1"
                                            value="@item.Quantidade"
                                            class="cart-mobile__qty-input js-qtd-carrinho-mobile"
                                            data-item-id="@item.ItemId" />
                                    </div>

                                    <button type="button"
                                            class="cart-mobile__remove-btn js-remover-item-carrinho-mobile"
                                            data-item-id="@item.ItemId"
                                            title="Remover item">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                                
                                @if (item.Acompanhamentos.Any())
                                {
                                    <ul class="list-unstyled bc-cart__acc-list mt-2">
                                        @foreach (var a in item.Acompanhamentos)
                                        {
                                            <li class="bc-cart__acc-item">
                                                <span><i class="fa-solid fa-plus small me-1 opacity-50"></i>@a.Nome</span>
                                                <span>@a.Preco.ToString("C", new CultureInfo("pt-BR"))</span>
                                            </li>
                                        }
                                    </ul>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.Observacao))
                                {
                                    <div class="small text-muted mt-1">
                                        <i class="fa-regular fa-comment-dots me-1 opacity-75"></i>
                                        <span>@item.Observacao</span>
                                    </div>
                                }
                            </div> *@

                            <div class="bc-cart__item mb-2" style="background: #fbfbfb; padding: 12px; border-radius: 9px; border: none;">
    
                                <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                                    <div class="fw-bold bc-cart__item-name text-truncate" style="max-width: 70%;">
                                        @item.Nome
                                    </div>
                                    <div class="small text-muted fw-medium">
                                        @item.PrecoUnitario.ToString("C", new CultureInfo("pt-BR"))
                                    </div>
                                </div>

                                @if (item.Acompanhamentos.Any())
                                {
                                    <ul class="list-unstyled bc-cart__acc-list my-2" style="background: #f1f1f1; border-radius: 6px; padding: 8px;">
                                        @foreach (var a in item.Acompanhamentos)
                                        {
                                            <li class="bc-cart__acc-item d-flex justify-content-between small text-muted">
                                                <span><i class="fa-solid fa-plus small me-1 opacity-50"></i>@a.Nome</span>
                                                <span>@a.Preco.ToString("C", new CultureInfo("pt-BR"))</span>
                                            </li>
                                        }
                                    </ul>
                                }

                                @if (!string.IsNullOrWhiteSpace(item.Observacao))
                                {
                                    <div class="small text-muted mt-1 mb-2 italic">
                                        <i class="fa-regular fa-comment-dots me-1 opacity-75"></i>
                                        <span>@item.Observacao</span>
                                    </div>
                                }

                                <hr class="my-2" style="opacity: 0.1;">

                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="d-flex align-items-center" style="background: #fff; border-radius: 8px; border: 1px solid #ececec; overflow: hidden;">
                                            <button type="button" class="btn btn-sm px-2 js-minus-qty" style="color: #D98C1A; border: none;">
                                                <i class="fa-solid fa-minus" style="font-size: 0.75rem;"></i>
                                            </button>
                
                                            <input type="number" value="@item.Quantidade" class="js-qtd-carrinho-mobile" data-item-id="@item.ItemId" readonly
                                                   style="width: 30px; border: none; text-align: center; font-weight: bold; font-size: 0.85rem; background: transparent;" />

                                            <button type="button" class="btn btn-sm px-2 js-plus-qty" style="color: #D98C1A; border: none;">
                                                <i class="fa-solid fa-plus" style="font-size: 0.75rem;"></i>
                                            </button>
                                        </div>

                                        <button type="button" class="bc-cart__remove-btn js-remover-item-carrinho-mobile" data-item-id="@item.ItemId"
                                                style="width: 32px; height: 32px; border-radius: 8px; border: none; background: #fff5f5; color: #c0392b;">
                                            <i class="fa-solid fa-trash-can" style="font-size: 0.8rem;"></i>
                                        </button>
                                    </div>

                                    <div class="text-end">
                                        <span class="small text-muted d-block" style="font-size: 0.7rem; text-transform: uppercase;">Total</span>
                                        <div class="fw-bold text-dark" style="font-size: 1rem;">
                                            @item.Total.ToString("C", new CultureInfo("pt-BR"))
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="bc-cart__summary mb-4">
                    <div class="d-flex justify-content-between text-muted small mb-1">
                        <span>Subtotal</span>
                        <span>@Model.Subtotal.ToString("C", new CultureInfo("pt-BR"))</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold bc-cart__total-row">
                        <span>Total</span>
                        <span>@Model.Total.ToString("C", new CultureInfo("pt-BR"))</span>
                    </div>
                </div>

                @if (!Model.EstaVazio)
                {
                    if (User.Identity.IsAuthenticated)
                    {
                        <button class="btn w-100 btn-checkout-mobile shadow-sm js-confirmar-add-produto-mobile mb-2" style="background: #B26528; color: rgb(255, 255, 255); font-weight: 700;"
                                @(Model.EstaVazio ? "disabled" : "")
                                data-carrinho-id="@Model.CarrinhoId">
                            FINALIZAR PEDIDO
                        </button>
                        <button type="button" class="btn btn-light w-100 fw-bold" style="color: #3c1e0a; background-color: #f8f9fa; padding:12px; font-weight: 700;"
                                data-bs-dismiss="modal">
                            <i class="fas fa-times me-2"></i>
                            <span>Fechar</span>
                        </button>
 

                    }
                    else
                    {
                        <button type="button"
                                class="btn w-100 d-flex align-items-center justify-content-center mb-2 fw-bold btn-login-cart btn-checkout-mobile js-login-carrinho-mobile">
                            <i class="fa-solid fa-circle-user fs-5 me-2"></i>
                            ENTRAR PARA FINALIZAR
                        </button>
                        <button type="button" class="btn btn-light w-100 fw-bold" style="color: #3c1e0a; background-color: #f8f9fa; padding:12px; font-weight: 700;"
                                data-bs-dismiss="modal">
                            <i class="fas fa-times me-2"></i>
                            <span>Fechar</span>
                        </button>
                    }
                }

            </div>
        </div>

    </div>
    <!-- 🔥 FIM WRAPPER -->
</div>


<script>
    // 1. EVENTO UNIFICADO PARA BOTÕES DE + E - (Desktop e Mobile)
    $(document).on('click', '.js-plus-qty, .js-minus-qty', function () {
        const $btn = $(this);
        // Busca o input que seja "irmão" do botão
        const $input = $btn.siblings('.js-qtd-carrinho-mobile');
        const isPlus = $btn.hasClass('js-plus-qty');
        const qtdAtual = parseInt($input.val()) || 1;

        // Captura o valor original antes da mudança
        $input.trigger('focus');

        let novaQtd = isPlus ? qtdAtual + 1 : qtdAtual - 1;
        if (novaQtd < 1) novaQtd = 1;

        // Atualiza o valor e dispara o AJAX via blur
        $input.val(novaQtd).trigger('blur');
    });

    // 2. ATUALIZAÇÃO DE QUANTIDADE (AJAX UNIFICADO)
    $(document).on('focus', '.js-qtd-carrinho-mobile', function () {
        $(this).data('valor-original', $(this).val());
    });

    $(document).on('blur', '.js-qtd-carrinho-mobile', function () {
        const input = $(this);
        const valorOriginal = input.data('valor-original');
        let quantidade = parseInt(input.val());
        const itemId = input.data('item-id');

        if (!quantidade || quantidade < 1) {
            quantidade = 1;
            input.val(1);
        }

        // Evita chamadas desnecessárias se o valor não mudou
        if (String(valorOriginal) === String(quantidade)) return;

        addLoading("Atualizando...");

        $.ajax({
            url: '/Carrinho/AtualizarQuantidade',
            type: 'POST',
            data: { itemId: itemId, quantidade: quantidade },
            success: function (response) {
                if (response.sucesso) {
                    recarregarCarrinhoEFooter();
                } else {
                    alert(response.mensagem || 'Erro ao atualizar.');
                    input.val(valorOriginal);
                }
            },
            error: function () {
                alert('Erro ao atualizar quantidade.');
                input.val(valorOriginal);
                removeLoading();
            }
        });
    });

    // 3. REMOVER ITEM (UNIFICADO)
    $(document).on('click', '.js-remover-item-carrinho-mobile, .js-remover-item-carrinho', function () {
        const botao = $(this);
        const itemId = botao.data('item-id');

        // 1. Exibe o confirm nativo do navegador
        if (confirm('Deseja remover este item do carrinho?')) {
        
            addLoading("Removendo...");

            $.ajax({
                url: '/Carrinho/RemoverItem',
                type: 'POST',
                data: { itemId: itemId },
                success: function (response) {
                    if (response.sucesso) {
                        recarregarCarrinhoEFooter();
                    } else {
                        // 2. Exibe o alert nativo em caso de erro retornado pelo servidor
                        alert(response.mensagem || 'Não foi possível remover o item.');
                    }
                },
                error: function () {
                    // 3. Exibe o alert nativo em caso de falha na requisição
                    alert('Erro ao processar a remoção do item.');
                },
                complete: function () {
                    removeLoading();
                }
            });
        }
    });

    // 4. MODAIS E UTILITÁRIOS (FINALIZAR PEDIDO / LOGIN)
    $(document).on('click', '.js-confirmar-add-produto-mobile', function () {
        addLoading("Carregando...");
        $.ajax({
            url: '/Pedido/BuscarModalFinalizarPedido',
            method: 'GET',
            success: function (html) {
                $('#conteudo-dinamico').empty().html(html);
                const modal = bootstrap.Modal.getOrCreateInstance(document.getElementById('modalFinalizarPedido'));
                modal.show();
                if (window.wizardInitFinalizarPedido) window.wizardInitFinalizarPedido();
            },
            complete: function () { removeLoading(); }
        });
    });

    $(document).on('click', '.js-login-carrinho-mobile', function () {
        const carregarLogin = () => {
            addLoading("Carregando...");
            $.ajax({
                url: '/Cliente/BuscarModalAutenticacaoCliente',
                method: 'GET',
                success: function (html) {
                    $('#conteudo-dinamico').empty().html(html);
                    bootstrap.Modal.getOrCreateInstance(document.getElementById('modal-cliente-auth')).show();
                },
                complete: function () { removeLoading(); }
            });
        };

        const modalCarrinhoEl = document.getElementById('modalCarrinhoMobile');
        const modalCarrinho = modalCarrinhoEl ? bootstrap.Modal.getInstance(modalCarrinhoEl) : null;

        if (modalCarrinho && modalCarrinhoEl.classList.contains('show')) {
            modalCarrinhoEl.addEventListener('hidden.bs.modal', carregarLogin, { once: true });
            modalCarrinho.hide();
        } else {
            carregarLogin();
        }
    });

    // 5. RESIZE
    let resizeTimeout;
    $(window).on('resize', function () {
        clearTimeout(resizeTimeout);
        resizeTimeout = setTimeout(() => {
            if (window.innerWidth >= 1200) {
                const modalEl = document.getElementById('modalCarrinhoMobile');
                if (modalEl) {
                    const inst = bootstrap.Modal.getInstance(modalEl);
                    if (inst) inst.hide();
                }
            }
        }, 150);
    });
</script>