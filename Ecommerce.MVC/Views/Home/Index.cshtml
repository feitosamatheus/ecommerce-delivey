<style>
    .bc-panel-none:empty {
        display: none;
    }

    .modal-backdrop.fade {
        transition: opacity 0.2s linear;
    }

    .modal.fade .modal-dialog {
        transition: transform 0.2s ease-out;
    }

    .carrinho-loading-wrapper {
        position: relative;
        min-height: 180px;
    }

    .carrinho-loading-wrapper.is-loading > *:not(.carrinho-loading-overlay) {
        filter: blur(3px);
        pointer-events: none;
        user-select: none;
    }

    .carrinho-loading-overlay {
        position: absolute;
        inset: 0;
        background: rgba(255, 255, 255, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 16px;
        z-index: 20;
    }

    .carrinho-loading-overlay.d-none {
        display: none;
    }

    .carrinho-loading-spinner {
        width: 42px;
        height: 42px;
        border: 4px solid rgba(217, 140, 26, 0.18);
        border-top-color: #D98C1A;
        border-radius: 50%;
        animation: carrinho-spin .8s linear infinite;
    }

    .bc-panel.d-none,
    .bc-prod-col.d-none {
        display: none !important;
    }

    @@keyframes carrinho-spin {
        to {
            transform: rotate(360deg);
        }
    }
</style>
<style>
