    window.iniciarModalAdicionarProduto = function () {
        const modalEl = document.getElementById('modalAddProduto');
        if (!modalEl) return;

        const form = modalEl.querySelector('#formAdicionarProdutoCarrinho');
        if (!form) return;

        const inputPrecoBase = modalEl.querySelector('#modalPrecoBase');
        const inputQtd = modalEl.querySelector('#quantidadeProduto');
        const btnMenos = modalEl.querySelector('#btnDiminuirQtd');
        const btnMais = modalEl.querySelector('#btnAumentarQtd');
        const totalEl = modalEl.querySelector('#valorTotalProduto');

        const precoPrincipalEl = modalEl.querySelector('#modalPrecoPrincipal');
        const precoCentavosEl = modalEl.querySelector('#modalPrecoCentavos');

        if (!inputPrecoBase || !inputQtd || !btnMenos || !btnMais || !totalEl) return;

        const precoBase = Number(inputPrecoBase.value || 0);

        function moedaBR(valor) {
            return valor.toLocaleString('pt-BR', {
                style: 'currency',
                currency: 'BRL'
            });
        }

        function formatarPrecoVisual(valor) {
            const formatado = valor.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            const partes = formatado.split(',');

            return {
                inteiro: partes[0],
                centavos: ',' + (partes[1] || '00')
            };
        }

        function obterQuantidade() {
            let qtd = parseInt(inputQtd.value, 10) || 1;

            if (qtd < 1) {
                qtd = 1;
                inputQtd.value = 1;
            }

            return qtd;
        }

        function obterAdicionalSelecionado() {
            let adicional = 0;

            form.querySelectorAll('.acomp-input:checked').forEach(function (input) {
                adicional += Number(input.dataset.preco || 0);
            });

            return adicional;
        }

        function atualizarPrecoUnitario(adicional) {
            const precoUnitario = precoBase + adicional;
            const partes = formatarPrecoVisual(precoUnitario);

            if (precoPrincipalEl) {
                precoPrincipalEl.textContent = partes.inteiro;
            }

            if (precoCentavosEl) {
                precoCentavosEl.textContent = partes.centavos;
            }
        }

        function calcularTotal() {
            const qtd = obterQuantidade();
            const adicional = obterAdicionalSelecionado();

            const precoUnitario = precoBase + adicional;
            const total = precoUnitario * qtd;

            atualizarPrecoUnitario(adicional);
            totalEl.textContent = moedaBR(total);
        }

        function controlarSelecaoUnicaPorCategoria(checkboxAtual) {
            if (!checkboxAtual) return;

            const categoriaId = checkboxAtual.dataset.categoriaId;
            if (!categoriaId) return;

            const containerCategoria = checkboxAtual.closest('[data-acomp-categoria]');
            if (!containerCategoria) return;

            const max = parseInt(containerCategoria.dataset.max || '0', 10);

            if (max === 1 && checkboxAtual.checked) {
                form.querySelectorAll('.acomp-input[data-categoria-id="' + categoriaId + '"]').forEach(function (item) {
                    if (item !== checkboxAtual) {
                        item.checked = false;
                    }
                });
            }
        }

        btnMenos.onclick = function () {
            let qtdAtual = obterQuantidade();
            qtdAtual = Math.max(qtdAtual - 1, 1);
            inputQtd.value = qtdAtual;
            calcularTotal();
        };

        btnMais.onclick = function () {
            let qtdAtual = obterQuantidade();
            qtdAtual = qtdAtual + 1;
            inputQtd.value = qtdAtual;
            calcularTotal();
        };

        inputQtd.oninput = calcularTotal;
        inputQtd.onchange = calcularTotal;
        inputQtd.onblur = calcularTotal;

        form.querySelectorAll('.acomp-input').forEach(function (input) {
            input.onchange = function () {
                controlarSelecaoUnicaPorCategoria(this);
                calcularTotal();
            };
        });

        calcularTotal();
    };

    // =========================
    // Modal - carregar produto
    // =========================
    const host = document.getElementById('modalHost');

    async function abrirModalProduto(produtoId) {
        if (!host) return;

        const old = document.getElementById('modalAddProduto');
        if (old) old.remove();

        try {
            addLoading("Carregando...");

            const resp = await fetch(`/Produto/BuscarModalAdicionarProduto?id=${encodeURIComponent(produtoId)}`, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!resp.ok) {
                throw new Error(`Erro HTTP ${resp.status}`);
            }

            const html = await resp.text();
            host.innerHTML = html;

            iniciarModalAdicionarProduto();

            const modalEl = document.getElementById('modalAddProduto');
            if (!modalEl) return;

            modalEl.addEventListener('hidden.bs.modal', function () {
                modalEl.remove();
            }, { once: true });

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();

        } catch (err) {
            console.error('Erro ao carregar modal:', err);
            alert('Não foi possível carregar o produto. Tente novamente.');
        } finally {
            removeLoading();
        }
    }

    // =========================
    // Clique nos produtos
    // =========================
    document.addEventListener('click', (e) => {
        const el = e.target.closest('.bc-product-clickable');
        if (!el) return;

        const produtoId = el.dataset.produtoId;
        if (!produtoId) return;

        abrirModalProduto(produtoId);
    });

    // =========================
    // Limpar filtro
    // =========================
    window.limparFiltroTexto = function () {
        const inputBusca = document.getElementById("filtroNome");
        const inputBuscaMobile = document.getElementById("filtroNomeMobile");

        if (inputBusca) inputBusca.value = "";
        if (inputBuscaMobile) inputBuscaMobile.value = "";

        filterState.texto = "";

        document.getElementById('emptySearchState')?.classList.add('d-none');
        document.getElementById('emptySearchState')?.classList.remove('d-flex');

        document.getElementById('emptySearchStateDesktop')?.classList.add('d-none');
        document.getElementById('emptySearchStateDesktop')?.classList.remove('d-flex');

        applyFilters();
    };

    // =========================
    // Boot
    // =========================
    document.addEventListener("DOMContentLoaded", () => {
        setupFilterLogic("");
        setupFilterLogic("Mobile");

        document.addEventListener("click", () => {
            document.querySelectorAll(".bc-select").forEach((s) => s.classList.remove("is-open"));
        });

        applyFilters();
    });

})();

