    function recalcularTotalModal(form) {
        if (!form) return;

        const modal = form.closest('#modalAddProduto');
        if (!modal) return;

        const inputPrecoBase = modal.querySelector('#modalPrecoBase');
        const inputQtd = modal.querySelector('#quantidadeProduto');
        const totalEl = modal.querySelector('#valorTotalProduto');

        if (!inputPrecoBase || !inputQtd || !totalEl) return;

        const precoBase = Number(inputPrecoBase.value || 0);
        let qtd = parseInt(inputQtd.value, 10) || 1;

        if (qtd < 1) {
            qtd = 1;
            inputQtd.value = 1;
        }

        let adicional = 0;

        form.querySelectorAll('.acomp-input:checked').forEach(function (input) {
            adicional += Number(input.dataset.preco || 0);
        });

        const total = (precoBase + adicional) * qtd;

        totalEl.textContent = total.toLocaleString('pt-BR', {
            style: 'currency',
            currency: 'BRL'
        });
    }
