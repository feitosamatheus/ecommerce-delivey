                                $"data-produto-id=\"{p.Id}\" " +
                                $"data-categoria-id=\"{categoria.Id}\" " +
                                $"data-nome=\"{nomeHtml}\">" +
                                $"<div class=\"bc-product__thumb\" style=\"{thumbStyle}\"></div>" +
                                "<div class=\"bc-product__info mt-3 text-center\">" +
                                    $"<div class=\"bc-product__title fw-bold\">{nomeHtml}</div>" +
                                    (string.IsNullOrWhiteSpace(descricaoHtml)
                                        ? ""
                                        : $"<div class=\"bc-product__desc text-muted small mt-1\">{descricaoHtml}</div>") +
                                    $"<div class=\"bc-product__price fw-bold mt-1\">{precoHtml}</div>" +
                                "</div>" +
                                $"<button type=\"button\" class=\"bc-product__add bc-product-clickable\" aria-label=\"Adicionar ao carrinho\" data-produto-id=\"{p.Id}\">" +
                                    "<i class=\"fa-solid fa-plus\"></i>" +
                                "</button>" +
                            "</div>" +
                        "</div>";

                    return new
                    {
                        produtoId = p.Id,
                        categoriaId = categoria.Id,
                        nome = p.Nome,
                        html
                    };
                }).ToList();

                <div class="bc-panel p-3 mb-3"
                    data-categoria-id="@categoria.Id"
                    data-display-type="carrossel"
                    data-items-per-slide="2"
                    data-original-items='@Html.Raw(JsonSerializer.Serialize(originalMobileItems))'
                    style="border-radius: 5px;">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <h5 class="mb-0 fw-bold">@categoria.Nome</h5>
                    </div>

                    <div id="@carouselId" class="carousel slide mb-4" data-bs-ride="false">
                        @if (slides.Count > 1)
                        {
                            <div class="carousel-indicators bc-carousel__indicators">
                                @for (int i = 0; i < slides.Count; i++)
                                {
                                    <button type="button"
                                            data-bs-target="#@carouselId"
                                            data-bs-slide-to="@i"
                                            class="@(i == 0 ? "active" : "")"
                                            aria-current="@(i == 0 ? "true" : "false")"
                                            aria-label="Slide @(i + 1)"></button>
                                }
                            </div>
                        }

                        <div class="carousel-inner">
                            @for (int i = 0; i < slides.Count; i++)
                            {
                                var slide = slides[i];

                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <div class="row g-3">
                                        @foreach (var p in slide)
                                        {
                                            <div class="col-6 col-md-4 bc-carousel-col bc-prod-col"
                                                data-produto-id="@p.Id"
                                                data-categoria-id="@categoria.Id"
                                                data-nome="@p.Nome">
                                                <div class="bc-product bc-product--vertical bc-product-clickable p-3"
                                                    data-produto-id="@p.Id"
                                                    data-categoria-id="@categoria.Id"
                                                    data-nome="@p.Nome">
                                                    <div class="bc-product__thumb"
                                                        style="@(string.IsNullOrWhiteSpace(p.ImagemUrl) ? "" : $"background-image:url('{p.ImagemUrl}')")">
                                                    </div>

                                                    <div class="bc-product__info mt-3 text-center">
                                                        <div class="bc-product__title fw-bold">@p.Nome</div>

                                                        @if (!string.IsNullOrWhiteSpace(p.Descricao))
                                                        {
                                                            <div class="bc-product__desc text-muted small mt-1">
                                                                @(p.Descricao.Length > 55 ? p.Descricao.Substring(0, 55) + "..." : p.Descricao)
                                                            </div>
                                                        }

                                                        <div class="bc-product__price fw-bold mt-1">
                                                            @p.Preco.ToString("C", new CultureInfo("pt-BR"))
                                                        </div>
                                                    </div>

                                                    <button type="button"
                                                            class="bc-product__add bc-product-clickable"
                                                            aria-label="Adicionar ao carrinho"
                                                            data-produto-id="@p.Id">
                                                        <i class="fa-solid fa-plus"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        @if (slides.Count > 1)
                        {
                            <button class="carousel-control-prev bc-carousel__btn"
                                    type="button"
                                    data-bs-target="#@carouselId"
                                    data-bs-slide="prev">
                                <i class="fa-solid fa-chevron-left"></i>
                            </button>

                            <button class="carousel-control-next bc-carousel__btn"
                                    type="button"
                                    data-bs-target="#@carouselId"
                                    data-bs-slide="next">
                                <i class="fa-solid fa-chevron-right"></i>
                            </button>
                        }
                    </div>
                </div>
            }
            else if (categoria.TipoExibicao == ETipoExibicao.Bloco)
            {
                <div class="bc-panel p-3 mb-2"
                    data-categoria-id="@categoria.Id"
                    data-display-type="bloco"
                    style="border-radius: 5px;">
                    <h5 class="mb-3 fw-bold">@categoria.Nome</h5>

                    <div class="row g-3 row-cols-1 row-cols-md-2">
                        @foreach (var p in produtos)
                        {
                            <div class="col bc-prod-col"
                                data-produto-id="@p.Id"
                                data-categoria-id="@categoria.Id"
                                data-nome="@p.Nome">
                                <div class="bc-product bc-product-clickable p-3"
                                    data-produto-id="@p.Id"
                                    data-categoria-id="@categoria.Id"
                                    data-nome="@p.Nome">
                                    <div class="d-flex gap-3">
                                        <div class="flex-grow-1 bc-product__info d-flex flex-column">
                                            <div class="mb-auto">
                                                <div class="fw-bold text-dark mb-1" style="font-size: 1.05rem; line-height: 1.2;">
                                                    @p.Nome
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(p.Descricao))
                                                {
                                                    <div class="text-muted small lh-sm" style="font-size: 0.85rem;">
                                                        @(p.Descricao.Length > 60 ? p.Descricao.Substring(0, 60) + "..." : p.Descricao)
                                                    </div>
                                                }
                                            </div>

                                            <div class="mt-2 fw-bold bc-product__price" style="font-size: 1.1rem; color: #D98C1A;">
                                                @p.Preco.ToString("C", new CultureInfo("pt-BR"))
                                            </div>
                                        </div>

                                        <div class="bc-product__thumb"
                                            style="@(string.IsNullOrWhiteSpace(p.ImagemUrl) ? "" : $"background-image:url('{p.ImagemUrl}')")">
                                        </div>
                                    </div>

                                    <button type="button" class="bc-product__add bc-product-clickable" aria-label="Adicionar ao carrinho" data-produto-id="@p.Id">
                                        <i class="fa-solid fa-plus"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        <div id="emptySearchState" class="d-none flex-column align-items-center justify-content-center py-2 px-0 w-100">
            <div class="text-center p-5 bg-white shadow-sm" style="margin: 0 auto; border-radius:5px;">
                <div class="mb-4 opacity-25">
                    <i class="fa-solid fa-magnifying-glass-chart fa-4x text-secondary"></i>
                </div>
                <h4 class="fw-bold" style="color: #3c1e0a;">Ops! Não encontramos nada</h4>
                <p class="text-muted mb-4">
                    Não existem produtos que correspondam à sua busca ou filtro no momento. Tente usar termos diferentes ou limpar os filtros.
                </p>
                <button type="button" class="btn btn-outline-dark rounded-pill px-4 fw-bold" onclick="limparFiltroTexto()">
                    <i class="fa-solid fa-rotate-left me-2"></i>Limpar Filtros
                </button>
            </div>
        </div>
    }
</div>

<div id="modalHost"></div>

<script>
(function () {
    const norm = (s) =>
        (s || "")
            .toString()
            .trim()
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");

    const filterState = {
        categoriaId: "",
        texto: ""
    };

    function getAllPanels() {
        return Array.from(document.querySelectorAll('.bc-panel[data-categoria-id]'));
    }

    function getAllProductCols(panelEl) {
        return Array.from(panelEl.querySelectorAll('.bc-prod-col[data-produto-id][data-nome]'));
    }

    function chunkArray(array, size) {
        const result = [];
        for (let i = 0; i < array.length; i += size) {
            result.push(array.slice(i, i + size));
        }
        return result;
    }

    function captureOriginalCarousel(panel) {
        const carousel = panel.querySelector('.carousel');
        if (!carousel) return;

        if (panel.dataset.originalCaptured === "true") return;

        const originalItems = Array.from(
            panel.querySelectorAll('.carousel-inner .bc-prod-col[data-produto-id][data-nome]')
        ).map((item) => {
            return {
                produtoId: item.getAttribute('data-produto-id') || "",
                categoriaId: item.getAttribute('data-categoria-id') || "",
                nome: item.getAttribute('data-nome') || "",
                html: item.outerHTML
            };
        });

        panel._originalCarouselItems = originalItems;
        panel.dataset.originalCaptured = "true";
    }

    function rebuildCarousel(panel, filteredItems) {
        const carousel = panel.querySelector('.carousel');
        if (!carousel) return;

        const carouselInner = carousel.querySelector('.carousel-inner');
        if (!carouselInner) return;

        const indicatorsWrap = carousel.querySelector('.carousel-indicators');
        const prevBtn = carousel.querySelector('.carousel-control-prev');
        const nextBtn = carousel.querySelector('.carousel-control-next');

        const itemsPerSlide = parseInt(panel.getAttribute("data-items-per-slide") || "3", 10);

        if (window.bootstrap && bootstrap.Carousel) {
            const instance = bootstrap.Carousel.getInstance(carousel);
            if (instance) {
                instance.dispose();
            }
        }

        carouselInner.innerHTML = "";

        if (indicatorsWrap) {
            indicatorsWrap.innerHTML = "";
        }

        if (!filteredItems.length) {
            if (indicatorsWrap) indicatorsWrap.classList.add("d-none");
            if (prevBtn) prevBtn.classList.add("d-none");
            if (nextBtn) nextBtn.classList.add("d-none");
            return;
        }

        const grouped = chunkArray(filteredItems, itemsPerSlide);

        grouped.forEach((group, slideIndex) => {
            const slide = document.createElement("div");
            slide.className = "carousel-item";
            if (slideIndex === 0) {
                slide.classList.add("active");
            }

            const row = document.createElement("div");
            row.className = "row g-3";

            group.forEach((item) => {
                const wrapper = document.createElement("div");
                wrapper.innerHTML = item.html.trim();
                const node = wrapper.firstElementChild;
                if (node) {
                    row.appendChild(node);
                }
            });

            slide.appendChild(row);
            carouselInner.appendChild(slide);

            if (indicatorsWrap) {
                const indicator = document.createElement("button");
                indicator.type = "button";
                indicator.setAttribute("data-bs-target", `#${carousel.id}`);
                indicator.setAttribute("data-bs-slide-to", slideIndex.toString());
                indicator.setAttribute("aria-label", `Slide ${slideIndex + 1}`);

                if (slideIndex === 0) {
                    indicator.classList.add("active");
                    indicator.setAttribute("aria-current", "true");
                }

                indicatorsWrap.appendChild(indicator);
            }
        });

        const hideControls = grouped.length <= 1;

        if (indicatorsWrap) indicatorsWrap.classList.toggle("d-none", hideControls);
        if (prevBtn) prevBtn.classList.toggle("d-none", hideControls);
        if (nextBtn) nextBtn.classList.toggle("d-none", hideControls);

        if (window.bootstrap && bootstrap.Carousel) {
            new bootstrap.Carousel(carousel, {
                interval: false,
                ride: false,
                wrap: true,
                touch: true
            });
        }
    }
    
    function restoreOriginalCarousel(panel) {
        captureOriginalCarousel(panel);

        const originalItems = panel._originalCarouselItems || [];
        rebuildCarousel(panel, originalItems);
    }

    function updateEmptyStates(totalPanelsVisible) {
        const emptyDesktop = document.getElementById('emptySearchStateDesktop');
        const emptyMobile = document.getElementById('emptySearchState');

        if (emptyDesktop) {
            emptyDesktop.classList.toggle('d-none', totalPanelsVisible > 0);
            emptyDesktop.classList.toggle('d-flex', totalPanelsVisible === 0);
        }

        if (emptyMobile) {
            emptyMobile.classList.toggle('d-none', totalPanelsVisible > 0);
            emptyMobile.classList.toggle('d-flex', totalPanelsVisible === 0);
        }
    }

    function applyFilters() {
        const categoriaId = (filterState.categoriaId || "").trim();
        const texto = norm(filterState.texto);
        const panels = getAllPanels();

        let totalPanelsVisible = 0;

        panels.forEach((panel) => {
            const panelCategoriaId = (panel.getAttribute("data-categoria-id") || "").trim();
            const displayType = (panel.getAttribute("data-display-type") || "").trim();

            if (categoriaId && panelCategoriaId !== categoriaId) {
                panel.classList.add("d-none");
                return;
            }

            if (displayType === "carrossel") {
                captureOriginalCarousel(panel);

                const originalItems = panel._originalCarouselItems || [];

                let filteredItems = originalItems;

                if (texto) {
                    filteredItems = originalItems.filter(item =>
                        norm(item.nome).includes(texto)
                    );
                }

                const panelTemProduto = filteredItems.length > 0;
                panel.classList.toggle("d-none", !panelTemProduto);

                if (panelTemProduto) {
                    if (texto) {
                        rebuildCarousel(panel, filteredItems);
                    } else {
                        restoreOriginalCarousel(panel);
                    }
                    totalPanelsVisible++;
                }

                return;
            }

            const cols = getAllProductCols(panel);
            let produtosVisiveis = 0;

            cols.forEach((col) => {
                const nome = norm(col.getAttribute("data-nome") || "");
                const match = !texto || nome.includes(texto);

                col.classList.toggle("d-none", !match);

                if (match) {
                    produtosVisiveis++;
                }
            });

            const panelTemProduto = produtosVisiveis > 0;
            panel.classList.toggle("d-none", !panelTemProduto);

            if (panelTemProduto) {
                totalPanelsVisible++;
            }
        });

        updateEmptyStates(totalPanelsVisible);
    }

    function syncSearchInputs(value) {
        const inputDesktop = document.getElementById("filtroNome");
        const inputMobile = document.getElementById("filtroNomeMobile");

        if (inputDesktop && inputDesktop.value !== value) inputDesktop.value = value;
        if (inputMobile && inputMobile.value !== value) inputMobile.value = value;
    }

    function syncCategorySelects(categoriaId, textoOpcao) {
        const wrappers = [
            document.getElementById("filtroCategoria"),
            document.getElementById("filtroCategoriaMobile")
        ];

        wrappers.forEach((selectWrap) => {
            if (!selectWrap) return;

            const valueSpan = selectWrap.querySelector(".bc-select__value");
            const nativeSelect = selectWrap.querySelector("select");
            const optionsList = Array.from(selectWrap.querySelectorAll(".bc-select__options li"));

            optionsList.forEach((o) => {
                o.classList.toggle("is-selected", (o.dataset.value || "") === categoriaId);
            });

            if (valueSpan) {
                valueSpan.textContent = textoOpcao || "Selecionar uma categoria";
            }

            if (nativeSelect) {
                nativeSelect.value = categoriaId;
            }
        });
    }

    function setupFilterLogic(suffix = "") {
        const btnPesquisar = document.getElementById("btnPesquisar" + suffix);
        const btnFecharBusca = document.getElementById("btnFecharBusca" + suffix);
        const filtroCategoria = document.getElementById("filtroCategoria" + suffix);
        const filtroTexto = document.getElementById("filtroTexto" + suffix);
        const inputBusca = document.getElementById("filtroNome" + suffix);

        let modoBuscaTexto = false;

        function abrirBuscaTexto() {
            filtroCategoria?.classList.add("d-none");
            filtroTexto?.classList.remove("d-none");
            btnPesquisar?.classList.add("d-none");
            modoBuscaTexto = true;
            setTimeout(() => inputBusca?.focus(), 50);
        }

        function fecharBuscaTexto() {
            filtroTexto?.classList.add("d-none");
            filtroCategoria?.classList.remove("d-none");
            btnPesquisar?.classList.remove("d-none");
            modoBuscaTexto = false;

            if (inputBusca) {
                inputBusca.value = "";
            }

            filterState.texto = "";
            syncSearchInputs("");
            applyFilters();
        }

        btnPesquisar?.addEventListener("click", () => {
            if (!modoBuscaTexto) abrirBuscaTexto();
            else inputBusca?.focus();
        });

        btnFecharBusca?.addEventListener("click", fecharBuscaTexto);

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && modoBuscaTexto) {
                fecharBuscaTexto();
            }
        });

        const selectWrap = document.getElementById("filtroCategoria" + suffix);
        if (selectWrap) {
            const trigger = selectWrap.querySelector(".bc-select__trigger");
            const optionsList = Array.from(selectWrap.querySelectorAll(".bc-select__options li"));
            const valueSpan = selectWrap.querySelector(".bc-select__value");
            const nativeSelect = selectWrap.querySelector("select");

            trigger?.addEventListener("click", (e) => {
                e.stopPropagation();

                const isOpen = selectWrap.classList.contains("is-open");
                document.querySelectorAll(".bc-select").forEach((s) => s.classList.remove("is-open"));

                if (!isOpen) {
                    selectWrap.classList.add("is-open");
                }
            });

            optionsList.forEach((option) => {
                option.addEventListener("click", (e) => {
                    e.stopPropagation();

                    optionsList.forEach((o) => o.classList.remove("is-selected"));
                    option.classList.add("is-selected");

                    const categoriaId = option.dataset.value || "";
                    const textoOpcao = option.textContent?.trim() || "Selecionar uma categoria";

                    if (valueSpan) {
                        valueSpan.textContent = textoOpcao;
                    }

                    if (nativeSelect) {
                        nativeSelect.value = categoriaId;
                    }

                    filterState.categoriaId = categoriaId;
                    syncCategorySelects(categoriaId, textoOpcao);
                    applyFilters();

                    selectWrap.classList.remove("is-open");
                });
            });
        }

        inputBusca?.addEventListener("input", () => {
            filterState.texto = inputBusca.value || "";
            syncSearchInputs(filterState.texto);
            applyFilters();
        });
    }

    window.limparFiltroTexto = function () {
        filterState.texto = "";
        filterState.categoriaId = "";

        syncSearchInputs("");
        syncCategorySelects("", "Selecionar uma categoria");

        const filtroTexto = document.getElementById("filtroTexto");
        const filtroTextoMobile = document.getElementById("filtroTextoMobile");
        const filtroCategoria = document.getElementById("filtroCategoria");
        const filtroCategoriaMobile = document.getElementById("filtroCategoriaMobile");
        const btnPesquisar = document.getElementById("btnPesquisar");
        const btnPesquisarMobile = document.getElementById("btnPesquisarMobile");

        filtroTexto?.classList.add("d-none");
        filtroTextoMobile?.classList.add("d-none");

        filtroCategoria?.classList.remove("d-none");
        filtroCategoriaMobile?.classList.remove("d-none");

        btnPesquisar?.classList.remove("d-none");
        btnPesquisarMobile?.classList.remove("d-none");

        applyFilters();
    };

    window.iniciarModalAdicionarProduto = function () {
        const modalEl = document.getElementById('modalAddProduto');
        if (!modalEl) return;

        const form = modalEl.querySelector('#formAdicionarProdutoCarrinho');
        if (!form) return;

        const inputPrecoBase = modalEl.querySelector('#modalPrecoBase');
        const inputQtd = modalEl.querySelector('#quantidadeProduto');
        const btnMenos = modalEl.querySelector('#btnDiminuirQtd');
        const btnMais = modalEl.querySelector('#btnAumentarQtd');
        const totalEl = modalEl.querySelector('#valorTotalProduto');
        const precoPrincipalEl = modalEl.querySelector('#modalPrecoPrincipal');
        const precoCentavosEl = modalEl.querySelector('#modalPrecoCentavos');

        if (!inputPrecoBase || !inputQtd || !btnMenos || !btnMais || !totalEl) return;

        const precoBase = Number(inputPrecoBase.value || 0);

        function moedaBR(valor) {
            return valor.toLocaleString('pt-BR', {
                style: 'currency',
                currency: 'BRL'
            });
        }

        function formatarPrecoVisual(valor) {
            const formatado = valor.toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            const partes = formatado.split(',');

            return {
                inteiro: partes[0],
                centavos: ',' + (partes[1] || '00')
            };
        }

        function obterQuantidade() {
            let qtd = parseInt(inputQtd.value, 10) || 1;

            if (qtd < 1) {
                qtd = 1;
                inputQtd.value = 1;
            }

            return qtd;
        }

        function obterAdicionalSelecionado() {
            let adicional = 0;

            form.querySelectorAll('.acomp-input:checked').forEach(function (input) {
                adicional += Number(input.dataset.preco || 0);
            });

            return adicional;
        }

        function atualizarPrecoUnitario(adicional) {
            const precoUnitario = precoBase + adicional;
            const partes = formatarPrecoVisual(precoUnitario);

            if (precoPrincipalEl) {
                precoPrincipalEl.textContent = partes.inteiro;
            }

            if (precoCentavosEl) {
                precoCentavosEl.textContent = partes.centavos;
            }
        }

        function calcularTotal() {
            const qtd = obterQuantidade();
            const adicional = obterAdicionalSelecionado();
            const precoUnitario = precoBase + adicional;
            const total = precoUnitario * qtd;

            atualizarPrecoUnitario(adicional);
            totalEl.textContent = moedaBR(total);
        }

        function controlarSelecaoUnicaPorCategoria(checkboxAtual) {
            if (!checkboxAtual) return;

            const categoriaId = checkboxAtual.dataset.categoriaId;
            if (!categoriaId) return;

            const containerCategoria = checkboxAtual.closest('[data-acomp-categoria]');
            if (!containerCategoria) return;

            const max = parseInt(containerCategoria.dataset.max || '0', 10);

            if (max === 1 && checkboxAtual.checked) {
                form.querySelectorAll('.acomp-input[data-categoria-id="' + categoriaId + '"]').forEach(function (item) {
                    if (item !== checkboxAtual) {
                        item.checked = false;
                    }
                });
            }
        }

        btnMenos.onclick = function () {
            let qtdAtual = obterQuantidade();
            qtdAtual = Math.max(qtdAtual - 1, 1);
            inputQtd.value = qtdAtual;
            calcularTotal();
        };

        btnMais.onclick = function () {
            let qtdAtual = obterQuantidade();
            qtdAtual = qtdAtual + 1;
            inputQtd.value = qtdAtual;
            calcularTotal();
        };

        inputQtd.oninput = calcularTotal;
        inputQtd.onchange = calcularTotal;
        inputQtd.onblur = calcularTotal;

        form.querySelectorAll('.acomp-input').forEach(function (input) {
            input.onchange = function () {
                controlarSelecaoUnicaPorCategoria(this);
                calcularTotal();
            };
        });

        calcularTotal();
    };

    const host = document.getElementById('modalHost');

    async function abrirModalProduto(produtoId) {
        if (!host) return;

        const old = document.getElementById('modalAddProduto');
        if (old) old.remove();

        try {
            addLoading("Carregando...");

            const resp = await fetch(`/Produto/BuscarModalAdicionarProduto?id=${encodeURIComponent(produtoId)}`, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });

            if (!resp.ok) {
                throw new Error(`Erro HTTP ${resp.status}`);
            }

            const html = await resp.text();
            host.innerHTML = html;

            iniciarModalAdicionarProduto();

            const modalEl = document.getElementById('modalAddProduto');
            if (!modalEl) return;

            modalEl.addEventListener('hidden.bs.modal', function () {
                modalEl.remove();
            }, { once: true });

            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();

        } catch (err) {
            console.error('Erro ao carregar modal:', err);
            alert('Não foi possível carregar o produto. Tente novamente.');
        } finally {
            removeLoading();
        }
    }

    document.addEventListener('click', (e) => {
        const el = e.target.closest('.bc-product-clickable');
        if (!el) return;

        const produtoId = el.dataset.produtoId;
        if (!produtoId) return;

        abrirModalProduto(produtoId);
    });

    document.addEventListener("DOMContentLoaded", () => {
        setupFilterLogic("");
        setupFilterLogic("Mobile");

        document.addEventListener("click", () => {
            document.querySelectorAll(".bc-select").forEach((s) => s.classList.remove("is-open"));
        });

        applyFilters();
    });
})();
</script>
<script>
    async function adicionarAoCarrinho() {
        const form = document.getElementById('formAdicionarProdutoCarrinho');
        if (!form) return;

        if (typeof window.addLoading === 'function') {
            window.addLoading('Processando...');
        }

        const produtoId = form.querySelector('input[name="ProdutoId"]').value;
        const quantidade = parseInt(form.querySelector('input[name="Quantidade"]').value, 10) || 1;
        const observacao = form.querySelector('textarea[name="Observacao"]').value.trim();

        const acompanhamentos = [];
        form.querySelectorAll('.acomp-input:checked').forEach(input => {
            acompanhamentos.push({
                CategoriaId: input.dataset.categoriaId,
                AcompanhamentoId: input.value
            });
        });

        const payload = {
            produtoId: produtoId,
            quantidade: quantidade,
            observacao: observacao || null,
            acompanhamentos: acompanhamentos
        };

        try {
            const response = await fetch('/Carrinho/Adicionar', {
                method: 'POST',
                headers: {
                    'Accept': 'application/json',
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            const type = result.success ? 'success' : 'danger';

            updateFeedbackAlert(type, result.message);

            if (result.success) {
                setTimeout(async () => {
                    try {
                        mostrarLoadingCarrinho();
                        await recarregarCarrinhoEFooter();
                    } catch (error) {
                        console.error(error);
                    } finally {
                        ocultarLoadingCarrinho();
                    }
                }, 800);
            }
        } catch (error) {
            console.error(error);
            showToast('danger', 'Ocorreu um problema ao adicionar o produto ao carrinho.');
            updateFeedbackAlert('danger', 'Ocorreu um problema ao adicionar o produto ao carrinho.');
        } finally {
            if (typeof window.removeLoading === 'function') {
                window.removeLoading();
            }
        }
    }

    document.addEventListener('click', (e) => {
        const btn = e.target.closest('#btnAdicionarCarrinho');
        if (btn) {
            e.preventDefault();
            clearToasts();
            clearFeedbackAlerts();
            adicionarAoCarrinho();
        }
    });

    function showToast(type, message) {
        const toastEl = document.createElement('div');
        toastEl.className = `toast align-items-center text-bg-${type} border-0`;
        toastEl.setAttribute('role', 'alert');
        toastEl.setAttribute('aria-live', 'assertive');
        toastEl.setAttribute('aria-atomic', 'true');
        toastEl.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        `;

        const container = document.getElementById('toast-container');
        if (!container) return;

        container.appendChild(toastEl);

        const toast = bootstrap.Toast.getOrCreateInstance(toastEl, {
            autohide: true,
            delay: 3000
        });

        toast.show();
    }

    function updateFeedbackAlert(type, message) {
        const feedback = document.getElementById('feedback-alerts');
        if (feedback) {
            feedback.innerHTML = `<div class="alert alert-${type} border-0 shadow-sm mb-0">${message}</div>`;
        }
    }

    function clearToasts() {
        const container = document.getElementById('toast-container');
        if (!container) return;

        container.querySelectorAll('.toast').forEach(el => {
            const t = bootstrap.Toast.getInstance(el);
            if (t) {
                t.hide();
                t.dispose();
            }
            el.remove();
        });
    }

    function clearFeedbackAlerts() {
        const feedbackDiv = document.getElementById('feedback-alerts');
        if (feedbackDiv) {
            feedbackDiv.innerHTML = '';
        }
    }

    function fecharModalEAbrirOutro(modalAtualId, proximoModalId) {
        const modalAtualEl = document.getElementById(modalAtualId);
        const proximoModalEl = document.getElementById(proximoModalId);

        if (!modalAtualEl || !proximoModalEl) return;

        const modalAtual = bootstrap.Modal.getInstance(modalAtualEl) || bootstrap.Modal.getOrCreateInstance(modalAtualEl);
        const proximoModal = bootstrap.Modal.getOrCreateInstance(proximoModalEl);

        const onHidden = () => {
            modalAtualEl.removeEventListener('hidden.bs.modal', onHidden);

            limparBackdropOrfao();

            requestAnimationFrame(() => {
                proximoModal.show();
            });
        };

        modalAtualEl.addEventListener('hidden.bs.modal', onHidden, { once: true });
        modalAtual.hide();
    }

    function limparBackdropOrfao() {
        document.querySelectorAll('.modal-backdrop').forEach((el, index, arr) => {
            if (index < arr.length - 1) {
                el.remove();
            }
        });

        if (!document.querySelector('.modal.show')) {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
        }
    }

    function mostrarLoadingCarrinho() {
        const container = document.getElementById('carrinho-container');
        if (!container) return;

        container.classList.add('is-loading');

        let overlay = container.querySelector('.carrinho-loading-overlay');
        if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'carrinho-loading-overlay';
            overlay.innerHTML = '<div class="carrinho-loading-spinner"></div>';
            container.appendChild(overlay);
        } else {
            overlay.classList.remove('d-none');
        }
    }

    function ocultarLoadingCarrinho() {
        const container = document.getElementById('carrinho-container');
        if (!container) return;

        container.classList.remove('is-loading');

        const overlay = container.querySelector('.carrinho-loading-overlay');
        if (overlay) {
            overlay.classList.add('d-none');
        }
    }

    function recalcularTotalModal(form) {
        if (!form) return;

        const modal = form.closest('#modalAddProduto');
        if (!modal) return;

        const inputPrecoBase = modal.querySelector('#modalPrecoBase');
        const inputQtd = modal.querySelector('#quantidadeProduto');
        const totalEl = modal.querySelector('#valorTotalProduto');

        if (!inputPrecoBase || !inputQtd || !totalEl) return;

        const precoBase = Number(inputPrecoBase.value || 0);
        let qtd = parseInt(inputQtd.value, 10) || 1;

        if (qtd < 1) {
            qtd = 1;
            inputQtd.value = 1;
        }

        let adicional = 0;

        form.querySelectorAll('.acomp-input:checked').forEach(function (input) {
            adicional += Number(input.dataset.preco || 0);
        });

        const total = (precoBase + adicional) * qtd;

        totalEl.textContent = total.toLocaleString('pt-BR', {
            style: 'currency',
            currency: 'BRL'
        });
    }
</script>