    // Mostra um toast Bootstrap com cor conforme o tipo ('success', 'danger' etc.)
    function showToast(type, message) {
        const toastEl = document.createElement('div');
        toastEl.className = `toast align-items-center text-bg-${type} border-0`;
        toastEl.setAttribute('role', 'alert');
        toastEl.setAttribute('aria-live', 'assertive');
        toastEl.setAttribute('aria-atomic', 'true');
        toastEl.innerHTML = `
            <div class="d-flex">
                <div class="toast-body">${message}</div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
        `;

        const container = document.getElementById('toast-container');
        container.appendChild(toastEl);

        // Inicializa e exibe o toast com autohide e delay personalizados
        // autohide: true garante que o toast se feche sozinho:contentReference[oaicite:1]{index=1}
        // delay: 3000 define a duração em milissegundos (3 segundos)
        const toast = bootstrap.Toast.getOrCreateInstance(toastEl, {
            autohide: true,
            delay: 3000
        });
        toast.show();
    }

    // Atualiza o bloco fixo de feedback com uma mensagem
    function updateFeedbackAlert(type, message) {
        const feedback = document.getElementById('feedback-alerts');
        if (feedback) {
            feedback.innerHTML = `<div class="alert alert-${type} border-0 shadow-sm mb-0">${message}</div>`;
        }
    }

    function clearToasts() {
        const container = document.getElementById('toast-container');
        if (container) {
            container.querySelectorAll('.toast').forEach(el => {
                const t = bootstrap.Toast.getInstance(el);
                if (t) {
                    t.hide();        // esconde imediatamente
                    t.dispose();     // destrói a instância
                }
                el.remove();          // remove do DOM
            });
        }
    }

    function clearFeedbackAlerts() {
        const feedbackDiv = document.getElementById('feedback-alerts');
        if (feedbackDiv) {
            feedbackDiv.innerHTML = '';
        }
    }

    function fecharModalEAbrirOutro(modalAtualId, proximoModalId) {
        const modalAtualEl = document.getElementById(modalAtualId);
        const proximoModalEl = document.getElementById(proximoModalId);

        if (!modalAtualEl || !proximoModalEl) return;

        const modalAtual = bootstrap.Modal.getInstance(modalAtualEl) || bootstrap.Modal.getOrCreateInstance(modalAtualEl);
        const proximoModal = bootstrap.Modal.getOrCreateInstance(proximoModalEl);

        const onHidden = () => {
            modalAtualEl.removeEventListener('hidden.bs.modal', onHidden);

            limparBackdropOrfao();

            requestAnimationFrame(() => {
                proximoModal.show();
            });
        };

        modalAtualEl.addEventListener('hidden.bs.modal', onHidden, { once: true });
        modalAtual.hide();
    }

    function limparBackdropOrfao() {
        document.querySelectorAll('.modal-backdrop').forEach((el, index, arr) => {
            if (index < arr.length - 1) {
                el.remove();
            }
        });

        if (!document.querySelector('.modal.show')) {
            document.body.classList.remove('modal-open');
            document.body.style.removeProperty('padding-right');
            document.body.style.removeProperty('overflow');
        }
    }

    function mostrarLoadingCarrinho() {
        const container = document.getElementById('carrinho-container');
        if (!container) return;

        container.classList.add('is-loading');

        let overlay = container.querySelector('.carrinho-loading-overlay');
        if (!overlay) {
            overlay = document.createElement('div');
            overlay.className = 'carrinho-loading-overlay';
            overlay.innerHTML = '<div class="carrinho-loading-spinner"></div>';
            container.appendChild(overlay);
        } else {
            overlay.classList.remove('d-none');
        }
    }

    function ocultarLoadingCarrinho() {
        const container = document.getElementById('carrinho-container');
        if (!container) return;

        container.classList.remove('is-loading');

        const overlay = container.querySelector('.carrinho-loading-overlay');
        if (overlay) {
            overlay.classList.add('d-none');
        }
    }

