@using System.Globalization
@using Ecommerce.MVC.Entities
@model Produto

@{
    var pt = new CultureInfo("pt-BR");
    var precoBase = Model.Preco;
    var imagem = string.IsNullOrWhiteSpace(Model.ImagemUrl)
        ? "/img/sem-imagem.png"
        : Model.ImagemUrl;
}

<div class="modal fade" id="modalAddProduto" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius:18px; overflow:hidden;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" style="color:#3c1e0a;">Adicionar produto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
            </div>

            <div class="modal-body pt-2">
                <div class="row g-4">
                    <div class="col-lg-5">
                        <div class="position-relative">
                            <img src="@imagem"
                                 alt="@Model.Nome"
                                 class="img-fluid w-100"
                                 style="border-radius:16px; object-fit:cover; max-height:320px;" />
                        </div>

                        <div class="mt-3">
                            <h4 class="fw-bold mb-1" style="color:#3c1e0a;">@Model.Nome</h4>

                            @if (!string.IsNullOrWhiteSpace(Model.Descricao))
                            {
                                <p class="text-muted mb-2">@Model.Descricao</p>
                            }

                            <div class="fw-bold fs-5" style="color:#198754;">
                                @precoBase.ToString("C", pt)
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <form id="formAdicionarProdutoCarrinho">
                            <input type="hidden" name="ProdutoId" value="@Model.Id" />

                            @if (Model.AcompanhamentoCategorias?.Any() == true)
                            {
                                <div class="mt-2">
                                    @foreach (var pc in Model.AcompanhamentoCategorias
                                                                .OrderBy(x => x.Ordem)
                                                                .ThenBy(x => x.Categoria.Nome))
                                    {
                                        var cat = pc.Categoria;
                                        var tipoSelecao = (pc.MaxSelecionados <= 1) ? "radio" : "checkbox";
                                        var requiredLabel = pc.Obrigatorio ? "Obrigatório" : "Opcional";
                                        var inputName = $"acomp_{pc.AcompanhamentoCategoriaId:N}";

                                        var itens = (pc.ProdutoAcompanhamentos ?? new List<ProdutoAcompanhamento>())
                                            .Where(a => a.Ativo)
                                            .OrderBy(a => a.Ordem)
                                            .ThenBy(a => a.Acompanhamento.Nome)
                                            .ToList();

                                        <div class="card border-0 shadow-sm mb-3" style="border-radius:14px; overflow:hidden;">
                                            <div class="card-body" style="background:#f7f7f7;">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="pe-3">
                                                        <div class="fw-bold" style="color:#3c1e0a;">@cat.Nome</div>

                                                        <div class="text-muted small">
                                                            @requiredLabel
                                                            @if (pc.MinSelecionados > 0)
                                                            {
                                                                <span> • Mín. @pc.MinSelecionados</span>
                                                            }
                                                            @if (pc.MaxSelecionados > 0)
                                                            {
                                                                <span> • Máx. @pc.MaxSelecionados</span>
                                                            }
                                                        </div>

                                                        @if (!string.IsNullOrWhiteSpace(cat.Descricao))
                                                        {
                                                            <div class="text-muted small">@cat.Descricao</div>
                                                        }
                                                    </div>

                                                    <span class="badge rounded-pill" style="background:#3c1e0a; color:#fff;">
                                                        @requiredLabel
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="list-group list-group-flush"
                                                 data-acomp-categoria
                                                 data-categoria-id="@pc.AcompanhamentoCategoriaId"
                                                 data-min="@pc.MinSelecionados"
                                                 data-max="@pc.MaxSelecionados"
                                                 data-obrigatorio="@(pc.Obrigatorio ? "1" : "0")"
                                                 style="overflow-y:auto; max-height:320px;">

                                                @if (itens.Any())
                                                {
                                                    @foreach (var item in itens)
                                                    {
                                                        var inputId = $"acomp_{pc.AcompanhamentoCategoriaId:N}_{item.Id:N}";
                                                        var temAdicional = item.Acompanhamento.Preco > 0;

                                                        <label class="list-group-item d-flex justify-content-between align-items-center py-3 acomp-item"
                                                               for="@inputId"
                                                               style="cursor:pointer;">
                                                            <div class="d-flex flex-column">
                                                                <span class="fw-semibold">@item.Acompanhamento.Nome</span>

                                                                @if (!string.IsNullOrWhiteSpace(item.Acompanhamento.Descricao))
                                                                {
                                                                    <span class="text-muted small">@item.Acompanhamento.Descricao</span>
                                                                }
                                                            </div>

                                                            <div class="d-flex align-items-center gap-3">
                                                                <div class="fw-bold @(temAdicional ? "text-success" : "text-muted")">
                                                                    @(temAdicional ? $"+ {item.Acompanhamento.Preco.ToString("C", pt)}" : "Incluso")
                                                                </div>

                                                                <input id="@inputId"
                                                                       type="@tipoSelecao"
                                                                       name="@inputName"
                                                                       class="form-check-input acomp-input"
                                                                       value="@item.Id"
                                                                       data-preco="@item.Acompanhamento.Preco.ToString(CultureInfo.InvariantCulture)"
                                                                       data-categoria-id="@pc.AcompanhamentoCategoriaId"
                                                                       aria-label="Selecionar @item.Acompanhamento.Nome" />
                                                            </div>
                                                        </label>
                                                    }
                                                }
                                                else
                                                {
                                                    <div class="p-3 text-muted small">
                                                        Nenhum item disponível nesta categoria.
                                                    </div>
                                                }
                                            </div>

                                            <div class="text-danger small px-3 pb-3 d-none"
                                                 data-acomp-erro="@pc.AcompanhamentoCategoriaId">
                                                Selecione no mínimo @pc.MinSelecionados item(ns).
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="mb-3">
                                <label class="form-label fw-semibold" style="color:#3c1e0a;">Observações</label>
                                <textarea name="Observacao"
                                          class="form-control"
                                          rows="3"
                                          maxlength="500"
                                          placeholder="Ex: tirar cebola, caprichar no molho..."></textarea>
                            </div>

                            <div class="d-flex align-items-center justify-content-between border rounded-4 p-3 mb-3">
                                <div>
                                    <div class="small text-muted">Quantidade</div>
                                </div>

                                <div class="d-flex align-items-center gap-2">
                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnDiminuirQtd">
                                        -
                                    </button>

                                    <input type="number"
                                           name="Quantidade"
                                           id="quantidadeProduto"
                                           class="form-control text-center"
                                           value="1"
                                           min="1"
                                           style="width:70px;" />

                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm"
                                            id="btnAumentarQtd">
                                        +
                                    </button>
                                </div>
                            </div>

                            <div class="d-grid">
                                <button type="button"
                                        id="btnAdicionarCarrinho"
                                        class="btn btn-lg text-white fw-bold"
                                        style="background:#3c1e0a; border-radius:14px;">
                                    Adicionar ao carrinho • <span id="valorTotalProduto">@precoBase.ToString("C", pt)</span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const form = document.getElementById('formAdicionarProdutoCarrinho');
        if (!form) return;

        const precoBase = @precoBase.ToString(CultureInfo.InvariantCulture).Replace(",", ".");
        const inputQtd = document.getElementById('quantidadeProduto');
        const btnMenos = document.getElementById('btnDiminuirQtd');
        const btnMais = document.getElementById('btnAumentarQtd');
        const btnAdicionar = document.getElementById('btnAdicionarCarrinho');
        const valorTotal = document.getElementById('valorTotalProduto');

        function moedaBR(valor) {
            return valor.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
        }

        function obterAcompanhamentosSelecionados() {
            const selecionados = [];
            const inputs = form.querySelectorAll('.acomp-input:checked');

            inputs.forEach(input => {
                selecionados.push({
                    AcompanhamentoId: input.value,
                    CategoriaId: input.dataset.categoriaId
                });
            });

            return selecionados;
        }

        function calcularTotal() {
            let adicional = 0;

            const selecionados = form.querySelectorAll('.acomp-input:checked');
            selecionados.forEach(input => {
                const preco = parseFloat(input.dataset.preco || '0');
                adicional += preco;
            });

            const qtd = Math.max(parseInt(inputQtd.value || '1'), 1);
            const total = (precoBase + adicional) * qtd;

            valorTotal.textContent = moedaBR(total);
        }

        function validarCategorias() {
            let valido = true;

            const categorias = form.querySelectorAll('[data-acomp-categoria]');
            categorias.forEach(cat => {
                const categoriaId = cat.dataset.categoriaId;
                const min = parseInt(cat.dataset.min || '0');
                const max = parseInt(cat.dataset.max || '0');
                const obrigatorio = cat.dataset.obrigatorio === '1';

                const marcados = cat.querySelectorAll('.acomp-input:checked').length;
                const erro = form.querySelector(`[data-acomp-erro="${categoriaId}"]`);

                let temErro = false;

                if (obrigatorio && marcados === 0) {
                    temErro = true;
                }

                if (marcados < min) {
                    temErro = true;
                }

                if (max > 0 && marcados > max) {
                    temErro = true;
                }

                if (erro) {
                    erro.classList.toggle('d-none', !temErro);
                }

                if (temErro) {
                    valido = false;
                }
            });

            return valido;
        }

        function montarPayload() {
            return {
                ProdutoId: form.querySelector('input[name="ProdutoId"]').value,
                Quantidade: parseInt(inputQtd.value || '1'),
                Observacao: form.querySelector('textarea[name="Observacao"]').value,
                Acompanhamentos: obterAcompanhamentosSelecionados()
            };
        }

        btnMenos?.addEventListener('click', function () {
            const atual = Math.max(parseInt(inputQtd.value || '1'), 1);
            inputQtd.value = Math.max(atual - 1, 1);
            calcularTotal();
        });

        btnMais?.addEventListener('click', function () {
            const atual = Math.max(parseInt(inputQtd.value || '1'), 1);
            inputQtd.value = atual + 1;
            calcularTotal();
        });

        inputQtd?.addEventListener('input', function () {
            if (!inputQtd.value || parseInt(inputQtd.value) < 1) {
                inputQtd.value = 1;
            }
            calcularTotal();
        });

        form.addEventListener('change', function (e) {
            if (e.target.classList.contains('acomp-input')) {
                calcularTotal();
                validarCategorias();
            }
        });

        btnAdicionar?.addEventListener('click', async function () {
            if (!validarCategorias()) {
                return;
            }

            const payload = montarPayload();

            try {
                const response = await fetch('/Carrinho/Adicionar', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();

                if (!response.ok || data.sucesso === false) {
                    alert(data.mensagem || 'Não foi possível adicionar o produto ao carrinho.');
                    return;
                }

                const modalEl = document.getElementById('modalAddProduto');
                const modal = bootstrap.Modal.getInstance(modalEl);
                modal?.hide();

                if (typeof window.atualizarBadgeCarrinho === 'function') {
                    window.atualizarBadgeCarrinho();
                }
            } catch {
                alert('Erro ao adicionar produto ao carrinho.');
            }
        });

        calcularTotal();
    })();
</script>