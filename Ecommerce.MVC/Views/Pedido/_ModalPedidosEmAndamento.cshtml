@using System.Globalization
@using Ecommerce.MVC.Enums
@using Ecommerce.MVC.Models.Pedidos
@model IReadOnlyList<PedidosEmAndamentoViewModel>

@{
    var pt = new CultureInfo("pt-BR");
}

<link rel="stylesheet" href="~/css/pedido/acompanhamento-pedido.css" asp-append-version="true" />

<div class="modal fade" id="modalPedidosEmAndamento" tabindex="-1" aria-labelledby="modalPedidosEmAndamentoLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content bc-modal border-0 shadow-lg" style="overflow: hidden;">
            <div class="modal-header border-0 d-flex align-items-center justify-content-between">
                <div class="text-start d-flex align-items-start">
                    <h5 class="modal-title fw-bolder mb-0" style="color: #3c1e0a; font-weight: bold !important; font-size: 1rem; margin-bottom: 0.5rem !important;">
                        <i class="fa-solid fa-fire me-2"></i>Acompanhe seu Pedido
                    </h5>
                    <span class="badge shadow bg-danger"
                          style="font-size: 0.75rem; z-index: 1; margin-left: 7px; margin-top: 3px;">
                        @ViewBag.TotalPedidos
                        <span class="visually-hidden">pedidos em andamento</span>
                    </span>
                </div>

                <button type="button" class="btn-close-custom" title="Fechar" data-bs-dismiss="modal" aria-label="Fechar" style="position: static; font-size: 1.5rem;">&times;</button>
            </div>

            <div class="modal-body pt-2 px-2 px-lg-4 bh-pedidos-em-andamento" id="modalPedidosEmAndamentoBody" style="max-height: 87vh; overflow-y: auto;">

@functions {
    private string MapStatusBadgeClass(EPedidoStatus status)
    {
        return status switch
        {
            EPedidoStatus.Cancelado => "bg-danger-subtle text-danger",
            EPedidoStatus.Concluido => "bg-success-subtle text-success",
            EPedidoStatus.Pronto => "bg-primary-subtle text-primary",
            EPedidoStatus.EmPreparo => "bg-warning-subtle text-warning-custom",
            EPedidoStatus.Confirmado => "bg-info-subtle text-info",
            EPedidoStatus.AguardandoPagamento => "bg-warning-subtle text-warning-custom",
            EPedidoStatus.Rascunho => "bg-secondary-subtle text-secondary",
            _ => "bg-secondary-subtle text-secondary"
        };
    }

    private bool IsRetirada(string metodoEntrega)
        => (metodoEntrega ?? "").Trim().ToLower().Contains("retirar");

    private bool IsPix(string? tipoPagamento)
        => string.Equals(tipoPagamento?.Trim(), "PIX", StringComparison.OrdinalIgnoreCase);

    private bool IsCartao(string? tipoPagamento)
    {
        if (string.IsNullOrWhiteSpace(tipoPagamento)) return false;

        var tipo = tipoPagamento.Trim().ToLower();

        return tipo.Contains("cartao")
            || tipo.Contains("cartão")
            || tipo.Contains("credito")
            || tipo.Contains("crédito")
            || tipo.Contains("debito")
            || tipo.Contains("débito")
            || tipo.Contains("card");
    }

    private string MapPagamentoBadgeClass(string? statusPagamento)
    {
        var status = (statusPagamento ?? "").Trim().ToLower();

        if (status.Contains("pago") || status.Contains("recebido") || status.Contains("confirmado"))
            return "bg-success";

        if (status.Contains("pendente") || status.Contains("aguardando"))
            return "bg-warning text-dark";

        if (status.Contains("expirado") || status.Contains("cancelado") || status.Contains("falhou"))
            return "bg-danger";

        return "bg-secondary";
    }

    private bool PagamentoConfirmado(string? statusPagamento)
    {
        var status = (statusPagamento ?? "").Trim().ToLower();
        return status.Contains("pago") || status.Contains("recebido") || status.Contains("confirmado");
    }

    private string ObterRotuloPagamento(string? tipoPagamento)
    {
        if (string.IsNullOrWhiteSpace(tipoPagamento))
            return "Não informado";

        if (IsPix(tipoPagamento))
            return "PIX";

        if (IsCartao(tipoPagamento))
            return "Cartão";

        return tipoPagamento;
    }
}

<div class="bh-history">
    <div class="order-list">

        @if (Model == null || !Model.Any())
        {
            <div id="emptyOrdersState" class="d-flex flex-column align-items-center justify-content-center py-5 px-3 pt-3 w-100">
                <div class="text-center bg-white" style="margin: 0 auto; border-radius:15px; max-width: 500px;">
                    <div class="mb-4 opacity-25">
                        <i class="fa-solid fa-calendar-xmark fa-4x text-secondary"></i>
                    </div>
                    <h4 class="fw-bold" style="color: #3c1e0a;">Nenhum pedido ativo</h4>
                    <p class="text-muted mb-4">
                        Você não possui pedidos em andamento no momento. Que tal dar uma olhada nas nossas delícias e fazer um novo pedido?
                    </p>
                    <button type="button" class="btn btn-outline-dark rounded-pill px-4 fw-bold" data-bs-dismiss="modal">
                        <i class="fa-solid fa-shop me-2"></i>Ver Cardápio
                    </button>
                </div>
            </div>
        }
        else
        {
            foreach (var p in Model)
            {
                var step = p.Step;
                var badgeClass = MapStatusBadgeClass(p.Status);
                var metodoRetirada = IsRetirada(p.MetodoEntrega);
                var colId = "ped_" + (p.Codigo ?? Guid.NewGuid().ToString("N"));

                var pagamento = p.Pagamento;
                var tipoPagamento = pagamento?.TipoPagamento;
                var statusPagamento = pagamento?.StatusPagamento ?? "Sem pagamento";
                var ehPix = IsPix(tipoPagamento);
                var ehCartao = IsCartao(tipoPagamento);
                var pagamentoConfirmado = PagamentoConfirmado(statusPagamento);
                var badgePagamentoClass = MapPagamentoBadgeClass(statusPagamento);

                <div class="order-wrapper order-wrapper-hover mb-2" style="border-radius: 16px;">
                    <div class="order-grid toggle-detalhes" data-target="@colId">
                        <div>
                            <span class="label-mobile label-mobile-start">Pedido</span>
                            <div class="fw-bold label-mobile-start" style="color: #3c1e0abd;">#@p.Codigo</div>
                        </div>

                        <div>
                            <span class="label-mobile label-mobile-end">Data/Hora</span>
                            <div class="text-muted small label-mobile-end">
                                @p.CriadoEmUtc.ToLocalTime().ToString("dd/MM HH:mm")
                            </div>
                        </div>

                        <div>
                            <span class="label-mobile label-mobile-start">Status</span>
                            <span class="badge @badgeClass py-2 px-3 label-mobile-end rounded-4">@p.StatusTexto</span>
                        </div>

                        <div>
                            <span class="label-mobile label-mobile-end">Total</span>
                            <div class="fw-bold label-mobile-end" style="color: #3c1e0abd;">@p.Total.ToString("C", pt)</div>
                        </div>

                        <div class="col-btn">
                            <button class="btn-toggle-detalhes" type="button">
                                <i class="fa-solid fa-chevron-down"></i>
                            </button>
                        </div>
                    </div>

                    <div id="@colId" class="collapse border-top">
                        <div class="order-stepper">
                            <div class="step @(step >= 1 ? "done" : "") @(step == 1 ? "active" : "")">
                                <div class="step-circle">
                                    @if (step > 1)
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-clock"></i>
                                    }
                                </div>
                                <span>Pedido</span>
                            </div>

                            <div class="step @(step >= 2 ? "done" : "") @(step == 2 ? "active" : "")">
                                <div class="step-circle">
                                    @if (step > 2)
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-receipt"></i>
                                    }
                                </div>
                                <span>Aprovado</span>
                            </div>

                            <div class="step @(step >= 3 ? "done" : "") @(step == 3 ? "active" : "")">
                                <div class="step-circle">
                                    @if (step > 3)
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-fire-burner"></i>
                                    }
                                </div>
                                <span>Preparo</span>
                            </div>

                            <div class="step @(step >= 4 ? "done" : "") @(step == 4 ? "active" : "")">
                                <div class="step-circle">
                                    @if (step > 4)
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid @(metodoRetirada ? "fa-box-open" : "fa-motorcycle")"></i>
                                    }
                                </div>
                                <span>@(metodoRetirada ? "Pronto" : "Rota")</span>
                            </div>

                            <div class="step @(step >= 5 ? "done" : "") @(step == 5 ? "active" : "")">
                                <div class="step-circle">
                                    @if (step > 5)
                                    {
                                        <i class="fa-solid fa-check"></i>
                                    }
                                    else
                                    {
                                        <i class="fa-solid fa-house-chimney-check"></i>
                                    }
                                </div>
                                <span>@(metodoRetirada ? "Retirado" : "Entregue")</span>
                            </div>
                        </div>

                        <div class="bh-pedidos-em-andamento">
                            <div class="p-4 bg-white shadow-sm order-wrapper">

                                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-light p-3 rounded-circle text-primary shadow-sm">
                                            <i class="fa-solid fa-store fa-lg"></i>
                                        </div>
                                        <div>
                                            <span class="label-mobile">Modo de Entrega</span>
                                            <div class="fw-bold text-dark">@p.MetodoEntrega</div>
                                            @if (p.HorarioRetirada != default)
                                            {
                                                <div class="text-success small fw-semibold">
                                                    <i class="fa-regular fa-clock me-1"></i>
                                                    Agendado: @p.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm", pt)
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="text-muted small">Aguardando definição de horário</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="text-md-center bg-light p-2 px-3 rounded-2 shadow-sm">
                                        <span class="label-mobile d-block">Pagamento</span>
                                        <div class="small text-muted mb-1">
                                            Tipo: <b>@ObterRotuloPagamento(tipoPagamento)</b>
                                        </div>
                                        <span class="badge rounded-pill px-3 @badgePagamentoClass">
                                            @statusPagamento
                                        </span>
                                    </div>
                                </div>

                                <div class="card bg-light border-0 rounded-4 p-3 mb-4">
                                    <div class="d-flex justify-content-between mb-2 small">
                                        <span>Subtotal</span>
                                        <span class="fw-bold">@p.Subtotal.ToString("C", pt)</span>
                                    </div>
                                    <div class="d-flex justify-content-between mb-2 small">
                                        <span>Sinal para produção</span>
                                        <span class="fw-bold text-success">@p.ValorSinal.ToString("C", pt)</span>
                                    </div>
                                    <div class="d-flex justify-content-between small text-muted">
                                        <span>Restante na retirada/entrega</span>
                                        <span>@p.ValorRestanteRetirada.ToString("C", pt)</span>
                                    </div>
                                    <hr class="my-3 opacity-25" />
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-semibold">Total do pedido</span>
                                        <span class="fw-bold fs-6">@p.Total.ToString("C", pt)</span>
                                    </div>
                                </div>

                                @if (ehPix)
                                {
                                    <div class="row g-3 mb-4">
                                        <div class="col-12 col-lg-5">
                                            <div class="bg-white p-3 rounded-4 border shadow-sm h-100">
                                                <div class="d-flex align-items-start justify-content-between mb-2">
                                                    <div>
                                                        <div class="fw-bold" style="color: var(--bh-primary);">Escaneie o QR Code</div>
                                                        <small class="text-muted" style="font-size: 0.75rem;">
                                                            Abra o app do seu banco → PIX → QR Code
                                                        </small>
                                                    </div>

                                                    @if (!string.IsNullOrWhiteSpace(pagamento?.PixExpiraEm))
                                                    {
                                                        <span class="badge rounded-pill text-bg-light border" style="font-size: 0.75rem; color: var(--bh-primary);">
                                                            <i class="fa-regular fa-clock me-1"></i>
                                                            Expira em <b>@pagamento.PixExpiraEm</b>
                                                        </span>
                                                    }
                                                </div>

                                                <div class="d-flex justify-content-center my-3">
                                                    @if (!string.IsNullOrWhiteSpace(pagamento?.PixQrCodeUrl))
                                                    {
                                                        <img src="@pagamento.PixQrCodeUrl"
                                                             alt="QR Code PIX"
                                                             class="img-fluid rounded-4 border"
                                                             style="max-width: 240px; background: #fff; padding: 10px;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="w-100 text-center border rounded-4 py-5 bg-light text-muted small">
                                                            QR Code indisponível no momento.
                                                        </div>
                                                    }
                                                </div>

                                                <div class="alert border-0 rounded-4 mb-0"
                                                     style="background-color: #f0f7ff; border-left: 4px solid #007bff !important;">
                                                    <div class="d-flex align-items-start">
                                                        <i class="fa-solid fa-shield-check text-primary me-2 mt-1"></i>
                                                        <div style="font-size: 0.8rem; line-height: 1.4;">
                                                            Após o pagamento, a confirmação pode levar alguns segundos.
                                                            Caso prefira, você pode fechar esta tela e acompanhar o status em
                                                            <strong>Acompanhar pedidos</strong>, onde também será possível
                                                            visualizar novamente o <strong>QR Code</strong> e o
                                                            <strong>código PIX (copia e cola)</strong>.
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-lg-7">
                                            <div class="bg-white p-3 rounded-4 border shadow-sm h-100">
                                                <div class="d-flex align-items-center justify-content-between mb-2">
                                                    <div>
                                                        <div class="fw-bold" style="color: var(--bh-primary);">Ou copie o código PIX</div>
                                                        <small class="text-muted" style="font-size: 0.75rem;">
                                                            Cole no app do banco → PIX → Copia e Cola
                                                        </small>
                                                    </div>
                                                    <i class="fa-brands fa-pix fs-3 opacity-25"></i>
                                                </div>

                                                <div class="mb-3">
                                                    <label class="small text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">
                                                        PIX copia e cola
                                                    </label>
                                                    <div class="input-group">
                                                        <textarea id="pixCopiaCola_@p.Codigo"
                                                                  class="form-control border rounded-3"
                                                                  rows="2"
                                                                  readonly
                                                                  style="font-size: 0.8rem; resize: none;">@pagamento?.PixCopiaCola</textarea>

                                                        <button type="button"
                                                                class="btn btn-outline-dark fw-bold"
                                                                onclick="copyToClipboard('pixCopiaCola_@p.Codigo')">
                                                            <i class="fa-regular fa-copy me-1"></i> Copiar
                                                        </button>
                                                    </div>
                                                </div>

                                                <div class="p-3 rounded-4 mb-3" style="background:#f8f9fa; border: 1px dashed #ddd;">
                                                    <div class="d-flex justify-content-between mb-1">
                                                        <span class="text-muted small">Identificador</span>
                                                        <span class="small fw-bold">@pagamento?.PixIdentificador</span>
                                                    </div>
                                                    <div class="d-flex justify-content-between mb-1">
                                                        <span class="text-muted small">Beneficiário</span>
                                                        <span class="small fw-bold">@pagamento?.PixBeneficiario</span>
                                                    </div>
                                                    <div class="d-flex justify-content-between">
                                                        <span class="text-muted small">Valor</span>
                                                        <span class="small fw-bold">
                                                            @p.ValorSinal.ToString("C", pt)
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="d-flex flex-column flex-md-row gap-2">
                                                    @if (pagamentoConfirmado)
                                                    {
                                                        <div class="alert alert-success border-0 rounded-4 mb-0 w-100">
                                                            <i class="fa-solid fa-circle-check me-1"></i>
                                                            Pagamento PIX confirmado com sucesso.
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button type="button"
                                                                class="btn btn-success fw-bold rounded-4 flex-fill">
                                                            <i class="fa-solid fa-circle-check me-1"></i> Já paguei
                                                        </button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                else if (ehCartao)
                                {
                                    <div class="mb-4">
                                        <div class="bg-white p-4 rounded-4 border shadow-sm text-center">
                                            <i class="fa-solid fa-credit-card fa-3x mb-3" style="color: #6f42c1;"></i>
                                            <h5 class="fw-bold">Pagamento Online</h5>
                                            <p class="text-muted small px-lg-5">
                                                Clique no botão abaixo para abrir nosso checkout seguro e realizar o pagamento do sinal com seu cartão de crédito.
                                            </p>

                                            <div class="alert border-0 rounded-4 mb-4 text-start"
                                                 style="background-color: #f5efff; border-left: 4px solid #6f42c1 !important;">
                                                <div class="d-flex align-items-start">
                                                    <i class="fa-solid fa-shield-check me-2 mt-1" style="color: #6f42c1;"></i>
                                                    <div style="font-size: 0.8rem; line-height: 1.4;">
                                                        O pagamento do sinal poderá ser realizado em até <strong>24 horas</strong>.
                                                        Após a aprovação da transação, o sistema identificará automaticamente a confirmação do pagamento.
                                                        Caso prefira, você pode fechar esta tela e acompanhar o status em
                                                        <strong>Acompanhar pedidos</strong>.
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="card bg-light border-0 rounded-4 p-3 mb-4 text-start">
                                                <div class="d-flex justify-content-between mb-2 small">
                                                    <span>Sinal (Cartão)</span>
                                                    <span class="fw-bold">@p.ValorSinal.ToString("C", pt)</span>
                                                </div>
                                                <div class="d-flex justify-content-between small text-muted">
                                                    <span>Status</span>
                                                    <span>@statusPagamento</span>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(pagamento?.Gateway))
                                                {
                                                    <div class="d-flex justify-content-between small text-muted mt-2">
                                                        <span>Gateway</span>
                                                        <span>@pagamento.Gateway</span>
                                                    </div>
                                                }
                                            </div>

                                            @if (pagamentoConfirmado)
                                            {
                                                <div class="alert alert-success border-0 rounded-4 mb-0">
                                                    <i class="fa-solid fa-circle-check me-1"></i>
                                                    Pagamento confirmado com sucesso.
                                                </div>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(pagamento?.InvoiceUrl))
                                            {
                                                <a href="@pagamento.InvoiceUrl"
                                                       target="_blank"
                                                       class="btn btn-primary w-100 fw-bold rounded-4 py-3 shadow"
                                                       style="background-color: #6f42c1; border: none;">
                                                    <i class="fa-solid fa-lock me-2"></i> Abrir Checkout Seguro
                                                </a>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-primary w-100 fw-bold rounded-4 py-3 shadow"
                                                        style="background-color: #6f42c1; border: none;"
                                                        disabled>
                                                    <i class="fa-solid fa-lock me-2"></i> Checkout indisponível
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-light border rounded-4 shadow-sm mb-4">
                                        <div class="fw-bold mb-1">Pagamento ainda não detalhado</div>
                                        <div class="small text-muted">
                                            As informações do meio de pagamento ainda não estão disponíveis para este pedido.
                                        </div>
                                    </div>
                                }

                                <div class="card border shadow-sm rounded-4 mb-3" style="background: #a9a9a936;">
                                    <div class="card-body p-4">
                                        @if (p.Itens == null || !p.Itens.Any())
                                        {
                                            <div class="text-center py-3 text-muted small">Nenhum item encontrado.</div>
                                        }
                                        else
                                        {
                                            @foreach (var it in p.Itens)
                                            {
                                                <div class="mb-1">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <span class="fw-bold text-dark" style="font-size: 0.85rem;">
                                                            @it.Quantidade x @it.ProdutoNome
                                                        </span>
                                                        <span class="fw-bold text-dark" style="font-size: 0.85rem;">
                                                            @it.TotalLinha.ToString("C", pt)
                                                        </span>
                                                    </div>

                                                    @if (it.Acompanhamentos?.Any() == true)
                                                    {
                                                        <div class="mt-1">
                                                            @foreach (var ac in it.Acompanhamentos)
                                                            {
                                                                <div class="d-flex justify-content-between text-muted ms-2" style="font-size: 0.75rem;">
                                                                    <span>+ @ac.Nome.ToLower()</span>
                                                                    <span>@ac.Preco.ToString("C", pt)</span>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            }

                                            <hr class="text-muted opacity-25">
                                            <div class="d-flex justify-content-between align-items-center mt-3">
                                                <span class="text-secondary" style="font-size: 1rem;">Total da encomenda</span>
                                                <span class="fw-bold text-dark" style="font-size: 1.1rem;">
                                                    @p.Total.ToString("C", pt)
                                                </span>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <span class="label-mobile">Observações</span>
                                    <div class="small italic text-muted">
                                        <i class="fa-regular fa-comment-dots me-1 opacity-50"></i>
                                        @(string.IsNullOrWhiteSpace(p.Observacao) ? "Nenhuma observação" : p.Observacao)
                                    </div>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

</div>
</div>
</div>
</div>

<script src="~/js/pedido/acompanhamento-pedido.js" asp-append-version="true"></script>