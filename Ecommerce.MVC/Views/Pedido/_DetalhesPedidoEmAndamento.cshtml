        background: #eef5ff;
        border: 1px solid #cfe2ff;
        border-radius: 14px;
        font-weight: 600;
        color: #0a58ca;
    }

    .concluido-side-box {
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
    }

    @@keyframes concluidoCheckPulse {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 10px 26px rgba(0,0,0,.16);
        }
        50% {
            transform: scale(1.08);
            box-shadow: 0 14px 28px rgba(13,110,253,.24);
        }
    }

    @@keyframes concluidoFinishFloat {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-7px);
        }
    }

    @@keyframes concluidoDot {
        0%, 100% {
            opacity: .35;
            transform: scale(.9);
        }
        50% {
            opacity: 1;
            transform: scale(1.2);
        }
    }

    @@keyframes concluidoActiveGlow {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 rgba(13,110,253,0);
        }
        50% {
            transform: scale(1.08);
            box-shadow: 0 0 0 8px rgba(13,110,253,.10);
        }
    }

    @@keyframes concluidoShine {
        0% {
            left: -35%;
        }
        100% {
            left: 120%;
        }
    }
</style>
