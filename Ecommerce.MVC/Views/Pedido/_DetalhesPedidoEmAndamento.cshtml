@using System.Globalization
@using Ecommerce.MVC.Enums
@using Ecommerce.MVC.Models.Pedidos
@model PedidosEmAndamentoViewModel

@{
    var pt = new CultureInfo("pt-BR");

    var pagamentos = Model.Pagamentos ?? new List<PedidoPagamentoViewModel>();

    var pagamento = Model.Status == EPedidoStatus.AguardandoPagamento
        ? pagamentos.OrderBy(p => p.Sequencia).FirstOrDefault()
        : pagamentos.OrderBy(p => p.Sequencia).FirstOrDefault();

    var tipoPagamento = pagamento?.TipoPagamento?.Trim();

    bool ehPix = string.Equals(tipoPagamento, "PIX", StringComparison.OrdinalIgnoreCase);

    bool ehCartao = !string.IsNullOrWhiteSpace(tipoPagamento)
        && (tipoPagamento.Contains("cartao", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("cartão", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("credito", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("crédito", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("debito", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("débito", StringComparison.OrdinalIgnoreCase)
            || tipoPagamento.Contains("card", StringComparison.OrdinalIgnoreCase));

    bool pagamentoConfirmado = Model.Status == EPedidoStatus.Confirmado;

    // bool pagamentoConfirmado = pagamento != null &&
    //     (pagamento.Status == EStatusPagamento.Received
    //     || pagamento.Status == EStatusPagamento.Confirmed
    //     || pagamento.Status == EStatusPagamento.ReceivedInCash);

    bool ehPagamentoSinal = pagamento != null && pagamento.TipoCobranca == ETipoCobrancaPedido.Sinal;
    bool ehPagamentoTotal = pagamento != null &&
        (pagamento.TipoCobranca == ETipoCobrancaPedido.Saldo
         || pagamento.TipoCobranca == ETipoCobrancaPedido.Complemento
         || pagamento.TipoCobranca == ETipoCobrancaPedido.Ajuste);

    var valorEmExibicao = pagamento?.Valor ?? Model.ValorSinal;
    var valorRetiradaExibicao = ehPagamentoTotal ? 0 : Model.ValorRestanteRetirada;

    string tituloPagamentoPendente = ehPagamentoSinal
        ? "Aguardando pagamento do sinal"
        : "Aguardando pagamento";

    string subtituloPagamentoPendente = ehPagamentoSinal
        ? $"Seu sinal de {valorEmExibicao.ToString("C", pt)} ainda não foi confirmado."
        : $"Seu pagamento de {valorEmExibicao.ToString("C", pt)} ainda não foi confirmado.";

    string badgePagamentoClass = "bg-secondary";

    if (pagamento != null)
    {
        if (pagamento.Status == EStatusPagamento.Received
            || pagamento.Status == EStatusPagamento.Confirmed
            || pagamento.Status == EStatusPagamento.ReceivedInCash)
        {
            badgePagamentoClass = "bg-success";
        }
        else if (pagamento.Status == EStatusPagamento.Pending
            || pagamento.Status == EStatusPagamento.AwaitingRiskAnalysis
            || pagamento.Status == EStatusPagamento.DunningRequested)
        {
            badgePagamentoClass = "bg-warning text-dark";
        }
        else if (pagamento.Status == EStatusPagamento.Overdue
            || pagamento.Status == EStatusPagamento.Refunded
            || pagamento.Status == EStatusPagamento.RefundRequested
            || pagamento.Status == EStatusPagamento.RefundInProgress
            || pagamento.Status == EStatusPagamento.ChargebackRequested
            || pagamento.Status == EStatusPagamento.ChargebackDispute
            || pagamento.Status == EStatusPagamento.AwaitingChargebackReversal)
        {
            badgePagamentoClass = "bg-danger";
        }
    }

    bool pedidoEmPreparo = Model.Status == EPedidoStatus.EmPreparo;
    bool pedidoPronto = Model.Status == EPedidoStatus.Pronto;
    bool pedidoConcluido = Model.Status == EPedidoStatus.Concluido;

    string badgePedidoClass = Model.Status switch
    {
        EPedidoStatus.Rascunho => "bg-secondary",
        EPedidoStatus.AguardandoPagamento => "bg-warning text-dark",
        EPedidoStatus.Confirmado => "bg-info text-dark",
        EPedidoStatus.EmPreparo => "bg-warning text-dark",
        EPedidoStatus.Pronto => "bg-success",
        EPedidoStatus.Concluido => "bg-primary",
        EPedidoStatus.Cancelado => "bg-danger",
        _ => "bg-secondary"
    };

    var agora = DateTime.Now;
    var retiradaLocal = Model.HorarioRetirada;
    var emPreparoEmLocal = Model.EmpreparoEmUtc?.ToLocalTime();
    var prontoEmLocal = Model.ProntoEmUtc?.ToLocalTime();
    var concluidoEmLocal = Model.ConcluidoEmUtc?.ToLocalTime();

    bool retiradaAtrasada = pedidoEmPreparo && agora > retiradaLocal;

    string textoRetiradaPrevista = retiradaLocal?.ToString("dd/MM/yyyy 'às' HH:mm", pt);
    string textoEmPreparoEm = emPreparoEmLocal?.ToString("dd/MM/yyyy 'às' HH:mm", pt) ?? "-";
    string textoProntoEm = prontoEmLocal?.ToString("dd/MM/yyyy 'às' HH:mm", pt) ?? "-";
    string textoConcluidoEm = concluidoEmLocal?.ToString("dd/MM/yyyy 'às' HH:mm", pt) ?? "-";

    string GetFinanceiroStatusTexto()
    {
        if (Model.PedidoQuitado)
            return "Quitado";

        if (Model.ValorPago > 0)
            return "Pagamento parcial";

        return "Aguardando pagamento";
    }
}

<input type="hidden" id="pixPedidoId" value="@Model.Id" />

@if (pagamento != null && !string.IsNullOrWhiteSpace(pagamento.GatewayPaymentId))
{
    <input type="hidden" id="gatewayPaymentId" value="@pagamento.GatewayPaymentId" />
}
else
{
    <input type="hidden" id="gatewayPaymentId" value="" />
}

<style>
    .header-confirmado-preparo {
        background: linear-gradient(135deg, #3d3870 0%, #20c997 100%);
    }

    .preparo-animation-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 14px;
        flex-wrap: nowrap;
    }

    .preparo-icon-stage {
        width: 68px;
        height: 68px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.18);
        border: 2px solid rgba(255,255,255,.28);
        backdrop-filter: blur(2px);
        font-size: 1.5rem;
        box-shadow: 0 8px 20px rgba(0,0,0,.12);
    }

    .stage-paid {
        animation: popApproved 1.8s ease-in-out infinite;
    }

    .stage-kitchen {
        animation: floatKitchen 1.4s ease-in-out infinite;
    }

    .preparo-flow-line {
        display: flex;
        align-items: center;
        gap: 8px;
        min-width: 70px;
        justify-content: center;
    }

    .flow-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: rgba(255,255,255,.4);
        animation: pulseDot 1.2s infinite ease-in-out;
    }

    .flow-dot.dot-2 {
        animation-delay: .2s;
    }

    .flow-dot.dot-3 {
        animation-delay: .4s;
    }

    .timeline-confirmado {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .timeline-step {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .timeline-bullet {
        width: 34px;
        height: 34px;
        min-width: 34px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: .9rem;
        margin-top: 2px;
    }

    .timeline-step.done .timeline-bullet {
        background: #198754;
        color: #fff;
        box-shadow: 0 6px 14px rgba(25,135,84,.22);
    }

    .timeline-step.active .timeline-bullet {
        background: #fff3cd;
        color: #a15c00;
        border: 1px solid #ffe08a;
        animation: activeBurner 1.1s ease-in-out infinite;
    }

    .timeline-content {
        flex: 1;
    }

    .fake-progress {
        height: 10px;
        width: 100%;
        background: #edf2f7;
        border-radius: 999px;
        overflow: hidden;
        position: relative;
    }

    .fake-progress-bar {
        width: 45%;
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(135deg, #3d3870 0%, #20c997 100%);
        animation: loadingRun 2.2s ease-in-out infinite;
    }

    .resumo-confirmado-box {
        background: #f8f9fa;
        border: 1px dashed #dee2e6;
    }

    @@keyframes pulseDot {
        0%, 100% {
            opacity: .35;
            transform: scale(.9);
        }
        50% {
            opacity: 1;
            transform: scale(1.2);
        }
    }

    @@keyframes floatKitchen {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-6px);
        }
    }

    @@keyframes popApproved {
        0%, 100% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.08);
        }
    }

    @@keyframes activeBurner {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 rgba(255,193,7,0);
        }
        50% {
            transform: scale(1.08);
            box-shadow: 0 0 0 8px rgba(255,193,7,.12);
        }
    }

    @@keyframes loadingRun {
        0% {
            transform: translateX(-65%);
        }
        50% {
            transform: translateX(60%);
        }
        100% {
            transform: translateX(180%);
        }
    }
</style>
