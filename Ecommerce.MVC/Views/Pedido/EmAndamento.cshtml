    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px; overflow: hidden;">
            <div class="modal-header border-0 pb-0 d-flex justify-content-between align-items-center mb-2">
                <div style="line-height: 4px;">
                    <h5 class="modal-title fw-bold mb-0" style="color:#3c1e0a;" id="pedidoTitulo">Detalhes do Pedido</h5>
                </div>
                <button type="button" class="btn-close-custom" data-bs-dismiss="modal" aria-label="Fechar">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div class="modal-body p-0" id="modalDetalhesPedidoBody">
