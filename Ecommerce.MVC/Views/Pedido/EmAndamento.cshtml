<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
<script>
    $(document).ready(function () {
        const $inputCodigo = $('#filtroCodigo');
        const $selectStatus = $('#filtroStatus');
        const modalEl = document.getElementById('modalDetalhesPedido');
        const modalBody = $('#modalDetalhesPedidoBody');
        let paginaAtual = 1;

        let valorOriginal = $inputCodigo.val();

        // =========================================================
        // CONTROLE DA CONEXÃO SIGNALR DOS DETALHES
        // =========================================================
        let detalhesConnection = null;
        let detalhesPedidoCodigoAtual = null;

        async function encerrarConexaoDetalhes() {
            console.log("[SignalR][Detalhes] Encerrar conexão solicitado.", {
                codigoAtual: detalhesPedidoCodigoAtual
            });

            if (detalhesConnection) {
                try {
                    await detalhesConnection.stop();
                    console.log("[SignalR][Detalhes] Conexão encerrada com sucesso.");
                } catch (error) {
                    console.error("[SignalR][Detalhes] Erro ao encerrar conexão:", error);
                }
            }

            detalhesConnection = null;
            detalhesPedidoCodigoAtual = null;
        }

        async function iniciarConexaoDetalhes(gatewayPaymentId) {
            console.log("[SignalR][Detalhes] iniciarConexaoDetalhes chamado.", { gatewayPaymentId });

            if (!gatewayPaymentId) {
                console.warn("[SignalR][Detalhes] gatewayPaymentId não informado. Conexão não iniciada.");
                return;
            }

            if (typeof signalR === "undefined") {
                console.error("[SignalR][Detalhes] Biblioteca signalR não carregada.");
                return;
            }

            if (detalhesConnection) {
                console.log("[SignalR][Detalhes] Já existe uma conexão anterior. Encerrando...");
                try {
                    await detalhesConnection.stop();
                    console.log("[SignalR][Detalhes] Conexão anterior encerrada com sucesso.");
                } catch (error) {
                    console.error("[SignalR][Detalhes] Erro ao encerrar conexão anterior:", error);
                }
            }

            detalhesPedidoCodigoAtual = gatewayPaymentId;

            console.log("[SignalR][Detalhes] Criando nova conexão com /hubs/pagamento ...");

            detalhesConnection = new signalR.HubConnectionBuilder()
                .withUrl("/hubs/pagamento")
                .withAutomaticReconnect()
                .build();

            detalhesConnection.onreconnecting((error) => {
                console.warn("[SignalR][Detalhes] Reconectando...", error);
            });

            detalhesConnection.onreconnected((connectionId) => {
                console.log("[SignalR][Detalhes] Reconectado com sucesso.", { connectionId });

                if (detalhesPedidoCodigoAtual) {
                    detalhesConnection.invoke("EntrarNoGrupoPedido", detalhesPedidoCodigoAtual)
                        .then(() => {
                            console.log("[SignalR][Detalhes] Reentrou no grupo após reconexão.", {
                                gatewayPaymentId: detalhesPedidoCodigoAtual
                            });
                        })
                        .catch((error) => {
                            console.error("[SignalR][Detalhes] Erro ao reentrar no grupo:", error);
                        });
                }
            });

            detalhesConnection.onclose((error) => {
                if (error) {
                    console.error("[SignalR][Detalhes] Conexão encerrada com erro:", error);
                } else {
                    console.log("[SignalR][Detalhes] Conexão encerrada normalmente.");
                }
            });

            detalhesConnection.on("PedidoAtualizado", function (data) {
                console.log("[SignalR][Detalhes] Evento recebido: PedidoAtualizado", data);

                if (data.statusDescricao && $("#detalhe-status-pedido").length) {
                    $("#detalhe-status-pedido").text(data.statusDescricao);
                }

                if (data.statusClasse && $("#detalhe-status-pedido").length) {
                    $("#detalhe-status-pedido")
                        .removeClass()
                        .addClass(`badge ${data.statusClasse}`);
                }

                if (data.htmlPagamento && $("#detalhe-container-pagamento").length) {
                    $("#detalhe-container-pagamento").html(data.htmlPagamento);
                }

                if (data.mensagem && $("#detalhe-mensagem-status").length) {
                    $("#detalhe-mensagem-status").html(data.mensagem);
                }

                agendarRecargaListaPedidos();
            });

            detalhesConnection.on("PagamentoConfirmado", function (data) {
                console.log("[SignalR][Detalhes] Evento recebido: PagamentoConfirmado", data);

                if ($("#detalhe-container-pagamento").length) {
                    $("#detalhe-container-pagamento").prepend(`
                        <div class="alert alert-success border-0 rounded-4 mb-3 animate__animated animate__fadeIn">
                            <i class="fa-solid fa-circle-check me-1"></i>
                            Pagamento confirmado com sucesso.
                        </div>
                    `);
                }

                if ($("#detalhe-status-pedido").length && data.statusDescricao) {
                    $("#detalhe-status-pedido").text(data.statusDescricao);
                }

                agendarRecargaListaPedidos();
            });

            detalhesConnection.on("PagamentoPendente", function (data) {
                console.log("[SignalR][Detalhes] Evento recebido: PagamentoPendente", data);

                if ($("#detalhe-container-pagamento").length) {
                    $("#detalhe-container-pagamento").prepend(`
                        <div class="alert alert-warning border-0 rounded-4 mb-3">
                            <i class="fa-regular fa-hourglass-half me-1"></i>
                            Status do pagamento: ${data.status ?? 'Pendente'}
                        </div>
                    `);
                }

                agendarRecargaListaPedidos();
            });

            detalhesConnection.on("PagamentoRecusado", function (data) {
                console.log("[SignalR][Detalhes] Evento recebido: PagamentoRecusado", data);

                if ($("#detalhe-container-pagamento").length) {
                    $("#detalhe-container-pagamento").prepend(`
                        <div class="alert alert-danger border-0 rounded-4 mb-3">
                            <i class="fa-solid fa-circle-xmark me-1"></i>
                            O pagamento não foi confirmado. Status: ${data.status ?? 'Recusado'}
                        </div>
                    `);
                }

                agendarRecargaListaPedidos();
            });

            try {
                console.log("[SignalR][Detalhes] Iniciando conexão...");
                await detalhesConnection.start();
                console.log("[SignalR][Detalhes] Conexão iniciada com sucesso.");

                console.log("[SignalR][Detalhes] Entrando no grupo do pagamento...", { gatewayPaymentId });
                await detalhesConnection.invoke("EntrarNoGrupoPedido", gatewayPaymentId);
                console.log("[SignalR][Detalhes] Usuário conectado ao grupo com sucesso.", { gatewayPaymentId });
            } catch (error) {
                console.error("[SignalR][Detalhes] Erro ao iniciar conexão ou entrar no grupo:", error);
            }
        }

        // =========================================================
        // AO FECHAR O MODAL, ENCERRA A CONEXÃO
        // =========================================================
        modalEl.addEventListener('hidden.bs.modal', async function () {
            console.log("[Modal][Detalhes] Modal fechado. Encerrando conexão...");

            await encerrarConexaoDetalhes();

            modalBody.html(`
                <div class="p-4 text-center text-muted">
                    Carregando...
                </div>
            `);
        });

        // =========================================================
        // 1. FUNÇÃO CENTRAL AJAX
        // =========================================================
        function carregarPedidos(pagina = 1) {
            paginaAtual = pagina;

            if (typeof addLoading === "function") addLoading("Atualizando lista...");

            const dados = {
                status: $selectStatus.val(),
                codigo: $inputCodigo.val(),
                pagina: pagina
            };

            $.ajax({
                url: '@Url.Action("GetListaPedidos", "Pedido")',
                type: 'GET',
                data: dados,
                success: function (html) {
                    $('#tabela-pedidos-container').html(html);
                    valorOriginal = $inputCodigo.val();
                },
                error: function () {
                    console.error("Erro ao filtrar.");
                },
                complete: function () {
                    if (typeof removeLoading === "function") {
                        removeLoading();
                    }
                }
            });
        }

        function recarregarListaAtual() {
            carregarPedidos(paginaAtual || 1);
        }

        // =========================================================
        // 2. EVENTOS DE FILTRO
        // =========================================================
        $selectStatus.on('change', function () {
            carregarPedidos(1);
        });

        $inputCodigo.on('blur', function () {
            if ($(this).val() !== valorOriginal) {
                carregarPedidos(1);
            }
        });

        $inputCodigo.on('keypress', function (e) {
            if (e.which === 13) {
                e.preventDefault();
                carregarPedidos(1);
            }
        });

        // =========================================================
        // 3. PAGINAÇÃO E LIMPEZA
        // =========================================================
        $(document).on('click', '.btn-pagina-ajax', function (e) {
            e.preventDefault();
            const pag = $(this).data('pagina');
            paginaAtual = pag;
            carregarPedidos(pag);
        });

        $(document).on('click', '.btn-link-clean, .btn-resetar-filtros', function (e) {
            e.preventDefault();
            $inputCodigo.val('');
            $selectStatus.val('');
            carregarPedidos(1);
        });

        // =========================================================
        // 4. DETALHES (MODAL + SIGNALR)
        // =========================================================
        $(document).on('click', '.btn-ver-detalhes', function () {
            const btn = $(this);
            const codigo = btn.data('codigo');
            const modalEl = $('#modalDetalhesPedido'); // O modal em questão
            const modalBody = modalEl.find('.modal-body');

            btn.prop('disabled', true).html('<i class="fa-solid fa-spinner fa-spin"></i>');

            $.ajax({
                url: '/Pedido/DetalhesEmAndamento',
                type: 'GET',
                data: { codigo: codigo },
                success: async function (html) {
                    try {
                        // Fechar qualquer conexão anterior
                        await encerrarConexaoDetalhes();

                        // Inserir o HTML carregado no modal
                        modalBody.html(html);

                        // Atualizar o título dinamicamente
                        const pedidoId = $('#modalDetalhesPedidoBody').find('#codigoPedido').val();  // Exemplo, verifique se o valor está sendo retornado corretamente
                        const statusPedido = $('#modalDetalhesPedidoBody').find('#statusPedido').val();  // Exemplo, ajuste conforme necessário

                        let titulo = 'Detalhes do Pedido #' + pedidoId;

                        // Adicionar lógica para alterar o título conforme o status
                        if (statusPedido === "AguardandoPagamento") {
                            titulo = 'Pedido #' + pedidoId ;
                        } else if (statusPedido === "EmPreparo") {
                            titulo = 'Pedido #' + pedidoId ;
                        } else if (statusPedido === "Pronto") {
                            titulo = 'Pedido #' + pedidoId ;
                        } else if (statusPedido === "Concluido") {
                            titulo = 'Pedido #' + pedidoId ;
                        } else {
                            titulo = 'Pedido #' + pedidoId;  // Default caso não haja status específico
                        }

                        // Preencher o título no modal
                        $('#pedidoTitulo').text(titulo);

                        // Inicializar o modal
                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                        modal.show();

                        const gatewayPaymentId = $('#modalDetalhesPedidoBody').find('#gatewayPaymentId').val();
                        console.log("[Modal][Detalhes] GatewayPaymentId encontrado no HTML:", { gatewayPaymentId });

                        if (gatewayPaymentId) {
                            await iniciarConexaoDetalhes(gatewayPaymentId);
                        } else {
                            console.warn("[Modal][Detalhes] GatewayPaymentId não encontrado. Modal aberto sem conexão em tempo real.");
                        }
                } catch (error) {
                    console.error("[Modal][Detalhes] Erro ao abrir detalhes com conexão:", error);
                }
            },
            error: function () {
                modalBody.html(`
                    <div class="p-4 text-center text-danger">
                        Ocorreu um erro ao carregar os detalhes do pedido.
                    </div>
                `);

                const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.show();
            },
            complete: function () {
                btn.prop('disabled', false).html('<i class="fa-solid fa-receipt fa-sm me-1"></i>Detalhes');
            }
        });
    });

