@{
    var termosServicoHtml = @"
        <p>
            Ao utilizar nossa plataforma, o cliente declara estar ciente e de acordo com as regras
            relacionadas ao cadastro, login, pedidos, pagamentos, produção e retirada.
        </p>
        <ul>
            <li class='mb-2'>
                Os pedidos estão sujeitos à disponibilidade dos produtos e à capacidade operacional da loja.
            </li>
            <li class='mb-2'>
                Os horários informados para preparo, entrega ou retirada são estimativas e podem variar em períodos de maior demanda.
            </li>
            <li class='mb-2'>
                Pedidos que dependam de confirmação de pagamento somente entram em produção após a validação do pagamento.
            </li>
            <li class='mb-2'>
                O cliente é responsável por informar corretamente seus dados cadastrais, endereço, telefone e demais informações necessárias para atendimento.
            </li>
            <li class='mb-2'>
                A loja poderá entrar em contato para confirmar dados do pedido, pagamento ou entrega, quando necessário.
            </li>
            <li class='mb-2'>
                Solicitações de cancelamento, alteração ou reembolso seguirão as regras internas da loja e do meio de pagamento utilizado.
            </li>
            <li class='mb-2'>
                Ao prosseguir com o cadastro ou uso da plataforma, o cliente concorda com o tratamento dos dados necessários para a execução do serviço.
            </li>
            <li>
                O uso indevido da plataforma poderá resultar em bloqueio de acesso, a critério da administração do sistema.
            </li>
        </ul>";

    var politicaPrivacidadeHtml = @"
        <p>
            Seus dados serão utilizados para autenticação, processamento de pedidos, comunicação sobre compras,
            suporte ao cliente e melhoria da experiência na plataforma.
        </p>
        <ul>
            <li class='mb-2'>
                Os dados informados no cadastro devem ser verdadeiros e atualizados.
            </li>
            <li class='mb-2'>
                As informações podem ser utilizadas para envio de notificações relacionadas ao pedido.
            </li>
            <li class='mb-2'>
                O compartilhamento com terceiros ocorre apenas quando necessário para pagamento, entrega ou obrigação legal.
            </li>
            <li class='mb-2'>
                Os dados são tratados conforme princípios de segurança, necessidade e finalidade.
            </li>
            <li>
                O cliente pode solicitar atualização cadastral ou esclarecimentos sobre o uso dos dados pelos canais de atendimento da loja.
            </li>
        </ul>";
}

<style>
    #auth-container {
        position: relative;
    }

    #modal-cliente-authBody .btn-principal {
        background-color: #D98C1A;
        color: white;
        border-radius: 1.5rem;
        padding: 12px;
        font-weight: bold;
        border: none;
        box-shadow: 0 4px 10px rgba(178, 101, 40, 0.3);
    }

        #modal-cliente-authBody .btn-principal:hover {
            background-color: #8E4F1E;
            color: white;
        }

    .auth-scroll-box {
        max-height: 340px;
        overflow-y: auto;
        border: 1px solid #eee;
        border-radius: 14px;
        background: #fafafa;
        padding: 16px;
    }

        .auth-scroll-box p,
        .auth-scroll-box li {
            font-size: 0.9rem;
            color: #6c757d;
            line-height: 1.65;
        }

        .auth-scroll-box ul {
            padding-left: 1.2rem;
            margin-bottom: 0;
        }

    .auth-section-title {
        color: #3c1e0a;
        font-weight: 700;
        font-size: 0.95rem;
        margin-bottom: 10px;
    }
</style>

<div class="modal fade" id="modal-cliente-auth" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg p-1">
        <div class="modal-content bc-modal" style="border-radius: 20px;">
            <div class="modal-body" id="modal-cliente-authBody">
                <div class="row g-0" id="auth-container">
                    <div class="d-flex align-items-center" style="position:absolute; z-index: 10; width: calc(100% - 1rem);">
                        <button type="button"
                                id="btnVoltar"
                                onclick="voltarModal()"
                                class="btn-close-custom"
                                aria-label="Voltar"
                                style="display: none;">
                            <i class="fa fa-arrow-left" style="font-size: 1.2rem;"></i>
                        </button>

                        <button type="button"
                                style="font-size: 2rem;"
                                onclick="fecharModal()"
                                class="btn-close-custom ms-auto"
                                aria-label="Close">
                            &times;
                        </button>
                    </div>

                    <div class="col-lg-5 d-none d-lg-block mb-2" id="img-banner" style="background: url('../../img/banner_lorem_login.png') center/cover; min-height: 480px;">
                        <div class="h-100 w-100" style="background: rgba(60, 30, 10, 0.4);"></div>
                    </div>

                    <div class="col-lg-7 px-2 px-lg-5 py-3" id="login-form">
                        <div class="text-center mb-2">
                            <img src="~/img/logo4.png" alt="Logo" style="width: 80px;">
                            </div>

                            <div>
                                <div class="text-center mb-4">
                                    <h4 class="fw-bold" style="color: #3c1e0a;">Entrar</h4>
                                    <p class="text-muted">Acesse para acompanhar seus pedidos</p>
                                </div>

                                <div id="loginErrorBox" class="alert alert-danger d-none" role="alert"></div>

                                <form id="loginForm"
                                      asp-controller="Cliente"
                                      asp-action="Login"
                                      method="post"
                                      asp-antiforgery="true">

                                    <div class="mb-3 text-start">
                                        <label class="form-label fw-bold" for="loginEmail">E-mail</label>
                                        <input type="email"
                                               id="loginEmail"
                                               name="email"
                                               class="form-control shadow-sm"
                                               style="height: 40px !important;"
                                               placeholder="seu@email.com"
                                               required>
                                        <div id="loginEmailFeedback" class="invalid-feedback"></div>
                                    </div>

                                    <div class="mb-3 text-start">
                                        <label class="form-label fw-bold" for="loginSenha">Senha</label>

                                        <div class="input-group shadow-sm" style="height: 40px;">
                                            <input type="password"
                                                   id="loginSenha"
                                                   name="senha"
                                                   class="form-control"
                                                   style="height: 40px !important;"
                                                   placeholder="******"
                                                   required>

                                            <span class="input-group-text cursor-pointer"
                                                  role="button"
                                                  aria-label="Mostrar/ocultar senha"
                                                  onclick="togglePasswordVisibility('loginSenha', this)">
                                                <i class="fa fa-eye"></i>
                                            </span>
                                        </div>

                                        <div id="loginSenhaFeedback" class="invalid-feedback"></div>

                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                            <small>
                                                <a href="javascript:void(0)"
                                                       onclick="showForgot()"
                                                       style="color: #d4a017; font-size: 0.75rem;">
                                                    Esqueci minha senha
                                                </a>
                                            </small>

                 @*                            <small class="d-flex gap-2 flex-wrap justify-content-end">
                                                <a href="javascript:void(0)"
                                                       onclick="showTerms('login')"
                                                       style="color: #d4a017; font-size: 0.75rem;">
                                                    Termos de Serviço
                                                </a>
                                                <a href="javascript:void(0)"
                                                       onclick="showPrivacy('login')"
                                                       style="color: #d4a017; font-size: 0.75rem;">
                                                    Política de Privacidade
                                                </a>
                                            </small> *@
                                        </div>
                                    </div>

                                    <button type="submit"
                                            class="btn w-100 btn-principal">
                                        Entrar
                                    </button>

                                    <div class="text-center mt-3">
                                        <small>
                                            Não tem conta?
                                            <a href="javascript:void(0)" onclick="toggleAuth()" style="color: #d4a017;">
                                                Cadastre-se
                                            </a>
                                        </small>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-12 px-2 px-lg-3 py-3 pt-0" id="register-form" style="display: none;">
                            <div class="text-center mb-2">
                                <img src="~/img/logo4.png" alt="Logo" style="width: 80px;">
                                </div>

                                <div>
                                    <div class="text-center mb-4">
                                        <h4 class="fw-bold" style="color: #3c1e0a;">Criar Conta</h4>
                                        <p class="text-muted small">Preencha os dados para se cadastrar</p>
                                    </div>

                                    <div id="registerErrorBox" class="alert alert-danger d-none" role="alert"></div>

                                    <form id="registerForm"
                                          asp-controller="Cliente"
                                          asp-action="Registrar"
                                          method="post"
                                          asp-antiforgery="true">

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">Nome Completo</label>
                                            <input type="text" id="registerNomeCompleto" name="NomeCompleto" class="form-control" placeholder="Seu nome" required>
                                            <div id="registerNomeCompletoFeedback" class="invalid-feedback"></div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label fw-bold">E-mail</label>
                                            <input type="email" id="registerEmail" name="Email" class="form-control" placeholder="exemplo@email.com" required>
                                            <div id="registerEmailFeedback" class="invalid-feedback"></div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">CPF</label>
                                                <input type="text"
                                                       id="registerCPF"
                                                       name="CPF"
                                                       class="form-control"
                                                       placeholder="000.000.000-00"
                                                       inputmode="numeric"
                                                       autocomplete="off"
                                                       maxlength="14"
                                                       required>
                                                <div id="registerCPFFeedback" class="invalid-feedback"></div>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">WhatsApp</label>
                                                <input type="tel"
                                                       id="registerWhatsApp"
                                                       name="WhatsApp"
                                                       class="form-control"
                                                       placeholder="(00) 00000-0000"
                                                       inputmode="tel"
                                                       autocomplete="off"
                                                       maxlength="15"
                                                       required>
                                                <div id="registerWhatsAppFeedback" class="invalid-feedback"></div>
                                            </div>
                                        </div>

                                        <div class="row">
                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Senha</label>
                                                <div class="input-group">
                                                    <input type="password"
                                                           name="Senha"
                                                           id="registerSenha"
                                                           class="form-control"
                                                           maxlength="8"
                                                           placeholder="******"
                                                           required>
                                                    <span class="input-group-text cursor-pointer"
                                                          onclick="togglePassword('registerSenha', this)">
                                                        <i class="fa fa-eye"></i>
                                                    </span>
                                                </div>
                                                <div id="registerSenhaFeedback" class="invalid-feedback"></div>
                                            </div>

                                            <div class="col-md-6 mb-3">
                                                <label class="form-label fw-bold">Confirmar Senha</label>
                                                <div class="input-group">
                                                    <input type="password"
                                                           name="ConfirmarSenha"
                                                           id="registerConfirmarSenha"
                                                           class="form-control"
                                                           maxlength="8"
                                                           placeholder="******"
                                                           required>
                                                    <span class="input-group-text cursor-pointer"
                                                          onclick="togglePassword('registerConfirmarSenha', this)">
                                                        <i class="fa fa-eye"></i>
                                                    </span>
                                                </div>
                                                <div id="registerConfirmarSenhaFeedback" class="invalid-feedback"></div>
                                            </div>

                                            <div class="mt-0" style="position: relative; top: -9px;">
                                                <small class="text-muted">
                                                    A senha deve conter entre <strong>6</strong> e <strong>8</strong> caracteres.
                                                </small>
                                            </div>
                                        </div>

                                        <hr class="my-4">

                                        <div class="bg-light p-3 rounded mb-3 border">
                                            <h6 class="fw-bold small mb-2" style="color: #3c1e0a;">Privacidade e Dados</h6>

                                            <div class="form-check mb-2 text-start">
                                                <input class="form-check-input" type="checkbox" id="checkTerms" name="AceitaTermos" required>
                                                <label class="form-check-label small" for="checkTerms">
                                                    Li e concordo com os
                                                    <a href="javascript:void(0)" onclick="showTerms('register')" style="color: #d4a017;">Termos de Serviço</a>
                                                    e a
                                                    <a href="javascript:void(0)" onclick="showPrivacy('register')" style="color: #d4a017;">Política de Privacidade</a>.
                                                </label>
                                            </div>

                                            <div class="form-check mb-2 text-start">
                                                <input class="form-check-input" type="checkbox" id="checkMarketing" name="AceitaMarketing">
                                                <label class="form-check-label small" for="checkMarketing">
                                                    Aceito receber promoções e novidades via e-mail/WhatsApp. (Opcional)
                                                </label>
                                            </div>

                                            <p class="text-muted" style="font-size: 0.75rem;">
                                                * Seus dados serão utilizados apenas para processar seus pedidos e melhorar sua experiência conosco, conforme a LGPD.
                                            </p>
                                        </div>

                                        <button type="submit" class="btn w-100 btn-principal">
                                            Finalizar Cadastro
                                        </button>

                                        <div class="text-center mt-3">
                                            <small>
                                                Já possui conta?
                                                <a href="javascript:void(0)" onclick="toggleAuth()" style="color: #d4a017;">Fazer Login</a>
                                            </small>
                                        </div>
                                    </form>
                                </div>
                            </div>

                            <div class="col-lg-7 px-2 px-lg-5 py-3" id="forgot-password-form" style="display: none;">
                                <div class="text-center mb-2 mt-4">
                                    <img src="~/img/logo4.png" alt="Logo" style="width: 80px;">
                                    </div>

                                    <div class="text-center mb-4">
                                        <h4 class="fw-bold" style="color: #3c1e0a;">Recuperar Senha</h4>
                                        <p class="text-muted">Insira seu e-mail para receber uma nova senha temporária.</p>
                                    </div>

                                    <div id="forgotPasswordSuccessBox" class="alert alert-success d-none" role="alert"></div>
                                    <div id="forgotPasswordErrorBox" class="alert alert-danger d-none" role="alert"></div>

                                    <form id="forgotPasswordForm"
                                          asp-controller="Cliente"
                                          asp-action="EsqueciMinhaSenha"
                                          method="post"
                                          asp-antiforgery="true">

                                        <div class="mb-3 text-start">
                                            <label class="form-label fw-bold" for="forgotEmail">E-mail cadastrado</label>
                                            <input type="email"
                                                   id="forgotEmail"
                                                   name="Email"
                                                   class="form-control shadow-sm"
                                                   style="height: 40px !important;"
                                                   placeholder="seu@email.com"
                                                   required>
                                            <div id="forgotEmailFeedback" class="invalid-feedback"></div>
                                        </div>

                                        <button type="submit" class="btn w-100 btn-principal">
                                            Enviar nova senha
                                        </button>

                                        <div class="text-center mt-3">
                                            <small>
                                                <a href="javascript:void(0)" onclick="showLogin()" style="color: #d4a017;">
                                                    Voltar para o Login
                                                </a>
                                            </small>
                                        </div>
                                    </form>
                                </div>

                            <div class="col-lg-12 px-2 px-lg-5 py-3" id="terms-form" style="display: none;">
                                    <div class="text-center mb-2 mt-4">
                                        <img src="~/img/logo4.png" alt="Logo" style="width: 80px;">
                                        </div>

                                        <div class="text-center mb-4">
                                            <h4 class="fw-bold" style="color: #3c1e0a;">Termos de Serviço</h4>
                                            <p class="text-muted">Leia atentamente as condições de uso da plataforma.</p>
                                        </div>

                                        <div class="auth-scroll-box mb-3">
                                            @Html.Raw(termosServicoHtml)
                                        </div>

                                        <div class="d-grid gap-2">
                                            <button type="button" class="btn btn-light border rounded-pill" onclick="voltarModal()">
                                                Voltar
                                            </button>
                                        </div>
                                    </div>

                            <div class="col-lg-12 px-2 px-lg-5 py-3" id="privacy-form" style="display: none;">
                                        <div class="text-center mb-2 mt-4">
                                            <img src="~/img/logo4.png" alt="Logo" style="width: 80px;">
                                            </div>

                                            <div class="text-center mb-4">
                                                <h4 class="fw-bold" style="color: #3c1e0a;">Política de Privacidade</h4>
                                                <p class="text-muted">Saiba como seus dados são utilizados.</p>
                                            </div>

                                            <div class="auth-scroll-box mb-3">
                                                @Html.Raw(politicaPrivacidadeHtml)
                                            </div>

                                            <div class="d-grid">
                                                <button type="button" class="btn btn-light border rounded-pill" onclick="voltarModal()">
                                                    Voltar
                                                </button>
                                            </div>
                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <script>
                        let authPreviousView = 'login';

                        function hideAllAuthScreens() {
                            document.getElementById('login-form').style.display = 'none';
                            document.getElementById('register-form').style.display = 'none';
                            document.getElementById('forgot-password-form').style.display = 'none';
                            document.getElementById('terms-form').style.display = 'none';
                            document.getElementById('privacy-form').style.display = 'none';
                        }

                        function showBanner(show) {
                            const imgBanner = document.getElementById('img-banner');
                            if (!imgBanner) return;

                            if (show) {
                                imgBanner.classList.remove('d-lg-none');
                                imgBanner.classList.add('d-lg-block');
                            } else {
                                imgBanner.classList.remove('d-lg-block');
                                imgBanner.classList.add('d-lg-none');
                            }
                        }

                        function showBackButton(show) {
                            document.getElementById('btnVoltar').style.display = show ? 'inline-flex' : 'none';
                        }

                        function togglePasswordVisibility(inputId, trigger) {
                            const input = document.getElementById(inputId);
                            if (!input) return;

                            const icon = trigger?.querySelector('i');
                            if (!icon) return;

                            const isPassword = input.type === "password";
                            input.type = isPassword ? "text" : "password";

                            icon.classList.toggle('fa-eye', !isPassword);
                            icon.classList.toggle('fa-eye-slash', isPassword);
                        }

                        function toggleAuth() {
                            const loginForm = document.getElementById('login-form');

                            if (loginForm.style.display === 'none') {
                                showLogin();
                            } else {
                                hideAllAuthScreens();
                                document.getElementById('register-form').style.display = 'block';
                                showBanner(false);
                                showBackButton(true);
                                authPreviousView = 'login';
                            }
                        }

                        function showForgot() {
                            hideAllAuthScreens();
                            document.getElementById('forgot-password-form').style.display = 'block';
                            showBanner(true);
                            showBackButton(true);
                            authPreviousView = 'login';
                        }

                        function showLogin() {
                            hideAllAuthScreens();
                            document.getElementById('login-form').style.display = 'block';
                            showBanner(true);
                            showBackButton(false);
                            authPreviousView = 'login';
                        }

                        function showTerms(fromView) {
                            authPreviousView = fromView || 'login';
                            hideAllAuthScreens();
                            document.getElementById('terms-form').style.display = 'block';
                            showBanner(false);
                            showBackButton(true);
                        }

                        function showPrivacy(fromView) {
                            authPreviousView = fromView || 'login';
                            hideAllAuthScreens();
                            document.getElementById('privacy-form').style.display = 'block';
                            showBanner(false);
                            showBackButton(true);
                        }

                        function aceitarTermos() {
                            const checkTerms = document.getElementById('checkTerms');
                            if (checkTerms) {
                                checkTerms.checked = true;
                            }
                            voltarModal();
                        }

                        function fecharModal() {
                            const modalElement = document.getElementById('modal-cliente-auth');
                            const modalInstance = bootstrap.Modal.getInstance(modalElement);
                            if (modalInstance) {
                                modalInstance.hide();
                            }

                            setTimeout(showLogin, 500);
                        }

                        function voltarModal() {
                            if (authPreviousView === 'register') {
                                hideAllAuthScreens();
                                document.getElementById('register-form').style.display = 'block';
                                showBanner(false);
                                showBackButton(true);
                                return;
                            }

                            if (authPreviousView === 'forgot') {
                                hideAllAuthScreens();
                                document.getElementById('forgot-password-form').style.display = 'block';
                                showBanner(true);
                                showBackButton(true);
                                return;
                            }

                            showLogin();
                        }

                        function onlyDigits(value) {
                            return (value || '').replace(/\D/g, '');
                        }

                        function maskCPF(value) {
                            const d = onlyDigits(value).slice(0, 11);
                            const p1 = d.slice(0, 3);
                            const p2 = d.slice(3, 6);
                            const p3 = d.slice(6, 9);
                            const p4 = d.slice(9, 11);

                            let out = p1;
                            if (p2) out += '.' + p2;
                            if (p3) out += '.' + p3;
                            if (p4) out += '-' + p4;
                            return out;
                        }

                        function maskPhoneBR(value) {
                            const d = onlyDigits(value).slice(0, 11);

                            const ddd = d.slice(0, 2);
                            const part1 = d.length > 10 ? d.slice(2, 7) : d.slice(2, 6);
                            const part2 = d.length > 10 ? d.slice(7, 11) : d.slice(6, 10);

                            let out = '';
                            if (ddd) out = `(${ddd}`;
                            if (ddd.length === 2) out += ') ';
                            if (part1) out += part1;
                            if (part2) out += '-' + part2;

                            return out;
                        }

                        function applyMask(input, masker) {
                            if (!input) return;

                            const handler = () => {
                                const start = input.selectionStart;
                                const before = input.value;

                                input.value = masker(input.value);

                                const diff = input.value.length - before.length;
                                const pos = (start || 0) + diff;
                                input.setSelectionRange(pos, pos);
                            };

                            input.addEventListener('input', handler);
                            input.addEventListener('blur', handler);
                            handler();
                        }

                        (function initMasks() {
                            const cpfInput = document.querySelector('#registerCPF');
                            const whatsappInput = document.querySelector('#registerWhatsApp');

                            applyMask(cpfInput, maskCPF);
                            applyMask(whatsappInput, maskPhoneBR);
                        })();

                        function togglePassword(inputId, trigger) {
                            const input = document.getElementById(inputId);
                            const icon = trigger.querySelector('i');

                            if (!input) return;

                            if (input.type === 'password') {
                                input.type = 'text';
                                icon.classList.remove('fa-eye');
                                icon.classList.add('fa-eye-slash');
                            } else {
                                input.type = 'password';
                                icon.classList.remove('fa-eye-slash');
                                icon.classList.add('fa-eye');
                            }
                        }
                    </script>