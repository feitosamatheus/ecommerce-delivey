@model Ecommerce.MVC.Models.Admin.AcompanhamentoCategorias.AcompanhamentoCategoriasIndexViewModel

@{
    ViewData["Title"] = "Categorias de Acompanhamento";
    ViewData["Description"] = "Gerencie os grupos de acompanhamentos do catálogo.";
}

<style>
    /* Design System Unificado */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .card-filter-clean .form-control {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        text-decoration: none;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
    }
</style>

<div class="container-fluid px-0">
    <div class="w-100 d-flex justify-content-end mb-3">
        <a asp-area="Admin" asp-controller="AcompanhamentoCategorias" asp-action="Create"
           class="btn btn-primary btn-sm shadow-sm btn-filter-action">
            <i class="fas fa-plus"></i> Nova Categoria
        </a>
    </div>
    @* Mensagens de Feedback *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
    }
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center py-2">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i> Filtros de Pesquisa
            </h3>
            <div class="card-tools ms-auto">
                <button type="button" class="btn btn-link btn-sm text-muted" data-lte-toggle="card-collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="card-body">
            <form method="get" id="formFiltroCategoriasAcomp">
                <div class="row g-3">
                    <div class="col-xl-9">
                        <label class="form-label">Nome ou Descrição</label>
                        <input type="text" name="busca" class="form-control"
                               value="@Model.Busca" placeholder="Ex: Molhos, Adicionais, Bebidas..." />
                    </div>

                    <div class="col-xl-3 d-flex align-items-end justify-content-start gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-filter-outline btn-filter-action w-100">
                            <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action w-100">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card card-table-clean">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center row">
            <h3 class="card-title fs-6 fw-bold mb-0 col-6">
                <i class="fas fa-list me-2 text-primary"></i> Categorias de Acompanhamento
            </h3>
            <div class="col-6 d-flex justify-content-end">
                <span class="badge bg-primary-subtle text-primary rounded-pill">@Model.Itens.Count() categorias</span>
            </div>
        </div>
        <div class="card-body table-responsive p-0">
            <table class="table table-hover table-clean align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 30%">Categoria</th>
                        <th>Descrição</th>
                        <th class="text-center">Qtd. Itens</th>
                        <th class="text-end" style="width: 150px">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Itens.Any())
                    {
                        foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@item.Nome</td>
                                <td class="text-muted">
                                    @(string.IsNullOrWhiteSpace(item.Descricao) ? "—" : item.Descricao)
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@item.QuantidadeAcompanhamentos itens</span>
                                </td>
                                <td class="text-end">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-white text-primary" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-categoria-acomp"
                                                data-id="@item.Id" title="Excluir">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>

                                    <form id="form-delete-@item.Id" asp-action="Delete" asp-route-id="@item.Id" 
                                          method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5">
                                <i class="fas fa-layer-group fa-3x text-light mb-3 d-block"></i>
                                <p class="text-muted mb-0">Nenhum resultado para sua consulta de pesquisa.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            // Confirmação de exclusão
            $(".btn-excluir-categoria-acomp").on("click", function () {
                const id = $(this).data("id");
                
                Swal.fire({
                    title: 'Remover Grupo?',
                    text: "Isso pode afetar os acompanhamentos vinculados a este grupo.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#2c180d',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sim, remover!',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (typeof window.addLoading === "function") {
                            window.addLoading("Processando...");
                        }
                        $(`#form-delete-${id}`).submit();
                    }
                });
            });
        });
    </script>
}