    </div>

    <!-- CONCLUÍDOS -->
    <div class="col-xl-3 col-lg-6">
        <div class="card shadow-sm border-0 cozinha-coluna-card">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <div class="col-6">
                    <h5 class="mb-0">Concluídos</h5>
                    <small class="text-muted">Pedidos finalizados</small>
                </div>

                <div class="d-flex align-items-center gap-2 col-6 justify-content-end">
                    <span class="badge bg-dark contador-pill">@concluidos.Count</span>
                    <button type="button" class="btn btn-sm btn-light toggle-card" data-target="card-concluidos">
                        <i class="bi bi-chevron-down"></i>
                    </button>
                </div>
            </div>

            <div class="card-body d-none" id="card-concluidos">
                @if (concluidos.Any())
                {
                    @foreach (var pedido in concluidos.OrderByDescending(p => p.EntregueEmUtc ?? p.ConcluidoEmUtc ?? p.CriadoEmUtc))
                    {
                        <div class="pedido-item-card p-3 mb-2">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-bold">Pedido @pedido.Codigo</div>
                                    <div class="text-muted small">@pedido.Cliente?.Nome</div>
                                </div>
                                <span class="badge bg-dark status-badge">Concluído</span>
                            </div>

                            <div class="small text-muted mb-2 info-pedido-grid">
                                <div><strong>Entrega:</strong> @pedido.MetodoEntrega</div>
                                <div><strong>Retirada:</strong> @ObterTextoHorario(pedido.HorarioRetirada)</div>
                                <div><strong>Criado em:</strong> @ObterTextoHorario(pedido.CriadoEmUtc)</div>
                                <div><strong>Em preparo em:</strong> @ObterTextoDataNullable(pedido.EmpreparoEmUtc)</div>
                                <div><strong>Concluído em:</strong> @ObterTextoDataNullable(pedido.ConcluidoEmUtc)</div>
                                <div><strong>Entregue em:</strong> @ObterTextoDataNullable(pedido.EntregueEmUtc)</div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(pedido.Observacao))
                            {
                                <div class="observacao-box small p-2 mb-2">
                                    <strong>Obs.:</strong> @pedido.Observacao
                                </div>
                            }

                            <div class="mb-0">
                                <strong>Itens</strong>
                                <ul class="lista-itens">
                                    @foreach (var item in pedido.Itens)
                                    {
                                        <li>
                                            <div>
                                                <strong>@item.Quantidade x @(item.ProdutoNomeSnapshot ?? "Item do pedido")</strong>
                                            </div>

                                            @if (item.Acompanhamentos != null && item.Acompanhamentos.Any())
                                            {
                                                <ul class="lista-acompanhamentos">
                                                    @foreach (var acomp in item.Acompanhamentos)
                                                    {
                                                        <li class="small text-muted">
                                                            + @(acomp.NomeSnapshot ?? "Acompanhamento")
                                                        </li>
                                                    }
                                                </ul>
                                            }
                                        </li>
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted mb-0">Nenhum pedido concluído.</p>
                }
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const STORAGE_KEY = 'cozinha-ui-state';

        function obterEstadoUI() {
            try {
                const raw = localStorage.getItem(STORAGE_KEY);
                return raw ? JSON.parse(raw) : { cards: {}, filtros: {} };
            } catch {
                return { cards: {}, filtros: {} };
            }
        }

        function salvarEstadoUI(estado) {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(estado));
        }

        function atualizarIcone(targetId, fechado) {
            const button = document.querySelector(`.toggle-card[data-target="${targetId}"]`);
            const icon = button ? button.querySelector('i') : null;
            if (!icon) return;

            if (fechado) {
                icon.classList.remove('bi-chevron-down');
                icon.classList.add('bi-chevron-right');
            } else {
                icon.classList.remove('bi-chevron-right');
                icon.classList.add('bi-chevron-down');
            }
        }

        function definirEstadoCard(targetId, fechado) {
            const body = document.getElementById(targetId);
            if (!body) return;

            if (fechado) {
                body.classList.add('d-none');
            } else {
                body.classList.remove('d-none');
            }

            atualizarIcone(targetId, fechado);
        }

        function ehGrupoInterno(targetId) {
            return targetId.startsWith('confirmados-')
                || targetId.startsWith('em-preparo-')
                || targetId.startsWith('prontos-');
        }

        function ehCardPrincipal(targetId) {
            return targetId === 'card-confirmados'
                || targetId === 'card-em-preparo'
                || targetId === 'card-prontos'
                || targetId === 'card-concluidos';
        }

        function aplicarFiltro(containerId, valor) {
            const container = document.getElementById(containerId);
            if (!container) return;

            const grupos = container.querySelectorAll('.grupo-filtravel');

            grupos.forEach(function (grupo) {
                const tipo = grupo.getAttribute('data-grupo');

                if (valor === 'Todos' || tipo === valor) {
                    grupo.classList.remove('d-none');
                } else {
                    grupo.classList.add('d-none');
                }
            });
        }

        function inicializarEstadosCards() {
            const estado = obterEstadoUI();

            document.querySelectorAll('.toggle-card').forEach(button => {
                const targetId = button.getAttribute('data-target');
                if (!targetId) return;

                if (Object.prototype.hasOwnProperty.call(estado.cards, targetId)) {
                    definirEstadoCard(targetId, estado.cards[targetId] === 'closed');
                    return;
                }

                // Padrão inicial:
                // grupos internos fechados no HTML
                // cards principais abertos no HTML
                if (ehGrupoInterno(targetId)) {
                    atualizarIcone(targetId, true);
                } else if (ehCardPrincipal(targetId)) {
                    atualizarIcone(targetId, false);
                }
            });
        }

        function inicializarFiltros() {
            const estado = obterEstadoUI();

            document.querySelectorAll('.filtro-grupo-coluna').forEach(select => {
                const containerId = select.getAttribute('data-container');
                if (!containerId) return;

                const valorSalvo = estado.filtros[containerId] || 'Todos';
                select.value = valorSalvo;
                aplicarFiltro(containerId, valorSalvo);
            });
        }

        function alternarCard(targetId) {
            const body = document.getElementById(targetId);
            if (!body) return;

            const estado = obterEstadoUI();
            const estaFechado = body.classList.contains('d-none');
            const novoEstadoFechado = !estaFechado;

            definirEstadoCard(targetId, novoEstadoFechado);
            estado.cards[targetId] = novoEstadoFechado ? 'closed' : 'open';
            salvarEstadoUI(estado);
        }

        function salvarFiltro(containerId, valor) {
            const estado = obterEstadoUI();
            estado.filtros[containerId] = valor;
            salvarEstadoUI(estado);
        }

        document.addEventListener('DOMContentLoaded', function () {
            inicializarEstadosCards();
            inicializarFiltros();
        });

        document.addEventListener('click', function (e) {
            const button = e.target.closest('.toggle-card');
            if (!button) return;

            const targetId = button.getAttribute('data-target');
            if (!targetId) return;

            alternarCard(targetId);
        });

        document.addEventListener('change', function (e) {
            const select = e.target.closest('.filtro-grupo-coluna');
            if (!select) return;

            const valor = select.value;
            const containerId = select.getAttribute('data-container');
            if (!containerId) return;

            aplicarFiltro(containerId, valor);
            salvarFiltro(containerId, valor);
        });
    </script>
}

