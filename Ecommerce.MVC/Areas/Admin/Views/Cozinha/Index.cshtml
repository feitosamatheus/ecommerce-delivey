@using Ecommerce.MVC.Enums
@model List<Ecommerce.MVC.Entities.Pedido>
@using Ecommerce.MVC.Entities

@{
    ViewData["Title"] = "Painel da Cozinha";
    ViewData["Description"] = "Acompanhe os pedidos por etapa e por data de retirada.";

    var confirmados = Model.Where(p => p.Status == EPedidoStatus.Confirmado).ToList();
    var emPreparo = Model.Where(p => p.Status == EPedidoStatus.EmPreparo).ToList();
    var prontos = Model.Where(p => p.Status == EPedidoStatus.Pronto).ToList();
    var concluidos = Model.Where(p => p.Status == EPedidoStatus.Concluido).ToList();

    var gruposConfirmados = confirmados
        .GroupBy(p => ObterGrupoData(p.HorarioRetirada))
        .OrderBy(g => ObterOrdemGrupo(g.Key))
        .ToList();

    var gruposEmPreparo = emPreparo
        .GroupBy(p => ObterGrupoData(p.HorarioRetirada))
        .OrderBy(g => ObterOrdemGrupo(g.Key))
        .ToList();

    var gruposProntos = prontos
        .GroupBy(p => ObterGrupoData(p.HorarioRetirada))
        .OrderBy(g => ObterOrdemGrupo(g.Key))
        .ToList();
}

@functions {
    public string ObterGrupoData(DateTime dataHora)
    {
        var data = dataHora.ToLocalTime().Date;
        var hoje = DateTime.Now.Date;

        if (data < hoje)
            return "Vencido";

        if (data == hoje)
            return "Hoje";

        if (data == hoje.AddDays(1))
            return "Amanhã";

        return "Futuro";
    }

    public string ObterClasseGrupo(string grupo)
    {
        return grupo switch
        {
            "Vencido" => "danger",
            "Hoje" => "primary",
            "Amanhã" => "success",
            "Futuro" => "secondary",
            _ => "secondary"
        };
    }

    public int ObterOrdemGrupo(string grupo)
    {
        return grupo switch
        {
            "Vencido" => 0,
            "Hoje" => 1,
            "Amanhã" => 2,
            "Futuro" => 3,
            _ => 4
        };
    }

    public string ObterTextoHorario(DateTime dataHora)
    {
        return dataHora.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    public string ObterTextoDataNullable(DateTime? dataHora)
    {
        if (!dataHora.HasValue)
            return "-";

        return dataHora.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm");
    }

    public string NormalizarId(string texto)
    {
        if (string.IsNullOrWhiteSpace(texto))
            return "grupo";

        return texto
            .ToLowerInvariant()
            .Replace("ã", "a")
            .Replace("á", "a")
            .Replace("à", "a")
            .Replace("â", "a")
            .Replace("é", "e")
            .Replace("ê", "e")
            .Replace("í", "i")
            .Replace("ó", "o")
            .Replace("ô", "o")
            .Replace("õ", "o")
            .Replace("ú", "u")
            .Replace("ç", "c")
            .Replace(" ", "-")
            .Replace("/", "-");
    }
}

@section Styles {
    <style>
        .cozinha-resumo-card {
            border-radius: 16px;
        }

        .cozinha-coluna-card {
            border-radius: 18px;
            overflow: hidden;
        }

            .cozinha-coluna-card .card-header {
                border-bottom: 1px solid rgba(0,0,0,.06);
            }

        .grupo-data-card {
            border-radius: 14px;
            overflow: hidden;
            background: #fff;
        }

            .grupo-data-card .card-header {
                border-bottom: 1px solid rgba(0,0,0,.05);
            }

        .pedido-item-card {
            border: 1px solid rgba(0,0,0,.08);
            border-radius: 14px;
            background: #fff;
        }

            .pedido-item-card:last-child {
                margin-bottom: 0 !important;
            }

        .toggle-card {
            min-width: 34px;
            height: 34px;
            padding: 0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .contador-pill {
            min-width: 32px;
            height: 32px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            font-weight: 600;
        }

        .lista-itens {
            padding-left: 1rem;
            margin-bottom: 0;
        }

            .lista-itens li {
                margin-bottom: .35rem;
            }

        .lista-acompanhamentos {
            margin-top: .35rem;
            margin-bottom: 0;
            padding-left: 1.25rem;
        }

            .lista-acompanhamentos li {
                margin-bottom: .2rem;
            }

        .observacao-box {
            background: #f8f9fa;
            border: 1px solid rgba(0,0,0,.06);
            border-radius: 12px;
        }

        .subtitulo-coluna {
            font-size: .82rem;
            text-transform: uppercase;
            letter-spacing: .04em;
            color: #6c757d;
            font-weight: 600;
        }

        .status-badge {
            font-size: .72rem;
            padding: .45rem .6rem;
            border-radius: 999px;
        }

        .filtro-interno-label {
            font-size: .78rem;
            font-weight: 600;
            color: #6c757d;
            margin-bottom: .35rem;
            display: block;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .info-pedido-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: .25rem;
        }

        .card-header .col-6:first-child {
            min-width: 0;
        }
    </style>
}

