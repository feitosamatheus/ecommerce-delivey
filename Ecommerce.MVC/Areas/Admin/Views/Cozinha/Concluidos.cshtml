@using Ecommerce.MVC.Enums
@using static Ecommerce.MVC.Areas.Admin.Controllers.CozinhaController
@model PedidosViewModel

@{
    ViewData["Title"] = "Pedidos Concluídos";
    ViewData["Description"] = "Pedidos já finalizados e entregues.";
}

<style>
    .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.5) !important; /* Cor preta com 50% de opacidade */
        transition: background-color 0.3s ease; /* Efeito de transição suave */
    }
</style>

<!-- CARD FILTROS -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-white">
        <strong>Filtros</strong>
    </div>
    <div class="card-body">
        <form method="get" id="filtro-data-form">
            <div class="row g-2">
                <div class="col-md-3">
                    <label for="dataInicio" class="form-label">De:</label>
                    <input type="date" id="dataInicio" name="dataInicio" class="form-control"
                           value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="dataFim" class="form-label">Até:</label>
                    <input type="date" id="dataFim" name="dataFim" class="form-control"
                           value="@Model.DataFim?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="nomeCliente" class="form-label">Nome do Cliente:</label>
                    <input type="text" id="nomeCliente" name="nomeCliente"
                           class="form-control" value="@Model.NomeCliente" />
                </div>

                <div class="col-md-3">
                    <label for="numeroPedido" class="form-label">Número do Pedido:</label>
                    <input type="text" id="numeroPedido" name="numeroPedido"
                           class="form-control" value="@Model.NumeroPedido" />
                </div>

                <div class="col-12 text-end mt-2">
                    <button type="submit" class="btn btn-primary">
                        Filtrar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>


<!-- CARD RESULTADO -->
<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div class="col-6 d-flex justify-content-start">
            <strong>Pedidos Concluídos</strong>
        </div>

        <div class="col-6 d-flex justify-content-end">
            <span class="badge bg-secondary text-end contador-pill">
                @Model.PedidosConcluidos.Count
            </span>

        </div>
    </div>

    <div class="card-body">
        @if (Model.PedidosConcluidos.Any())
        {
            <div class="row g-3">
                @foreach (var pedido in Model.PedidosConcluidos)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="border rounded-3 p-3 h-100 bg-white shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-bold">Pedido @pedido.Codigo</div>
                                    <div class="text-muted small">@pedido.Cliente?.Nome</div>
                                </div>

                                <span class="badge bg-dark">Concluído</span>
                            </div>

                            <div class="small text-muted mb-2">
                                <div><strong>Entrega:</strong> @pedido.MetodoEntrega</div>
                                <div><strong>Retirada:</strong> @pedido.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div><strong>Criado em:</strong> @pedido.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div><strong>Pronto em:</strong> @(pedido.ProntoEmUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                <div><strong>Concluído em:</strong> @(pedido.ConcluidoEmUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                            </div>

                            <button type="button"
                                    class="btn btn-info btn-sm w-100"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalDetalhes"
                                    data-id="@pedido.Id">
                                Ver Detalhes
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-muted">Nenhum pedido concluído no momento.</div>
        }
    </div>
</div>


<!-- MODAL -->
<div class="modal fade" id="modalDetalhes" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" id="conteudoModalPedido">
            <div class="modal-body text-center py-5">
                <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
            </div>
        </div>
    </div>
</div>

<!-- Incluindo o jQuery CDN -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- Incluindo o Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Incluindo o Bootstrap 5 JavaScript CDN -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <script>
        $(document).on('show.bs.modal', '#modalDetalhes', function (event) {

            var button = $(event.relatedTarget);
            var pedidoId = button.data('id');

            $("#conteudoModalPedido").html(`
                <div class="modal-body text-center py-5">
                    <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
                </div>
            `);

            $.ajax({
                url: '/Admin/Cozinha/DetalhesConcluido',
                method: 'GET',
                data: { id: pedidoId },
                success: function (data) {
                    $('#conteudoModalPedido').html(data);
                },
                error: function () {
                    $('#conteudoModalPedido').html(
                        '<div class="modal-body text-danger text-center">Erro ao carregar os detalhes.</div>'
                    );
                }
            });
        });
    </script>
}