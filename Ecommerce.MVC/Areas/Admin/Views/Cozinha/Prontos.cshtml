@using static Ecommerce.MVC.Areas.Admin.Controllers.CozinhaController
@model PedidosViewModel

@{
    ViewData["Title"] = "Pedidos Prontos e Concluídos";
    ViewData["Description"] = "Pedidos prontos para entrega ou retirada, e pedidos já finalizados.";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div class="col-6">
            <h5 class="mb-0">Pedidos Prontos e Concluídos</h5>
            <small class="text-muted">Pedidos em processo ou finalizados</small>
        </div>

        <div class="d-flex align-items-center gap-2 col-6 justify-content-end">
            <span class="badge bg-secondary contador-pill">
                @Model.PedidosProntos.Count + @Model.PedidosConcluidos.Count
            </span>
        </div>
    </div>

    <div class="card-body">
        <!-- Aba de Pedidos Prontos -->
        <ul class="nav nav-tabs" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <a class="nav-link active" id="prontos-tab" data-toggle="tab" href="#prontos" role="tab" aria-controls="prontos" aria-selected="true">Pedidos Prontos</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" id="concluidos-tab" data-toggle="tab" href="#concluidos" role="tab" aria-controls="concluidos" aria-selected="false">Pedidos Concluídos</a>
            </li>
        </ul>
        <div class="tab-content mt-3" id="myTabContent">
            <!-- Pedidos Prontos -->
            <div class="tab-pane fade show active" id="prontos" role="tabpanel" aria-labelledby="prontos-tab">
                @if (Model.PedidosProntos.Any())
                {
                    <div class="row g-3">
                        @foreach (var pedido in Model.PedidosProntos)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="border rounded-3 p-3 h-100 bg-white shadow-sm">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="fw-bold">Pedido @pedido.Codigo</div>
                                            <div class="text-muted small">@pedido.Cliente?.Nome</div>
                                        </div>

                                        <span class="badge bg-success">Pronto</span>
                                    </div>

                                    <div class="small text-muted mb-2">
                                        <div><strong>Entrega:</strong> @pedido.MetodoEntrega</div>
                                        <div><strong>Retirada:</strong> @pedido.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        <div><strong>Criado em:</strong> @pedido.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        <div><strong>Pronto em:</strong> @(pedido.ConcluidoEmUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(pedido.Observacao))
                                    {
                                        <div class="alert alert-light border small mb-3">
                                            <strong>Obs.:</strong> @pedido.Observacao
                                        </div>
                                    }

                                    <div class="mb-3">
                                        <strong>Itens</strong>
                                        <ul class="mb-0 ps-3">
                                            @foreach (var item in pedido.Itens)
                                            {
                                                <li class="mb-1">
                                                    <div>
                                                        @item.Quantidade x @(item.ProdutoNomeSnapshot ?? "Item do pedido")
                                                    </div>

                                                    @if (item.Acompanhamentos != null && item.Acompanhamentos.Any())
                                                    {
                                                        <ul class="small text-muted ps-3 mb-0">
                                                            @foreach (var acomp in item.Acompanhamentos)
                                                            {
                                                                <li>+ @(acomp.NomeSnapshot ?? "Acompanhamento")</li>
                                                            }
                                                        </ul>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <form asp-action="Concluir" method="post" class="w-100">
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <button type="submit" class="btn btn-dark btn-sm w-100">
                                                Concluir pedido
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhum pedido pronto no momento.</div>
                }
            </div>

            <!-- Pedidos Concluídos -->
            <div class="tab-pane fade" id="concluidos" role="tabpanel" aria-labelledby="concluidos-tab">
                @if (Model.PedidosConcluidos.Any())
                {
                    <div class="row g-3">
                        @foreach (var pedido in Model.PedidosConcluidos)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="border rounded-3 p-3 h-100 bg-white shadow-sm">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div>
                                            <div class="fw-bold">Pedido @pedido.Codigo</div>
                                            <div class="text-muted small">@pedido.Cliente?.Nome</div>
                                        </div>

                                        <span class="badge bg-dark">Concluído</span>
                                    </div>

                                    <div class="small text-muted mb-2">
                                        <div><strong>Entrega:</strong> @pedido.MetodoEntrega</div>
                                        <div><strong>Retirada:</strong> @pedido.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        <div><strong>Criado em:</strong> @pedido.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                        <div><strong>Concluído em:</strong> @(pedido.ConcluidoEmUtc?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") ?? "-")</div>
                                    </div>

                                    @if (!string.IsNullOrWhiteSpace(pedido.Observacao))
                                    {
                                        <div class="alert alert-light border small mb-3">
                                            <strong>Obs.:</strong> @pedido.Observacao
                                        </div>
                                    }

                                    <div class="mb-3">
                                        <strong>Itens</strong>
                                        <ul class="mb-0 ps-3">
                                            @foreach (var item in pedido.Itens)
                                            {
                                                <li class="mb-1">
                                                    <div>
                                                        @item.Quantidade x @(item.ProdutoNomeSnapshot ?? "Item do pedido")
                                                    </div>

                                                    @if (item.Acompanhamentos != null && item.Acompanhamentos.Any())
                                                    {
                                                        <ul class="small text-muted ps-3 mb-0">
                                                            @foreach (var acomp in item.Acompanhamentos)
                                                            {
                                                                <li>+ @(acomp.NomeSnapshot ?? "Acompanhamento")</li>
                                                            }
                                                        </ul>
                                                    }
                                                </li>
                                            }
                                        </ul>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <form asp-action="VoltarParaEmPreparo" method="post" class="w-100">
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                                <i class="bi bi-arrow-left"></i> Voltar
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-muted">Nenhum pedido concluído no momento.</div>
                }
            </div>
        </div>
    </div>
</div>