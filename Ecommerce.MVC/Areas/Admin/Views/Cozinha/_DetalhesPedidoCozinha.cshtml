@using Ecommerce.MVC.Enums
@using Ecommerce.MVC.Entities
@model Ecommerce.MVC.Entities.Pedido

@{
    string GetPedidoStatusClass(EPedidoStatus status)
    {
        return status switch
        {
            EPedidoStatus.Rascunho => "bg-secondary-subtle text-secondary border border-secondary-subtle",
            EPedidoStatus.AguardandoPagamento => "bg-warning-subtle text-warning border border-warning-subtle",
            EPedidoStatus.Confirmado => "bg-info-subtle text-info border border-info-subtle",
            EPedidoStatus.EmPreparo => "bg-primary-subtle text-primary border border-primary-subtle",
            EPedidoStatus.Pronto => "bg-success-subtle text-success border border-success-subtle",
            EPedidoStatus.Concluido => "bg-success text-white border border-success",
            EPedidoStatus.Cancelado => "bg-danger-subtle text-danger border border-danger-subtle",
            _ => "bg-light text-dark border"
        };
    }
}

<style>
    .modal-content-clean {
        border: none !important;
        border-radius: 1rem !important;
        overflow: hidden;
    }

    .modal-header-clean {
        background-color: #fff;
        border-bottom: 1px solid #f1f5f9;
        padding: 1.25rem;
    }

    .modal-title-clean {
        font-weight: 700;
        color: #334155;
        font-size: 1.1rem;
    }

    .modal-body-clean {
        background-color: #f8fafc;
        padding: 1.5rem;
    }

    .card-clean {
        border: 1px solid #e2e8f0;
        border-radius: 1rem;
        box-shadow: 0 2px 10px rgba(15, 23, 42, .04);
        background: #fff;
    }

    .card-clean .card-header {
        background: #fff;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-clean .card-body {
        padding: 1.25rem;
    }

    .summary-box {
        border: 1px solid #e2e8f0;
        border-radius: .85rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        padding: 1rem;
        height: 100%;
    }

    .summary-box .label {
        display: block;
        font-size: .75rem;
        text-transform: uppercase;
        letter-spacing: .04em;
        color: #64748b;
        margin-bottom: .35rem;
        font-weight: 600;
    }

    .summary-box .value {
        font-size: 1.05rem;
        font-weight: 700;
        color: #0f172a;
    }

    .section-title {
        font-size: 0.75rem !important;
        letter-spacing: 0.05em;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 0;
        font-weight: 700;
    }

    .table-clean th {
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .03em;
        color: #64748b;
        background: #f8fafc;
        border-bottom: 1px solid #e2e8f0;
        white-space: nowrap;
    }

    .table-clean td {
        vertical-align: middle;
    }

    .acompanhamento-tag {
        display: inline-block;
        margin: 0 .35rem .35rem 0;
        padding: .28rem .55rem;
        border-radius: 999px;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        font-size: .75rem;
        color: #475569;
    }

    .badge-status {
        font-size: .75rem;
        padding: .5rem .7rem;
        border-radius: 999px;
        font-weight: 600;
    }

    .dl-clean dt {
        color: #64748b;
        font-weight: 600;
    }

    .dl-clean dd {
        color: #0f172a;
        font-weight: 500;
    }

    .modal-backdrop.show {
        opacity: 0.2 !important;
    }

    .collapse-toggle {
        border: 0;
        background: transparent;
        padding: 0;
        color: #64748b;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
    }

    .collapse-toggle i {
        transition: transform .2s ease;
    }

    .collapse-toggle[aria-expanded="true"] i {
        transform: rotate(180deg);
    }
</style>

<div class="modal-content modal-content-clean">
    <div class="modal-header modal-header-clean">
        <div>
            <h5 class="modal-title modal-title-clean mb-1">
                <i class="fas fa-shopping-bag me-2 text-primary opacity-75"></i>
                Pedido #@Model.Codigo
            </h5>
            <div class="small text-muted">
                Criado em @Model.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
            </div>
        </div>

        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
    </div>

    <div class="modal-body modal-body-clean">

        <!-- RESUMO DO PEDIDO -->
        <div class="card card-clean mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="col-6">
                    <h6 class="section-title">Resumo do Pedido</h6>
                </div>
                <div class="col-6 d-flex justify-content-end">
                    <button class="collapse-toggle"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapseResumoPedido"
                            aria-expanded="true"
                            aria-controls="collapseResumoPedido">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                </div>
            </div>
            <div class="collapse show" id="collapseResumoPedido">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="summary-box">
                                <span class="label">Status do pedido</span>
                                <div class="value">
                                    <span class="badge badge-status @GetPedidoStatusClass(Model.Status)">
                                        @Model.Status
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="summary-box">
                                <span class="label">Método de entrega</span>
                                <div class="value">@Model.MetodoEntrega</div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="summary-box">
                                <span class="label">Horário de retirada</span>
                                <div class="value">
                                    @Model.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row g-4">
            <!-- CLIENTE / ENTREGA -->
            <div class="col-lg-6">
                <div class="card card-clean h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div class="col-6">
                            <h6 class="section-title">Cliente e Entrega</h6>
                        </div>
                        <div class="col-6 d-flex justify-content-end">
                            <button class="collapse-toggle"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseDadosPedido"
                                    aria-expanded="true"
                                    aria-controls="collapseDadosPedido">
                                <i class="fas fa-chevron-down"></i>
                            </button>
                        </div>
                    </div>
                    <div class="collapse show collapseDadosPedido" id="collapseDadosPedido">
                        <div class="card-body">
                            <dl class="row mb-0 dl-clean">
                                <dt class="col-sm-5">Cliente</dt>
                                <dd class="col-sm-7">@Model.Cliente?.Nome</dd>

                                <dt class="col-sm-5">Data do pedido</dt>
                                <dd class="col-sm-7">@Model.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-sm-5">Horário retirada</dt>
                                <dd class="col-sm-7">@Model.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-sm-5">Método entrega</dt>
                                <dd class="col-sm-7">
                                    <span class="badge bg-light text-dark border">@Model.MetodoEntrega</span>
                                </dd>

                                <dt class="col-sm-5">Forma informada</dt>
                                <dd class="col-sm-7">@Model.Pagamento</dd>

                                <dt class="col-sm-5">Observação</dt>
                                <dd class="col-sm-7 text-muted">
                                    @(string.IsNullOrWhiteSpace(Model.Observacao) ? "-" : Model.Observacao)
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ANDAMENTO -->
            <div class="col-lg-6">
                <div class="card card-clean h-100">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <div class="col-6">
                            <h6 class="section-title">Andamento do Pedido</h6>
                        </div>
                        <div class="col-6 d-flex justify-content-end">
                            <button class="collapse-toggle"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collapseDadosPedido"
                                    aria-expanded="true"
                                    aria-controls="collapseDadosPedido">
                                <i class="fas fa-chevron-down"></i>
                            </button>
                        </div>
                    </div>
                    <div class="collapse show collapseDadosPedido" id="collapseDadosPedido">
                        <div class="card-body">
                            <dl class="row mb-0 dl-clean">
                                <dt class="col-sm-5">Criado em</dt>
                                <dd class="col-sm-7">@Model.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                                <dt class="col-sm-5">Em preparo em</dt>
                                <dd class="col-sm-7">
                                    @(Model.EmpreparoEmUtc.HasValue
                                        ? Model.EmpreparoEmUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        : "-")
                                </dd>

                                <dt class="col-sm-5">Pronto em</dt>
                                <dd class="col-sm-7">
                                    @(Model.ProntoEmUtc.HasValue
                                        ? Model.ProntoEmUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        : "-")
                                </dd>

                                <dt class="col-sm-5">Concluído em</dt>
                                <dd class="col-sm-7">
                                    @(Model.ConcluidoEmUtc.HasValue
                                        ? Model.ConcluidoEmUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        : "-")
                                </dd>

                                <dt class="col-sm-5">Entregue em</dt>
                                <dd class="col-sm-7">
                                    @(Model.EntregueEmUtc.HasValue
                                        ? Model.EntregueEmUtc.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        : "-")
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ITENS -->
        <div class="card card-clean mt-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="col-6">
                    <h6 class="section-title">Itens do Pedido</h6>
                </div>
                <div class="col-6 d-flex justify-content-end">
                    <button class="collapse-toggle"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#collapseItensPedido"
                            aria-expanded="true"
                            aria-controls="collapseItensPedido">
                        <i class="fas fa-chevron-down"></i>
                    </button>
                </div>
            </div>

            <div class="collapse show" id="collapseItensPedido">
                <div class="card-body p-0">
                    @if (Model.Itens == null || !Model.Itens.Any())
                    {
                        <div class="p-4 text-center">
                            <p class="text-muted mb-0 small">Nenhum item encontrado.</p>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-clean align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Produto</th>
                                        <th>Acompanhamentos</th>
                                        <th class="text-center">Qtd</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Itens)
                                    {
                                        <tr>
                                            <td>
                                                <div class="fw-semibold text-dark">@item.ProdutoNomeSnapshot</div>
                                            </td>
                                            <td>
                                                @if (item.Acompanhamentos != null && item.Acompanhamentos.Any())
                                                {
                                                    @foreach (var acomp in item.Acompanhamentos)
                                                    {
                                                        <span class="acompanhamento-tag">
                                                            @acomp.NomeSnapshot
                                                        </span>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="text-muted small">Sem acompanhamentos</span>
                                                }
                                            </td>
                                            <td class="text-center">
                                                <span class="badge bg-light text-secondary border">@item.Quantidade</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer bg-white border-top-0 pb-4">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
            Fechar
        </button>
    </div>
</div>