@model DashboardProdutosVendidosViewModel
@using System.Globalization
@{
    var pt = new CultureInfo("pt-BR");
}

<style>
    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
    }

    .badge-status {
        font-weight: 600;
        padding: 0.35em 0.65em;
        border-radius: 0.375rem;
    }

    .pagination-clean .page-link {
        border: 1px solid #e2e8f0;
        color: #64748b;
        margin: 0 2px;
        border-radius: 0.5rem !important;
        font-weight: 500;
        transition: all 0.2s ease;
        padding: 0.4rem 0.8rem;
    }

    .pagination-clean .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #fff;
        color: #fff;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .mobile-order-item {
        border: 1px solid #edf2f7;
        border-radius: 0.6rem;
        padding: 0.8rem;
        margin: 0.5rem 0;
        background: #ffffff;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.03);
    }

    .mobile-order-item:last-child {
        margin-bottom: 0.25rem;
    }

    /* hover removed for mobile cards */

    /* Mobile improvements */
    .mobile-order-item .product-name {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        display: block;
        font-size: 0.98rem;
    }

    .mobile-order-item .meta-line {
        font-size: 0.82rem;
        color: #64748b;
    }

    /* compact qty badge near title */
    .mobile-order-item .badge-qty {
        display: inline-block;
        min-width: 27px;
        height: 27px;
        line-height: 26px;
        text-align: center;
        font-weight: 700;
        background: #0d6efd;
        color: #fff;
        border-radius: 999px;
        font-size: 0.82rem;
    }

    /* icon-only action button */
    .mobile-order-item .actions-btn {
        width: 36px;
        height: 36px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .mobile-order-item .price-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.5rem;
    }

    .mobile-order-item .price-row .small-label { font-size: 0.78rem; color: #94a3b8; }
    .mobile-order-item .price-row .value { font-weight: 700; }

    @@media (max-width: 575.98px) {
        .card-header .card-title { font-size: 0.95rem; }
        .mobile-order-item { padding: 0.6rem; }
        .mobile-order-item .product-name { font-size: 0.95rem; }
    }
</style>

<div class="app-content">
    <div class="container-fluid">
        <!-- Cards de Resumo -->
        <div class="row mb-4 mt-3">
            <div class="col-lg-3 mb-2">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <p class="text-muted mb-2">Total de Unidades</p>
                                <h3 class="mb-0">@Model.TotalProdutosVendidos</h3>
                            </div>
                            <div class="text-primary" style="font-size: 2.5rem;">
                                <i class="bi bi-shop"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 mb-2">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <p class="text-muted mb-2">Total de Pedidos</p>
                                <h3 class="mb-0">@Model.TotalPedidos</h3>
                            </div>
                            <div class="text-success" style="font-size: 2.5rem;">
                                <i class="bi bi-receipt"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 mb-2">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex align-items-center">
                            <div class="flex-grow-1">
                                <p class="text-muted mb-2">Receita Total</p>
                                <h3 class="mb-0">R$ @Model.TotalReceita.ToString("N2")</h3>
                            </div>
                            <div class="text-warning" style="font-size: 2.5rem;">
                                <i class="bi bi-cash-coin"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabela de Produtos Vendidos -->
        <div class="card card-table-clean">
            <div class="card-header p-0">
                <div class="row g-0 align-items-center h-100">
                    <div class="col-6 d-flex align-items-center ps-3 py-3">
                        <h3 class="card-title fs-6 fw-bold mb-0">
                            <i class="bi bi-list me-2 text-primary"></i> Detalhamento
                        </h3>
                    </div>
                    <div class="col-6 d-flex justify-content-end pe-3 py-3">
                        <a href="@Url.Action("ProdutosVendidos", "Dashboard")" class="btn btn-sm btn-info">
                            <i class="bi bi-arrow-clockwise"></i> Atualizar
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-0">
                <!-- Layout Desktop: Tabela -->
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover table-clean align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th class="text-center">Quantidade</th>
                                <th class="text-center">Preço Unit.</th>
                                <th class="text-center">Total Vendido</th>
                                <th class="text-center">Nº Pedidos</th>
                                <th class="text-center">Última Venda</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Produtos.Any())
                            {
                                @foreach (var produto in Model.Produtos)
                                {
                                    <tr>
                                        <td>
                                            <strong>@produto.NomeProduto</strong>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-info">@produto.QuantidadeTotal</span>
                                        </td>
                                        <td class="text-center">
                                            R$ @produto.PrecoUnitario.ToString("N2")
                                        </td>
                                        <td class="text-center">
                                            <strong class="text-success">R$ @produto.TotalVendido.ToString("N2")</strong>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-secondary">@produto.NumeroPedidos</span>
                                        </td>
                                        <td class="text-center">
                                            <small>@produto.UltimaVenda.ToString("dd/MM/yyyy HH:mm")</small>
                                        </td>
                                        <td class="text-center">
                                            <a href="@Url.Action("DetalhesProduto", "Dashboard", new { nomeProduto = produto.NomeProduto })"
                                               class="btn btn-sm btn-outline-primary" title="Ver detalhes dos pedidos">
                                                <i class="bi bi-eye"></i> Ver Detalhes
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox me-2"></i>
                                        Nenhum produto vendido ainda
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Layout Mobile: Cards -->
                <div class="d-md-none">
                    @if (Model.Produtos.Any())
                    {
                        @foreach (var produto in Model.Produtos)
                        {
                            <div class="mobile-order-item p-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="flex-grow-1 me-2">
                                        <div class="d-flex align-items-top justify-content-between">
                                            <div class="me-2">
                                                <div class="fw-bold text-dark mb-1 product-name">@produto.NomeProduto</div>
                                                <div class="meta-line"><i class="bi bi-cart-check me-1"></i> @produto.NumeroPedidos pedido(s)</div>
                                            </div>
                                            <div class="text-end">
                                                <span class="badge-qty">@produto.QuantidadeTotal</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="d-flex flex-column align-items-end ms-2" style="position: relative;top: -6px;">
                                        <a href="@Url.Action("DetalhesProduto", "Dashboard", new { nomeProduto = produto.NomeProduto })"
                                           class="btn btn-outline-primary actions-btn mb-0" title="Ver detalhes dos pedidos">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="row g-2 mt-3 pt-2 border-top">
                                    <div class="col-12">
                                        <div class="price-row">
                                            <div>
                                                <div class="small-label">Preço Unit.</div>
                                                <div class="value">R$ @produto.PrecoUnitario.ToString("N2")</div>
                                            </div>
                                            <div class="text-end">
                                                <div class="small-label">Receita</div>
                                                <div class="value text-success">R$ @produto.TotalVendido.ToString("N2")</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row g-2 mt-2">
                                    <div class="col-12">
                                        <small class="text-muted d-block">Última venda</small>
                                        <small class="text-dark">@produto.UltimaVenda.ToString("dd/MM/yyyy HH:mm")</small>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="bi bi-inbox bi-3x text-light mb-3 d-block"></i>
                            <p class="text-muted mb-0">Nenhum produto vendido ainda.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Você pode adicionar scripts aqui se necessário
    </script>
}
