@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    ViewData["Title"] ??= "Admin";
    Layout = null;
    var nomeUsuario = User?.Identity?.IsAuthenticated == true ? User.Identity.Name : "Usuário";
}

<!DOCTYPE html>
<html lang="pt-BR" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin</title>

    <link rel="stylesheet" href="~/adminlte4/css/adminlte.min.css" />
    <link rel="stylesheet" href="~/adminlte4/assets/css/overlayscrollbars.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css">

    @RenderSection("Styles", required: false)

    <style>
        .status-online {
            width: 10px;
            height: 10px;
            background-color: #28a745;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 0 2px rgba(40, 167, 69, 0.2);
        }
        /* Estilo para o Título da Página */
        .page-title {
            font-weight: 700;
            color: #1e293b; /* Slate 800 */
            letter-spacing: -0.02em;
            font-size: 1.75rem;
        }

        .app-content-header {
            padding: 2rem 0 1.5rem 0; /* Mais espaço em cima e embaixo */
            background: transparent;
        }

        /* Breadcrumb Minimalista */
        .breadcrumb-clean {
            font-size: 0.8rem;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: #94a3b8;
            margin-bottom: 0.5rem;
        }

        .breadcrumb-clean a {
            color: #64748b;
            text-decoration: none;
            transition: color 0.2s;
        }

        .breadcrumb-clean a:hover {
            color: #3b82f6;
        }

    </style>
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">
    @await Html.PartialAsync("Partials/_LoadingSpinner")

    <div class="app-wrapper">

        <nav class="app-header navbar navbar-expand bg-body">
            <div class="container-fluid">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                            <i class="bi bi-list"></i>
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <span class="nav-link">
                            <span class="status-online"></span>
                            Olá, @nomeUsuario
                        </span>
                    </li>
                </ul>
            </div>
        </nav>

        <aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
            <div class="sidebar-brand">
                <a href="@Url.Action("Index", "Home", new { area = "Admin" })" class="brand-link text-decoration-none">
                    <span class="brand-text fw-light">Admin</span>
                </a>
            </div>

            <div class="sidebar-wrapper">
                <nav class="mt-2">
                    <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="menu">

                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Home", new { area = "Admin" })"
                                   class="nav-link @(controller == "Home" ? "active" : "")">
                                <i class="nav-icon bi bi-house-door"></i>
                                <p>Dashboard</p>
                            </a>
                        </li>

                        <li class="nav-item">
                            <a href="@Url.Action("Index", "Pedidos", new { area = "Admin" })"
                                   class="nav-link @(controller == "Pedidos" ? "active" : "")">
                                <i class="nav-icon bi bi-cart-check"></i>
                                <p>Pedidos</p>
                            </a>
                        </li>

                        <li class="nav-item @(controller == "Produtos" || controller == "Categorias" ? "menu-open" : "")">
                            <a href="#" class="nav-link @(controller == "Produtos" || controller == "Categorias" ? "active" : "")">
                                <i class="nav-icon bi bi-box-seam"></i>
                                <p>
                                    Produtos
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview menu-open">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Produtos", new { area = "Admin" })"
                                           class="nav-link @(controller == "Produtos" ? "active" : "")">
                                        <i class="nav-icon bi bi-list-ul"></i>
                                        <p>Todos os Produtos</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Categorias", new { area = "Admin" })"
                                           class="nav-link @(controller == "Categorias" ? "active" : "")">
                                        <i class="nav-icon bi bi-tags"></i>
                                        <p>Categorias</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        <li class="nav-item @(controller == "Acompanhamentos" || controller == "AcompanhamentoCategorias" ? "menu-open" : "")">
                            <a href="#" class="nav-link @(controller == "Acompanhamentos" || controller == "AcompanhamentoCategorias" ? "active" : "")">
                                <i class="nav-icon bi bi-ui-checks-grid"></i>
                                <p>
                                    Acompanhamentos
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Acompanhamentos", new { area = "Admin" })"
                                           class="nav-link @(controller == "Acompanhamentos" ? "active" : "")">
                                        <i class="nav-icon bi bi-list-check"></i>
                                        <p>Itens</p>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "AcompanhamentoCategorias", new { area = "Admin" })"
                                           class="nav-link @(controller == "AcompanhamentoCategorias" ? "active" : "")">
                                        <i class="nav-icon bi bi-tags"></i>
                                        <p>Categorias</p>
                                    </a>
                                </li>
                            </ul>
                        </li>

                        @* SEÇÃO DE USUÁRIOS *@
                        <li class="nav-item @(controller == "Usuarios" ? "menu-open" : "")">
                            <a href="#" class="nav-link @(controller == "Usuarios" ? "active" : "")">
                                <i class="nav-icon bi bi-people"></i>
                                <p>
                                    Pessoas
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Usuarios", new { area = "Admin" })"
                                           class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" && controller == "Usuarios" ? "active" : "")">
                                        <i class="nav-icon bi bi-person-lines-fill"></i>
                                        <p>Listar Usuários</p>
                                    </a>
                                </li>
                               
                            </ul>
                        </li>
                        <li class="nav-item @(controller == "Cozinha" ? "menu-open" : "")">
                            <a href="#" class="nav-link @(controller == "Cozinha" ? "active" : "")">
                                <i class="nav-icon bi bi-fire"></i>
                                <p>
                                    Cozinha
                                    <i class="nav-arrow bi bi-chevron-right"></i>
                                </p>
                            </a>
                            <ul class="nav nav-treeview">
                                <li class="nav-item">
                                    <a href="@Url.Action("Index", "Cozinha", new { area = "Admin" })"
                                           class="nav-link @(controller == "Cozinha" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                                        <i class="nav-icon bi bi-receipt-cutoff"></i>
                                        <p>Painel da Cozinha</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="@Url.Action("EmPreparo", "Cozinha", new { area = "Admin" })"
                                           class="nav-link @(controller == "Cozinha" && ViewContext.RouteData.Values["action"]?.ToString() == "EmPreparo" ? "active" : "")">
                                        <i class="nav-icon bi bi-clock-history"></i>
                                        <p>Em Preparo</p>
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a href="@Url.Action("Prontos", "Cozinha", new { area = "Admin" })"
                                           class="nav-link @(controller == "Cozinha" && ViewContext.RouteData.Values["action"]?.ToString() == "Prontos" ? "active" : "")">
                                        <i class="nav-icon bi bi-check2-circle"></i>
                                        <p>Pedidos Prontos</p>
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </nav>
            </div>
        </aside>
        @* <main class="app-main">
            <div class="app-content-header"> 
                <div class="container-fluid"> 
                    <h3 class="mb-0">@ViewData["Title"]</h3> 
                </div> 
            </div>
            <div class="app-content">
                <div class="container-fluid px-0">
                    @RenderBody()
                </div>
            </div>
        </main> *@
        <main class="app-main" >
            <div class="app-content-header" style="padding: 1rem .5rem .0rem .5rem !important"> 
                <div class="container-fluid px-2"> @* Adicionado padding lateral para alinhar com o conteúdo *@
                    
                    @* Caminho de navegação opcional *@
                    <nav aria-label="breadcrumb" class="breadcrumb-clean">
                        <ol class="breadcrumb mb-1">
                            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Admin</a></li>
                            <li class="breadcrumb-item active" aria-current="page">@ViewData["Title"]</li>
                        </ol>
                    </nav>

                    <div class="d-flex align-items-center justify-content-between">
                        <div>
                            <h1 class="page-title mb-0">@ViewData["Title"]</h1>
                            <p class="text-muted mb-0" style="font-size: 0.9rem;">
                                @ViewData["Description"]
                            </p>
                        </div>
                        
                        @* Espaço para um botão de ação rápida, caso precise no futuro *@
                        <div class="page-actions">
                            @* Exemplo: <a href="/Admin/Pedidos/Create" class="btn btn-primary btn-action shadow-sm">Novo Pedido</a> *@
                        </div>
                    </div>
                    <hr class="" style="border-top: 1px solid #b8bbbf">
                </div> 
            </div>
            <div class="app-content">
                <div class="container-fluid px-2"> @* Alinhado com o header *@
                    @RenderBody()
                </div>
            </div>
        </main>

        <footer class="app-footer">
            <div class="float-end d-none d-sm-inline">Administração</div>
            <strong>&copy; @DateTime.Now.Year</strong>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/adminlte4/js/bootstrap.bundle.min.js"></script>
    <script src="~/adminlte4/js/adminlte.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>