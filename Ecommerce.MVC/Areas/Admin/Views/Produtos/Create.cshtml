@model Ecommerce.MVC.Models.Admin.ProdutoCreateViewModel

@{
    ViewData["Title"] = "Novo Produto";
    ViewData["Description"] = "Cadastre um novo item no seu cardápio.";
}

<style>
    .card-form-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
        margin-bottom: 1.5rem;
    }

    .card-form-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1.25rem;
    }

    .card-form-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .image-preview-container {
        width: 100%;
        height: 200px;
        border: 2px dashed #e2e8f0;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: #f8fafc;
        margin-bottom: 1rem;
    }

    #imgPreview {
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
    }

    .acompanhamento-card-item {
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: 1rem;
        background: #f8fafc;
    }

    .badge-rule {
        font-size: 0.75rem;
        padding: 0.45rem 0.65rem;
        border-radius: 999px;
        background: #eef2ff;
        color: #334155;
        display: inline-block;
        margin-right: 0.35rem;
        margin-top: 0.25rem;
    }

    .acompanhamento-opcao {
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        background: #fff;
        padding: 0.75rem 1rem;
    }

    .image-preview-container {
        width: 100%;
        height: 300px;
        border: 2px dashed #cbd5e0;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background-color: #f8fafc;
        transition: all 0.3s ease;
    }

    .image-preview-container:hover {
        border-color: #3182ce;
        background-color: #edf2f7;
    }

    #imgPreview {
        max-width: 100%;
        max-height: 100%;
        object-fit: cover;
        display: block;
    }
</style>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="container-fluid px-0">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a asp-action="Index" class="btn btn-filter-outline">
                <i class="fas fa-arrow-left me-1"></i> Voltar
            </a>

            <button type="submit" class="btn btn-primary btn-filter-action shadow-sm">
                <i class="fas fa-save me-1"></i> Salvar Produto
            </button>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="row">
            <div class="col-xl-8">
                <div class="card card-form-clean">
                    <div class="card-header">
                        <h3 class="card-title fs-6 mb-0 text-primary">Informações Básicas</h3>
                    </div>

                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="Nome" class="form-label">Nome do Produto</label>
                                <input asp-for="Nome" class="form-control" placeholder="Ex: Pizza Margherita Individual" />
                                <span asp-validation-for="Nome" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Descricao" class="form-label">Descrição Detalhada</label>
                                <textarea asp-for="Descricao" class="form-control" rows="4" placeholder="Descreva os ingredientes e detalhes..."></textarea>
                                <span asp-validation-for="Descricao" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoriaId" class="form-label">Categoria</label>
                                <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
                                    <option value="">Selecione uma categoria</option>
                                </select>
                                <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="Preco" class="form-label">Preço (R$)</label>
                                <input asp-for="Preco" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Preco" class="text-danger small"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="TempoPreparoMinutos" class="form-label">Preparo (Min)</label>
                                <input asp-for="TempoPreparoMinutos" class="form-control" type="number" />
                                <span asp-validation-for="TempoPreparoMinutos" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-form-clean">
                    <div class="card-header row d-flex justify-content-between align-items-center">
                        <div class="col-6">
                            <h3 class="card-title fs-6 mb-0 text-primary">Categorias de Acompanhamento</h3>
                        </div>
                        <div class="col-6 d-flex justify-content-end">
                            <button type="button" id="btnAdicionarCategoriaAcompanhamento" class="btn btn-sm btn-primary">
                                <i class="fas fa-plus me-1"></i> Adicionar
                            </button>
                        </div>
                    </div>

                    <div class="card-body">
                        <div id="categorias-acompanhamento-container">
                            @if (Model.CategoriasAcompanhamentoSelecionadas != null && Model.CategoriasAcompanhamentoSelecionadas.Any())
                            {
                                for (int i = 0; i < Model.CategoriasAcompanhamentoSelecionadas.Count; i++)
                                {
                                    <div class="acompanhamento-card-item mb-3 categoria-acompanhamento-item">
                                        <div class="row g-3">
                                            <div class="col-md-6">
                                                <label class="form-label">Categoria de Acompanhamento</label>
                                                <select name="CategoriasAcompanhamentoSelecionadas[@i].AcompanhamentoCategoriaId"
                                                        class="form-select select-categoria-acompanhamento">
                                                    <option value="">Selecione</option>
                                                    @foreach (var item in Model.CategoriasAcompanhamentoDisponiveis)
                                                    {
                                                        var selected = Model.CategoriasAcompanhamentoSelecionadas[i].AcompanhamentoCategoriaId.HasValue
                                                            && Model.CategoriasAcompanhamentoSelecionadas[i].AcompanhamentoCategoriaId.Value.ToString() == item.Value;

                                                        if (selected)
                                                        {
                                                            <option value="@item.Value" selected>@item.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@item.Value">@item.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-2">
                                                <label class="form-label">Obrigatório</label>
                                                <div class="form-check form-switch mt-2">
                                                    <input class="form-check-input input-obrigatorio-checkbox"
                                                           type="checkbox"
                                                           name="CategoriasAcompanhamentoSelecionadas[@i].Obrigatorio"
                                                           value="true"
                                                           @(Model.CategoriasAcompanhamentoSelecionadas[i].Obrigatorio ? "checked" : null) />

                                                    <input type="hidden"
                                                           name="CategoriasAcompanhamentoSelecionadas[@i].Obrigatorio"
                                                           value="false" />
                                                </div>
                                            </div>

                                            <div class="col-md-2">
                                                <label class="form-label">Mínimo</label>
                                                <input type="number"
                                                       min="0"
                                                       class="form-control input-min"
                                                       name="CategoriasAcompanhamentoSelecionadas[@i].MinSelecionados"
                                                       value="@Model.CategoriasAcompanhamentoSelecionadas[i].MinSelecionados" />
                                            </div>

                                            <div class="col-md-2">
                                                <label class="form-label">Máximo</label>
                                                <input type="number"
                                                       min="1"
                                                       class="form-control input-max"
                                                       name="CategoriasAcompanhamentoSelecionadas[@i].MaxSelecionados"
                                                       value="@Model.CategoriasAcompanhamentoSelecionadas[i].MaxSelecionados" />
                                            </div>

                                            <div class="col-md-2">
                                                <label class="form-label">Ordem</label>
                                                <input type="number"
                                                       min="0"
                                                       class="form-control input-ordem"
                                                       name="CategoriasAcompanhamentoSelecionadas[@i].Ordem"
                                                       value="@Model.CategoriasAcompanhamentoSelecionadas[i].Ordem" />
                                            </div>

                                            <div class="col-md-10">
                                                <input type="hidden"
                                                       name="CategoriasAcompanhamentoSelecionadas[@i].NomeCategoria"
                                                       value="@Model.CategoriasAcompanhamentoSelecionadas[i].NomeCategoria"
                                                       class="input-nome-categoria" />

                                                <div class="categoria-acompanhamento-regras mb-3">
                                                    <span class="badge-rule">
                                                        Obrigatório: @(Model.CategoriasAcompanhamentoSelecionadas[i].Obrigatorio ? "Sim" : "Não")
                                                    </span>
                                                    <span class="badge-rule">
                                                        Mínimo: @Model.CategoriasAcompanhamentoSelecionadas[i].MinSelecionados
                                                    </span>
                                                    <span class="badge-rule">
                                                        Máximo: @Model.CategoriasAcompanhamentoSelecionadas[i].MaxSelecionados
                                                    </span>
                                                    <span class="badge-rule">
                                                        Ordem: @Model.CategoriasAcompanhamentoSelecionadas[i].Ordem
                                                    </span>
                                                </div>
                                            </div>

                                            <div class="col-md-2 d-flex align-items-end justify-content-end">
                                                <button type="button" class="btn btn-outline-danger btnRemoverCategoriaAcompanhamento">
                                                    <i class="fas fa-trash me-1"></i> Remover
                                                </button>
                                            </div>

                                            <div class="col-12">
                                                <div class="acompanhamentos-vinculados">
                                                    @if (Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos != null &&
                                                         Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos.Any())
                                                    {
                                                        <div class="row g-2">
                                                            @for (int j = 0; j < Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos.Count; j++)
                                                            {
                                                                <div class="col-md-6">
                                                                    <div class="form-check acompanhamento-opcao">
                                                                        <input type="hidden"
                                                                               name="CategoriasAcompanhamentoSelecionadas[@i].Acompanhamentos[@j].AcompanhamentoId"
                                                                               value="@Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos[j].AcompanhamentoId" />

                                                                        <input type="hidden"
                                                                               name="CategoriasAcompanhamentoSelecionadas[@i].Acompanhamentos[@j].Nome"
                                                                               value="@Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos[j].Nome" />

                                                                        <input class="form-check-input"
                                                                               type="checkbox"
                                                                               id="cat_@(i)_acom_@(j)"
                                                                               name="CategoriasAcompanhamentoSelecionadas[@i].Acompanhamentos[@j].Selecionado"
                                                                               value="true"
                                                                               @(Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos[j].Selecionado ? "checked" : null) />

                                                                        <input type="hidden"
                                                                               name="CategoriasAcompanhamentoSelecionadas[@i].Acompanhamentos[@j].Selecionado"
                                                                               value="false" />

                                                                        <label class="form-check-label ms-1" for="cat_@(i)_acom_@(j)">
                                                                            @Model.CategoriasAcompanhamentoSelecionadas[i].Acompanhamentos[j].Nome
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                        </div>

                        <div id="mensagemSemCategorias" class="text-muted small">
                            Nenhuma categoria de acompanhamento adicionada.
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="card card-form-clean">
                    <div class="card-header">
                        <h3 class="card-title fs-6 mb-0 text-primary">Mídia e Status</h3>
                    </div>

                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label d-block text-center">Imagem do Produto</label>

                            <div class="image-preview-container" id="containerPreview">
                                <img id="imgPreview" src="/img/placeholder-produto.png" alt="Preview" />
                            </div>

                            <input type="file" name="imagemForm" id="imagemForm" class="form-control form-control-sm" accept="image/*" />
                            <small class="text-muted mt-1 d-block text-center">JPG, PNG ou WebP (Máx. 2MB)</small>
                        </div>

                        <hr class="text-light">

                        <div class="form-check form-switch mt-3">
                            <input class="form-check-input" type="checkbox" asp-for="Ativo" checked>
                            <label class="form-check-label fw-bold" asp-for="Ativo">Produto Ativo</label>
                            <small class="d-block text-muted">Se desativado, o produto não aparecerá no cardápio digital.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script id="template-categoria-acompanhamento" type="text/template">
    <div class="acompanhamento-card-item mb-3 categoria-acompanhamento-item">
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Categoria de Acompanhamento</label>
                <select name="CategoriasAcompanhamentoSelecionadas[__index__].AcompanhamentoCategoriaId"
                        class="form-select select-categoria-acompanhamento">
                    <option value="">Selecione</option>
                    @foreach (var item in Model.CategoriasAcompanhamentoDisponiveis)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label">Obrigatório</label>
                <div class="form-check form-switch mt-2">
                    <input type="checkbox"
                           class="form-check-input input-obrigatorio-checkbox"
                           name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio"
                           value="true" />

                    <input type="hidden"
                           name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio"
                           value="false" />
                </div>
            </div>

            <div class="col-md-2">
                <label class="form-label">Mínimo</label>
                <input type="number"
                       min="0"
                       class="form-control input-min"
                       name="CategoriasAcompanhamentoSelecionadas[__index__].MinSelecionados"
                       value="0" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Máximo</label>
                <input type="number"
                       min="1"
                       class="form-control input-max"
                       name="CategoriasAcompanhamentoSelecionadas[__index__].MaxSelecionados"
                       value="1" />
            </div>

            <div class="col-md-2">
                <label class="form-label">Ordem</label>
                <input type="number"
                       min="0"
                       class="form-control input-ordem"
                       name="CategoriasAcompanhamentoSelecionadas[__index__].Ordem"
                       value="0" />
            </div>

            <div class="col-md-10">
                <input type="hidden"
                       name="CategoriasAcompanhamentoSelecionadas[__index__].NomeCategoria"
                       value=""
                       class="input-nome-categoria" />

                <div class="categoria-acompanhamento-regras mb-3">
                    <span class="badge-rule">Obrigatório: Não</span>
                    <span class="badge-rule">Mínimo: 0</span>
                    <span class="badge-rule">Máximo: 1</span>
                    <span class="badge-rule">Ordem: 0</span>
                </div>
            </div>

            <div class="col-md-2 d-flex align-items-end justify-content-end">
                <button type="button" class="btn btn-outline-danger btnRemoverCategoriaAcompanhamento">
                    <i class="fas fa-trash me-1"></i> Remover
                </button>
            </div>

            <div class="col-12">
                <div class="acompanhamentos-vinculados"></div>
            </div>
        </div>
    </div>
</script>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const container = document.getElementById("categorias-acompanhamento-container");
            const btnAdicionar = document.getElementById("btnAdicionarCategoriaAcompanhamento");
            const template = document.getElementById("template-categoria-acompanhamento").innerHTML;
            const mensagemSemCategorias = document.getElementById("mensagemSemCategorias");

            function atualizarMensagemVazia() {
                const total = container.querySelectorAll(".categoria-acompanhamento-item").length;
                mensagemSemCategorias.style.display = total > 0 ? "none" : "block";
            }

            function obterProximoIndice() {
                return container.querySelectorAll(".categoria-acompanhamento-item").length;
            }

            function reindexar() {
                const itens = container.querySelectorAll(".categoria-acompanhamento-item");

                itens.forEach((item, index) => {
                    item.querySelectorAll("select, input").forEach(campo => {
                        if (campo.name) {
                            campo.name = campo.name
                                .replace(/CategoriasAcompanhamentoSelecionadas\[\d+\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`)
                                .replace(/CategoriasAcompanhamentoSelecionadas\[__index__\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`);
                        }
                    });

                    const acompanhamentos = item.querySelectorAll(".acompanhamento-opcao");
                    acompanhamentos.forEach((acomItem, acomIndex) => {
                        acomItem.querySelectorAll("input").forEach(campo => {
                            if (campo.name) {
                                campo.name = campo.name.replace(
                                    /CategoriasAcompanhamentoSelecionadas\[\d+\]\.Acompanhamentos\[\d+\]/g,
                                    `CategoriasAcompanhamentoSelecionadas[${index}].Acompanhamentos[${acomIndex}]`);
                            }

                            if (campo.id && campo.id.includes("cat_")) {
                                campo.id = `cat_${index}_acom_${acomIndex}`;
                            }
                        });

                        const label = acomItem.querySelector("label[for]");
                        if (label) {
                            label.setAttribute("for", `cat_${index}_acom_${acomIndex}`);
                        }
                    });

                    atualizarResumoRegras(item);
                });
            }

            function atualizarResumoRegras(item) {
                const obrigatorio = item.querySelector(".input-obrigatorio-checkbox")?.checked ?? false;
                const min = item.querySelector(".input-min")?.value ?? "0";
                const max = item.querySelector(".input-max")?.value ?? "1";
                const ordem = item.querySelector(".input-ordem")?.value ?? "0";
                const box = item.querySelector(".categoria-acompanhamento-regras");

                box.innerHTML = `
                    <span class="badge-rule">Obrigatório: ${obrigatorio ? "Sim" : "Não"}</span>
                    <span class="badge-rule">Mínimo: ${min}</span>
                    <span class="badge-rule">Máximo: ${max}</span>
                    <span class="badge-rule">Ordem: ${ordem}</span>
                `;
            }

            function montarHtmlAcompanhamentos(indexCategoria, acompanhamentos) {
                if (!acompanhamentos || acompanhamentos.length === 0) {
                    return `<div class="alert alert-light border mb-0">Nenhum acompanhamento ativo encontrado para esta categoria.</div>`;
                }

                let html = `<div class="row g-2">`;

                acompanhamentos.forEach((item, idx) => {
                    html += `
                        <div class="col-md-6">
                            <div class="form-check acompanhamento-opcao">
                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].AcompanhamentoId"
                                       value="${item.id}" />

                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Nome"
                                       value="${item.nome}" />

                                <input type="checkbox"
                                       class="form-check-input"
                                       id="cat_${indexCategoria}_acom_${idx}"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                       value="true" />

                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                       value="false" />

                                <label class="form-check-label ms-1" for="cat_${indexCategoria}_acom_${idx}">
                                    ${item.nome}
                                </label>
                            </div>
                        </div>
                    `;
                });

                html += `</div>`;
                return html;
            }

            async function carregarAcompanhamentos(item) {
                const select = item.querySelector(".select-categoria-acompanhamento");
                const categoriaId = select.value;
                const index = Array.from(container.querySelectorAll(".categoria-acompanhamento-item")).indexOf(item);

                const inputNome = item.querySelector(".input-nome-categoria");
                const acompanhamentosBox = item.querySelector(".acompanhamentos-vinculados");

                if (!categoriaId) {
                    inputNome.value = "";
                    acompanhamentosBox.innerHTML = "";
                    atualizarResumoRegras(item);
                    return;
                }

                const response = await fetch(`@Url.Action("ObterAcompanhamentosPorCategoria", "Produtos", new { area = "Admin" })?categoriaId=${categoriaId}`);

                if (!response.ok) {
                    acompanhamentosBox.innerHTML = `<div class="alert alert-danger mb-0">Não foi possível carregar os acompanhamentos.</div>`;
                    return;
                }

                const data = await response.json();

                inputNome.value = data.categoria.nome;
                acompanhamentosBox.innerHTML = montarHtmlAcompanhamentos(index, data.acompanhamentos);
                reindexar();
            }

            btnAdicionar.addEventListener("click", function () {
                const index = obterProximoIndice();
                const html = template.replaceAll("__index__", index);
                container.insertAdjacentHTML("beforeend", html);
                atualizarMensagemVazia();
            });

            container.addEventListener("click", function (e) {
                const btnRemover = e.target.closest(".btnRemoverCategoriaAcompanhamento");
                if (btnRemover) {
                    btnRemover.closest(".categoria-acompanhamento-item").remove();
                    reindexar();
                    atualizarMensagemVazia();
                }
            });

            container.addEventListener("change", async function (e) {
                const item = e.target.closest(".categoria-acompanhamento-item");
                if (!item) return;

                if (e.target.closest(".select-categoria-acompanhamento")) {
                    await carregarAcompanhamentos(item);
                }

                if (
                    e.target.classList.contains("input-min") ||
                    e.target.classList.contains("input-max") ||
                    e.target.classList.contains("input-ordem") ||
                    e.target.classList.contains("input-obrigatorio-checkbox")
                ) {
                    atualizarResumoRegras(item);
                }
            });

            $("#imagemForm").change(function () {
                const file = this.files[0];
                if (file) {
                    let reader = new FileReader();
                    reader.onload = function (event) {
                        $("#imgPreview").attr("src", event.target.result);
                    };
                    reader.readAsDataURL(file);
                }
            });

            $('form').submit(function () {
                if ($(this).valid()) {
                    if (typeof window.addLoading === "function") {
                        window.addLoading("Salvando produto...");
                    }
                }
            });

            document.querySelectorAll(".categoria-acompanhamento-item").forEach(item => {
                atualizarResumoRegras(item);
            });

            atualizarMensagemVazia();
        });
    </script>
}