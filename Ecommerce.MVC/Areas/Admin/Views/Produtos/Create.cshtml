@model Ecommerce.MVC.Models.Admin.ProdutoCreateViewModel

@{
    ViewData["Title"] = "Novo Produto";
    ViewData["Description"] = "Atualize os dados e as configurações de exibição deste item.";
    ViewData["page"] = "Produto";

}

<style>
    :root {
        --primary-soft: #eef2ff;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
    }

    .card-form-clean {
        border: none;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border-radius: 1rem;
        background-color: #ffffff;
        margin-bottom: 1.5rem;
        transition: transform 0.2s;
    }

    .card-header-custom {
        padding: 1.25rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.05em;
    }

    /* Image Upload Styling */
    .image-upload-zone {
        cursor: pointer;
        width: 100%;
        height: 250px;
        border: 2px dashed var(--border-color);
        border-radius: 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

        .image-upload-zone:hover {
            border-color: #3b82f6;
            background-color: #eff6ff;
        }

    #imgPreview {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: none;
    }

    .upload-placeholder {
        text-align: center;
        color: var(--text-muted);
    }

    /* Acompanhamentos UI */
    .acompanhamento-card-item {
        border: 1px solid var(--border-color);
        border-radius: 0.75rem;
        padding: 1.25rem;
        background: #ffffff;
        margin-bottom: 1rem;
        border-left: 4px solid #cbd5e1;
    }

        .acompanhamento-card-item.has-content {
            border-left-color: #3b82f6;
        }

    .badge-rule {
        font-size: 0.7rem;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        background: var(--primary-soft);
        color: #1e293b;
        font-weight: 600;
    }

    .badge-mandatory {
        background: #fee2e2;
        color: #991b1b;
    }

    .input-group-text-clean {
        background: #f8fafc;
        border-right: none;
        color: var(--text-muted);
        font-weight: 600;
    }
    .acompanhamentos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 0.75rem;
    }

    .acompanhamento-card-option {
        border: 1px solid var(--border-color);
        border-radius: 0.9rem;
        background: #fff;
        padding: 0.9rem 1rem;
        transition: all 0.2s ease;
        position: relative;
        min-height: 96px;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .acompanhamento-card-option:hover {
        border-color: #93c5fd;
        background: #f8fbff;
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.08);
    }

    .acompanhamento-card-option.is-checked {
        border-color: #3b82f6;
        background: #eff6ff;
        box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.15);
    }

    .acompanhamento-check {
        margin-top: 0.2rem;
        flex-shrink: 0;
    }

    .acompanhamento-check .form-check-input {
        width: 1.1rem;
        height: 1.1rem;
        cursor: pointer;
    }

    .acompanhamento-card-content {
        flex: 1;
        min-width: 0;
    }

    .acompanhamento-card-title {
        font-weight: 700;
        color: #0f172a;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 0.2rem;
    }

    .acompanhamento-card-description {
        color: #64748b;
        font-size: 0.82rem;
        line-height: 1.35;
        margin-bottom: 0.35rem;
    }

    .acompanhamento-card-meta {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .acompanhamento-meta-badge {
        font-size: 0.72rem;
        font-weight: 600;
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        background: #f1f5f9;
        color: #334155;
    }

    .acompanhamentos-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

    .acompanhamentos-header-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #334155;
        margin: 0;
    }

    .acompanhamentos-header-subtitle {
        font-size: 0.75rem;
        color: #64748b;
        margin: 0;
    }
</style>

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="container-fluid">
        <div class="d-flex flex-column flex-md-row justify-content-end align-items-md-center mb-4 gap-3">
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="fas fa-save me-2"></i>Publicar Produto
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-8">
                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark"><i class="fas fa-info-circle me-2 text-primary"></i>Geral</span>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
    <div class="col-12">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" placeholder="Nome do prato ou bebida" />
        <span asp-validation-for="Nome" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Descricao" class="form-label">Descrição</label>
        <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Ex: Sopa de macaxeira com carne de sol e queijo coalho..."></textarea>
    </div>

    <div class="col-md-4">
        <label asp-for="CategoriaId" class="form-label">Categoria do Menu</label>
        <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger small"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Preco" class="form-label">Preço de Venda</label>
        <div class="input-group">
            <span class="input-group-text input-group-text-clean">R$</span>
            <input asp-for="Preco" type="text" value="" class="form-control money" placeholder="0,00" />
        </div>
        <span asp-validation-for="Preco" class="text-danger small"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Ordem" class="form-label">Ordem</label>
        <input asp-for="Ordem" class="form-control" type="number" min="0" />
        <span asp-validation-for="Ordem" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label class="form-label">Tempo de preparo</label>

        <div class="row g-2">
            <div class="col-md-6">
                <div class="input-group">
                    <input asp-for="TempoPreparoHoras"
                           class="form-control"
                           type="number"
                           min="0"
                           max="999"
                           placeholder="Horas" />
                    <span class="input-group-text">hr</span>
                </div>
                <span asp-validation-for="TempoPreparoHoras" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="input-group">
                    <input asp-for="TempoPreparoMinutosRestantes"
                           class="form-control"
                           type="number"
                           min="0"
                           max="59"
                           placeholder="Minutos" />
                    <span class="input-group-text">min</span>
                </div>
                <span asp-validation-for="TempoPreparoMinutosRestantes" class="text-danger small"></span>
            </div>
        </div>
    </div>
</div>
                    </div>
                </div>

                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark"><i class="fas fa-list-ul me-2 text-primary"></i>Personalização</span>
                        <button type="button" id="btnAdicionarCategoriaAcompanhamento" class="btn btn-sm btn-primary">
                            <i class="fas fa-plus me-1"></i>Novo Grupo
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="categorias-acompanhamento-container">
                        </div>
                        <div id="mensagemSemCategorias" class="text-center py-4 text-muted">
                            <i class="fas fa-layer-group d-block fs-2 mb-2 opacity-25"></i>
                            <p class="small mb-0">Sem grupos de acompanhamento (opcional).</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark">Imagem</span>
                    </div>
                    <div class="card-body">
                        <div class="image-upload-zone" onclick="document.getElementById('imagemForm').click()">
                            <div class="upload-placeholder" id="placeholderIcon">
                                <i class="fas fa-cloud-upload-alt fa-3x mb-2"></i>
                                <p class="small mb-0">Clique para upload</p>
                            </div>
                            <img id="imgPreview" src="#" alt="Preview" />
                        </div>
                        <input type="file"
               name="imagemForm"
               id="imagemForm"
               class="d-none"
               accept="image/*" />

                        <p class="text-center text-muted x-small mt-2">Formatos: JPG, PNG (Máx 3MB)</p>
                    </div>
                </div>

                <div class="card card-form-clean bg-light border-0">
                    <div class="card-body">
                        <div class="form-check form-switch custom-switch">
                            <input class="form-check-input" type="checkbox" asp-for="Ativo" checked>
                                <label class="form-check-label fw-bold" asp-for="Ativo">Disponível para venda</label>
                            </div>
                            <p class="text-muted small mt-2 mb-0">Produtos desativados não aparecem para o cliente no cardápio.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>

    <script id="template-categoria-acompanhamento" type="text/template">
        <div class="card shadow-sm mb-4 categoria-acompanhamento-item border-0">
            <div class="card-body">
                <div class="row g-3 align-items-end mb-4">
                    <div class="col-md-7">
                        <label class="form-label fw-semibold text-dark">Categoria de Acompanhamento</label>
                        <select name="CategoriasAcompanhamentoSelecionadas[__index__].AcompanhamentoCategoriaId"
                                class="form-select select-categoria-acompanhamento border-secondary-subtle">
                            <option value="">Selecione uma categoria...</option>
                            @foreach (var item in Model.CategoriasAcompanhamentoDisponiveis)
                            {
                                    <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-5 text-md-end">
                        <button type="button" class="btn btn-link text-danger text-decoration-none btnRemoverCategoriaAcompanhamento p-0 mb-2">
                            <i class="fas fa-trash-alt me-1"></i> Remover Categoria
                        </button>
                    </div>
                </div>

                <div class="bg-body-tertiary p-3 rounded-3 mb-2">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small text-muted d-block">Obrigatório?</label>
                            <div class="form-check form-switch pt-1">
                                <input type="checkbox"
                                       id="check_obrigatorio___index__"
                                       class="form-check-input input-obrigatorio-checkbox"
                                       name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio"
                                       value="true" />
                                <label class="form-check-label small" for="check_obrigatorio___index__">Sim</label>
                            
                                <input type="hidden" name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio" value="false" />
                            </div>
                        </div>

                        <div class="col-6 col-md-3">
                            <label class="form-label small text-muted font-monospace">Mínimo</label>
                            <input type="number" min="0" class="form-control form-control-sm input-min"
                                   name="CategoriasAcompanhamentoSelecionadas[__index__].MinSelecionados" value="0" />
                        </div>

                        <div class="col-6 col-md-3">
                            <label class="form-label small text-muted font-monospace">Máximo</label>
                            <input type="number" min="1" class="form-control form-control-sm input-max"
                                   name="CategoriasAcompanhamentoSelecionadas[__index__].MaxSelecionados" value="1" />
                        </div>

                        <div class="col-12 col-md-3">
                            <label class="form-label small text-muted font-monospace">Ordem</label>
                            <input type="number" min="0" class="form-control form-control-sm input-ordem"
                                   name="CategoriasAcompanhamentoSelecionadas[__index__].Ordem" value="0" />
                        </div>
                    </div>
                </div>

                <div class="categoria-acompanhamento-regras d-flex gap-2 px-1">
                    <span class="badge text-secondary border badge-rule">Obrigatório: Não</span>
                    <span class="badge text-secondary border badge-rule">Mínimo: 0</span>
                    <span class="badge text-secondary border badge-rule">Máximo: 1</span>
                </div>

                <input type="hidden" name="CategoriasAcompanhamentoSelecionadas[__index__].NomeCategoria"
                       value="" class="input-nome-categoria" />

                <div class="acompanhamentos-vinculados mt-3"></div>
            </div>
        </div>
    </script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const container = document.getElementById("categorias-acompanhamento-container");
            const btnAdicionar = document.getElementById("btnAdicionarCategoriaAcompanhamento");
            const template = document.getElementById("template-categoria-acompanhamento").innerHTML;
            const mensagemSemCategorias = document.getElementById("mensagemSemCategorias");

            $('.money').mask('#.##0,00', {
                reverse: true
            });

            function atualizarMensagemVazia() {
                const total = container.querySelectorAll(".categoria-acompanhamento-item").length;
                mensagemSemCategorias.style.display = total > 0 ? "none" : "block";
            }

            function obterProximoIndice() {
                return container.querySelectorAll(".categoria-acompanhamento-item").length;
            }

            function reindexar() {
                const itens = container.querySelectorAll(".categoria-acompanhamento-item");

                itens.forEach((item, index) => {
                    item.querySelectorAll("select, input").forEach(campo => {
                        if (campo.name) {
                            campo.name = campo.name
                                .replace(/CategoriasAcompanhamentoSelecionadas\[\d+\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`)
                                .replace(/CategoriasAcompanhamentoSelecionadas\[__index__\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`);
                        }
                    });

                    const acompanhamentos = item.querySelectorAll(".acompanhamento-opcao");
                    acompanhamentos.forEach((acomItem, acomIndex) => {
                        acomItem.querySelectorAll("input").forEach(campo => {
                            if (campo.name) {
                                campo.name = campo.name.replace(
                                    /CategoriasAcompanhamentoSelecionadas\[\d+\]\.Acompanhamentos\[\d+\]/g,
                                    `CategoriasAcompanhamentoSelecionadas[${index}].Acompanhamentos[${acomIndex}]`);
                            }

                            if (campo.id && campo.id.includes("cat_")) {
                                campo.id = `cat_${index}_acom_${acomIndex}`;
                            }
                        });

                        const label = acomItem.querySelector("label[for]");
                        if (label) {
                            label.setAttribute("for", `cat_${index}_acom_${acomIndex}`);
                        }
                    });

                    atualizarResumoRegras(item);
                });
            }

            function atualizarResumoRegras(item) {
                const obrigatorio = item.querySelector(".input-obrigatorio-checkbox")?.checked ?? false;
                const min = item.querySelector(".input-min")?.value ?? "0";
                const max = item.querySelector(".input-max")?.value ?? "1";
                const ordem = item.querySelector(".input-ordem")?.value ?? "0";
                const box = item.querySelector(".categoria-acompanhamento-regras");

                box.innerHTML = `
                    <span class="badge-rule">Obrigatório: ${obrigatorio ? "Sim" : "Não"}</span>
                    <span class="badge-rule">Mínimo: ${min}</span>
                    <span class="badge-rule">Máximo: ${max}</span>
                    <span class="badge-rule">Ordem: ${ordem}</span>
                `;
            }

            /* function montarHtmlAcompanhamentos(indexCategoria, acompanhamentos) {
                if (!acompanhamentos || acompanhamentos.length === 0) {
                    return `<div class="alert alert-light border mb-0">Nenhum acompanhamento ativo encontrado para esta categoria.</div>`;
                }

                let html = `<div class="row g-2">`;

                acompanhamentos.forEach((item, idx) => {
                    html += `
                        <div class="col-md-6">
                            <div class="form-check acompanhamento-opcao">
                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].AcompanhamentoId"
                                       value="${item.id}" />

                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Nome"
                                       value="${item.nome}" />

                                <input type="checkbox"
                                       class="form-check-input"
                                       id="cat_${indexCategoria}_acom_${idx}"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                       value="true" />

                                <input type="hidden"
                                       name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                       value="false" />

                                <label class="form-check-label ms-1" for="cat_${indexCategoria}_acom_${idx}">
                                    ${item.nome}
                                </label>
                            </div>
                        </div>
                    `;
                });

                html += `</div>`;
                return html;
            } */

            function montarHtmlAcompanhamentos(indexCategoria, acompanhamentos) {
                if (!acompanhamentos || acompanhamentos.length === 0) {
                    return `
                        <div class="alert alert-light border mb-0">
                            Nenhum acompanhamento ativo encontrado para esta categoria.
                        </div>
                    `;
                }

                let html = `
                    <div class="acompanhamentos-header">
                        <div>
                            <p class="acompanhamentos-header-title">Itens da categoria</p>
                            <p class="acompanhamentos-header-subtitle">
                                Selecione os acompanhamentos disponíveis para este grupo.
                            </p>
                        </div>
                        <span class="badge-rule">${acompanhamentos.length} item(ns)</span>
                    </div>

                    <div class="acompanhamentos-grid">
                `;

                acompanhamentos.forEach((item, idx) => {
                    const descricao = item.descricao ?? "";
                    const preco = item.preco ?? "0,00";
                    const ordem = item.ordem ?? 0;

                    html += `
                        <div class="acompanhamento-card-option" data-acompanhamento-card>
                            <div class="acompanhamento-check">
                                <input type="hidden"
                                    name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].AcompanhamentoId"
                                    value="${item.id}" />

                                <input type="hidden"
                                    name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Nome"
                                    value="${item.nome}" />

                                <input type="checkbox"
                                    class="form-check-input input-selecionado-acomp"
                                    id="cat_${indexCategoria}_acom_${idx}"
                                    name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                    value="true" />

                                <input type="hidden"
                                    name="CategoriasAcompanhamentoSelecionadas[${indexCategoria}].Acompanhamentos[${idx}].Selecionado"
                                    value="false" />
                            </div>

                            <label class="acompanhamento-card-content mb-0" for="cat_${indexCategoria}_acom_${idx}">
                                <div class="acompanhamento-card-title">${item.nome}</div>
                                <div class="acompanhamento-card-description">
                                    ${descricao || "Sem descrição cadastrada."}
                                </div>

                                <div class="acompanhamento-card-meta">
                                    <span class="acompanhamento-meta-badge">R$ ${preco}</span>
                                    <span class="acompanhamento-meta-badge">Ordem ${ordem}</span>
                                </div>
                            </label>
                        </div>
                    `;
                });

                html += `</div>`;
                return html;
            }

            async function carregarAcompanhamentos(item) {
                const select = item.querySelector(".select-categoria-acompanhamento");
                const categoriaId = select.value;
                const index = Array.from(container.querySelectorAll(".categoria-acompanhamento-item")).indexOf(item);

                const inputNome = item.querySelector(".input-nome-categoria");
                const acompanhamentosBox = item.querySelector(".acompanhamentos-vinculados");

                if (!categoriaId) {
                    inputNome.value = "";
                    acompanhamentosBox.innerHTML = "";
                    atualizarResumoRegras(item);
                    return;
                }

                const response = await fetch(`@Url.Action("ObterAcompanhamentosPorCategoria", "Produtos", new { area = "Admin" })?categoriaId=${categoriaId}`);

                if (!response.ok) {
                    acompanhamentosBox.innerHTML = `<div class="alert alert-danger mb-0">Não foi possível carregar os acompanhamentos.</div>`;
                    return;
                }

                const data = await response.json();

                inputNome.value = data.categoria.nome;
                acompanhamentosBox.innerHTML = montarHtmlAcompanhamentos(index, data.acompanhamentos);
                reindexar();
            }

            btnAdicionar.addEventListener("click", function () {
                const index = obterProximoIndice();
                const html = template.replaceAll("__index__", index);
                container.insertAdjacentHTML("beforeend", html);
                atualizarMensagemVazia();
            });

            container.addEventListener("click", function (e) {
                const btnRemover = e.target.closest(".btnRemoverCategoriaAcompanhamento");
                if (btnRemover) {
                    btnRemover.closest(".categoria-acompanhamento-item").remove();
                    reindexar();
                    atualizarMensagemVazia();
                }
            });

            container.addEventListener("change", async function (e) {
                const item = e.target.closest(".categoria-acompanhamento-item");
                if (!item) return;

                if (e.target.closest(".select-categoria-acompanhamento")) {
                    await carregarAcompanhamentos(item);
                }

                if (
                    e.target.classList.contains("input-min") ||
                    e.target.classList.contains("input-max") ||
                    e.target.classList.contains("input-ordem") ||
                    e.target.classList.contains("input-obrigatorio-checkbox")
                ) {
                    atualizarResumoRegras(item);
                }
            });

            $("#imagemForm").on("change", function () {
                const file = this.files && this.files[0];
                if (!file) {
                    $("#imgPreview").attr("src", "#").hide();
                    $("#placeholderIcon").show();
                    return;
                }

                const maxSize = 3 * 1024 * 1024; // 2MB

                if (file.size > maxSize) {
                    this.value = "";
                    $("#imgPreview").attr("src", "#").hide();
                    $("#placeholderIcon").show();

                    if (typeof uiNotify !== "undefined" && uiNotify.alert) {
                        uiNotify.alert.error("A imagem deve ter no máximo 2MB.");
                    } else {
                        alert("A imagem deve ter no máximo 2MB.");
                    }

                    return;
                }

                const reader = new FileReader();

                reader.onload = function (event) {
                    $("#imgPreview")
                        .attr("src", event.target.result)
                        .css("display", "block");

                    $("#placeholderIcon").hide();
                };

                reader.readAsDataURL(file);
            });

            $('form').submit(function () {
                if ($(this).valid()) {
                    if (typeof window.addLoading === "function") {
                        window.addLoading("Salvando produto...");
                    }
                }
            });

            document.querySelectorAll(".categoria-acompanhamento-item").forEach(item => {
                atualizarResumoRegras(item);
            });

            atualizarMensagemVazia();
        });
    </script>
}