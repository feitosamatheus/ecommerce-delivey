@model Ecommerce.MVC.Models.Admin.ProdutosIndexViewModel
@using System.Globalization
@{
    var pt = new CultureInfo("pt-BR");

    string IconeOrdenacao(string coluna)
    {
        if (Model.SortColumn != coluna)
            return "fas fa-sort text-muted opacity-50";

        return Model.SortDirection == "asc"
            ? "fas fa-sort-up text-primary"
            : "fas fa-sort-down text-primary";
    }
}

<style>
    /* Estilos de Paginação e Design System */
    .pagination-clean .page-link {
        border: 1px solid #e2e8f0;
        color: #64748b;
        margin: 0 2px;
        border-radius: 0.5rem !important;
        font-weight: 500;
        transition: all 0.2s ease;
        padding: 0.4rem 0.8rem;
    }

    .pagination-clean .page-item.active .page-link {
        background-color: #0d6efd;
        border-color: #fff;
        color: #fff;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .btn-white {
        background: #fff;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
    }

    .img-product-thumb {
        width: 44px;
        height: 44px;
        object-fit: cover;
        border-radius: 0.5rem;
        border: 1px solid #e2e8f0;
    }
</style>

<div class="card card-table-clean mt-2">
    <div class="card-header d-flex align-items-center justify-content-between row mx-0">
        <div class="col-6 ps-0">
            <h3 class="card-title fs-6 fw-bold mb-0">
                <i class="fas fa-list me-2 text-primary"></i> Catálogo de Produtos
            </h3>
        </div>

        <div class="col-6 pe-0 mt-2 mt-sm-0">
            <div class="d-flex justify-content-end align-items-center gap-3 flex-wrap">
                @if (Model.Produtos != null && Model.Produtos.Any())
                {
                    <span class="badge rounded-pill bg-light text-primary border">
                        @Model.TotalItens <span class="d-none d-sm-inline">Produtos</span>
                    </span>
                }

                <div class="d-flex align-items-center gap-2">
                    <select class="form-select form-select-sm"
                            id="tamanhoPagina"
                            name="tamanhoPagina"
                            form="formFiltroProdutos"
                            onchange="$('#formFiltroProdutos').submit()"
                            style="width: 85px; border-radius: 0.5rem;">
                        <option value="5" selected="@(Model.TamanhoPagina == 5)">5</option>
                        <option value="10" selected="@(Model.TamanhoPagina == 10)">10</option>
                        <option value="20" selected="@(Model.TamanhoPagina == 20)">20</option>
                        <option value="50" selected="@(Model.TamanhoPagina == 50)">50</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive d-none d-md-block">
            <table class="table table-hover table-clean align-middle mb-0">
                @* <thead>
                    <tr>
                        <th class="ps-4" style="width: 80px;">Foto</th>
                        <th>
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="Nome">
                                Produto <i class="@IconeOrdenacao("Nome") ms-1"></i>
                            </a>
                        </th>
                        <th>Categoria</th>
                        <th class="text-end">Preço</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4" style="width: 150px">Ações</th>
                    </tr>
                </thead> *@
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 80px;">Foto</th>

                        <th>
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="Nome">
                                Produto <i class="@IconeOrdenacao("Nome") ms-1"></i>
                            </a>
                        </th>

                        <th>
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="Categoria">
                                Categoria <i class="@IconeOrdenacao("Categoria") ms-1"></i>
                            </a>
                        </th>

                        <th class="text-end">
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="Preco">
                                Preço <i class="@IconeOrdenacao("Preco") ms-1"></i>
                            </a>
                        </th>

                        <th class="text-center">
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="Status">
                                Status <i class="@IconeOrdenacao("Status") ms-1"></i>
                            </a>
                        </th>
                        
                        <th>
                            <a href="javascript:void(0)" class="text-decoration-none text-reset ordenacao-produto" data-coluna="DataCriacao">
                                Data criação <i class="@IconeOrdenacao("DataCriacao") ms-1"></i>
                            </a>
                        </th>


                        <th class="text-end pe-4" style="width: 150px">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Produtos != null && Model.Produtos.Any())
                    {
                        @foreach (var p in Model.Produtos)
                        {
                            <tr>
                                <td class="ps-4">
                                    <img src="@(string.IsNullOrEmpty(p.ImagemUrl) ? "/img/no-image.png" : p.ImagemUrl)"
                                         class="img-product-thumb" alt="@p.Nome" />
                                </td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark">@p.Nome</span>
                                        @if (!string.IsNullOrEmpty(p.Descricao))
                                        {
                                            <small class="text-muted text-truncate" style="max-width: 250px;">@p.Descricao</small>
                                        }
                                    </div>
                                </td>
                                <td>
                                    <span class="text-muted"><i class="fas fa-tag me-1 small"></i> @(p.Categoria?.Nome ?? "Geral")</span>
                                </td>
                                <td class="text-end fw-bold text-dark">@p.Preco.ToString("C", pt)</td>
                                <td class="text-center">
                                    @if (p.Ativo)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle badge-status">
                                            Ativo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle badge-status">
                                            Inativo
                                        </span>
                                    }
                                </td>
                                <td>
                                    @p.DataCriacaoUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-white text-primary" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-produto" data-id="@p.Id" title="Excluir">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                    <form id="form-delete-@p.Id" asp-action="Delete" asp-route-id="@p.Id" method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            @if (Model.Produtos != null && Model.Produtos.Any())
            {
                <div class="p-3 border-bottom bg-white">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label small text-muted mb-1">Ordenar por</label>
                            <select class="form-select form-select-sm" id="sortColumnMobile">
                                <option value="Nome" selected="@(Model.SortColumn == "Nome")">Produto</option>
                                <option value="Categoria" selected="@(Model.SortColumn == "Categoria")">Categoria</option>
                                <option value="Preco" selected="@(Model.SortColumn == "Preco")">Preço</option>
                                <option value="Status" selected="@(Model.SortColumn == "Status")">Status</option>
                                <option value="DataCriacao" selected="@(Model.SortColumn == "DataCriacao")">Data de criação</option>
                            </select>
                        </div>

                        <div class="col-5">
                            <label class="form-label small text-muted mb-1">Direção</label>
                            <select class="form-select form-select-sm" id="sortDirectionMobile">
                                <option value="asc" selected="@(Model.SortDirection == "asc")">Crescente</option>
                                <option value="desc" selected="@(Model.SortDirection == "desc")">Decrescente</option>
                            </select>
                        </div>
                    </div>
                </div>
                @foreach (var p in Model.Produtos)
                {
                    <div class="mobile-order-item p-3 border-bottom">
                        <div class="d-flex align-items-center gap-3">
                            <img src="@(string.IsNullOrEmpty(p.ImagemUrl) ? "/img/no-image.png" : p.ImagemUrl)"
                                 class="img-product-thumb" alt="@p.Nome" />
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold text-dark">@p.Nome</span>
                                    <span class="fw-bold text-primary">@p.Preco.ToString("C", pt)</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <small class="text-muted"><i class="fas fa-tag me-1"></i> @(p.Categoria?.Nome ?? "Geral")</small>
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@p.Id" class="btn btn-sm btn-white text-primary">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-produto" data-id="@p.Id">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>

        @if (Model.Produtos == null || !Model.Produtos.Any())
        {
            <div class="text-center py-5">
                <i class="fas fa-layer-group fa-3x text-light mb-3 d-block"></i>
                <p class="text-muted mb-0">Nenhum resultado encontrado.</p>
            </div>
        }

        @if (Model.TotalPaginas > 1)
        {
            <div class="d-flex justify-content-between align-items-center p-3 border-top bg-white flex-wrap gap-2">
                <div class="text-muted small">
                    Exibindo <strong>@(((Model.PaginaAtual - 1) * Model.TamanhoPagina) + 1)</strong>
                    até <strong>@(Math.Min(Model.PaginaAtual * Model.TamanhoPagina, Model.TotalItens))</strong>
                    de <strong>@Model.TotalItens</strong> produtos
                </div>

                <nav aria-label="Navegação de páginas">
                    <ul class="pagination pagination-sm pagination-clean mb-0">
                        <li class="page-item @(Model.PaginaAtual == 1 ? "disabled" : "")">
                            <a class="page-link paginacao-produto" href="javascript:void(0)" data-pagina="@(Model.PaginaAtual - 1)">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            @if (i == 1 || i == Model.TotalPaginas || (i >= Model.PaginaAtual - 2 && i <= Model.PaginaAtual + 2))
                            {
                                <li class="page-item @(i == Model.PaginaAtual ? "active" : "")">
                                    <a class="page-link paginacao-produto" href="javascript:void(0)" data-pagina="@i">@i</a>
                                </li>
                            }
                            else if (i == Model.PaginaAtual - 3 || i == Model.PaginaAtual + 3)
                            {
                                <li class="page-item disabled"><span class="page-link border-0">...</span></li>
                            }
                        }

                        <li class="page-item @(Model.PaginaAtual == Model.TotalPaginas ? "disabled" : "")">
                            <a class="page-link paginacao-produto" href="javascript:void(0)" data-pagina="@(Model.PaginaAtual + 1)">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>