@model IEnumerable<Ecommerce.MVC.Entities.Produto>

@{
    ViewData["Title"] = "Produtos - Admin";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Produtos</h2>
        <a asp-area="Admin" asp-controller="Produtos" asp-action="Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Novo produto
        </a>
    </div>

    <div class="table-responsive bg-white rounded-3 shadow-sm">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nome</th>
                    <th>Categoria</th>
                    <th class="text-end">Preço</th>
                    <th class="text-center">Preparo (min)</th>
                    <th style="width: 1%;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Nome</td>
                        <td>@p.Categoria?.Nome</td>
                        <td class="text-end">@p.Preco.ToString("C")</td>
                        <td class="text-center">@p.TempoPreparoMinutos</td>
                        <td class="text-end">
                            <div class="btn-group btn-group-sm">
                                <a asp-area="Admin" asp-controller="Produtos" asp-action="Edit" asp-route-id="@p.Id" class="btn btn-outline-secondary">
                                    Editar
                                </a>
                                <form asp-area="Admin" asp-controller="Produtos" asp-action="Delete" asp-route-id="@p.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Deseja realmente excluir este produto?');">
                                        Excluir
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

