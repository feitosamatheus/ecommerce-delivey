@model Ecommerce.MVC.Models.Admin.ProdutosIndexViewModel

@{
    ViewData["Title"] = "Produtos";
    ViewData["Description"] = "Gerencie o catálogo de produtos, preços e categorias.";
}

<style>
    /* Design System - Barriga Cheia */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

        .card-filter-clean .card-header {
            background-color: transparent;
            border-bottom: 1px solid #f1f5f9;
            padding: 1rem 1.25rem;
        }

        .card-filter-clean .form-label {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.025em;
            color: #64748b;
            margin-bottom: 0.5rem;
        }

        .card-filter-clean .form-control,
        .card-filter-clean .form-select {
            border: 1px solid #e2e8f0;
            border-radius: 0.5rem;
            padding: 0.5rem 0.75rem;
            font-size: 0.9rem;
            transition: all 0.2s ease;
        }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        text-decoration: none;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
    }

    .badge-status {
        font-weight: 600;
        padding: 0.35em 0.65em;
        border-radius: 0.375rem;
    }

    .btn-tool {
        transition: all 0.2s ease-in-out;
    }
</style>

<div class="container-fluid px-0">
    <div class="w-100 d-flex justify-content-between align-items-center mb-3">
        <h2 class="fs-4 fw-bold mb-0 text-dark">Gestão de Produtos</h2>
        <div class="d-flex gap-2">
            <a asp-area="Admin" asp-controller="Produtos" asp-action="Create"
                   class="btn btn-primary btn-sm shadow-sm btn-filter-action">
                <i class="fas fa-plus"></i> Novo Produto
            </a>
        </div>
    </div>
    @* Mensagens de Feedback *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
    }
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center py-2">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i> Filtros de Pesquisa
            </h3>
            <div class="card-tools ms-auto">
                <button type="button" class="btn btn-link btn-sm text-muted btn-tool" data-lte-toggle="card-collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="card-body">
            <form id="formFiltroProdutos" method="get" action="@Url.Action("Index", "Produtos", new { area = "Admin" })">
                <input type="hidden" id="pagina" name="pagina" value="@Model.PaginaAtual" />
                <input type="hidden" name="sortColumn" id="sortColumn" value="@Model.SortColumn" />
                <input type="hidden" name="sortDirection" id="sortDirection" value="@Model.SortDirection" />
                
                <div class="row g-3">
                    <div class="col-xl-5">
                        <label for="busca" class="form-label">Nome do Produto</label>
                        <input type="text" class="form-control" id="busca" name="busca"
                               placeholder="Ex: Pizza Calabresa..." value="@Context.Request.Query["busca"]">
                    </div>

                    <div class="col-xl-4">
                        <label for="categoriaId" class="form-label">Categoria</label>
                        <select class="form-select" id="categoriaId" name="categoriaId">
                            <option value="">Todas as categorias</option>
                            @foreach (var cat in Model.Categorias)
                            {
                                <option value="@cat.Value" selected="@(Context.Request.Query["categoriaId"] == cat.Value)">
                                    @cat.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-xl-3 d-flex align-items-end justify-content-end gap-2">
                        <a href="@Url.Action("Index", "Produtos", new { area = "Admin" })" class="btn btn-filter-outline btn-filter-action">
                            <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card card-table-clean">
        <div id="resultadoProdutos" class="card-body table-responsive p-0">
            @await Html.PartialAsync("_ProdutosLista", Model)
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
        // Lógica AJAX para Filtro e Paginação
        $("#formFiltroProdutos").on("submit", function (e, manterPagina) {
        e.preventDefault();
        const $form = $(this);
        const $btn = $form.find("button[type='submit']");

        if (!manterPagina) { $form.find("#pagina").val(1); }

        let url = $form.attr("action") + "?" + $form.serialize();
        $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Aguarde...');

        if (typeof window.addLoading === "function") window.addLoading("Buscando produtos...");

        $.ajax({
        url: url,
        type: "GET",
        headers: { "X-Requested-With": "XMLHttpRequest" },
        success: function (html) {
        $("#resultadoProdutos").html(html);
        window.history.replaceState({}, "", url);
        },
        error: function () {
        Swal.fire("Erro", "Não foi possível carregar os produtos.", "error");
        },
        complete: function () {
        $btn.prop("disabled", false).html('<i class="fas fa-search"></i> Filtrar');
        if (typeof window.removeLoading === "function") window.removeLoading();
        }
        });
        });

        // Exclusão com SweetAlert2
        $(document).on("click", ".btn-excluir-produto", function () {
        const id = $(this).data("id");
                
        Swal.fire({
        title: 'Remover Produto?',
        text: "O item será desativado e não aparecerá mais no catálogo.",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#2c180d',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Sim, desativar!',
        cancelButtonText: 'Cancelar',
        reverseButtons: true
        }).then((result) => {
        if (result.isConfirmed) {
        if (typeof window.addLoading === "function") {
        window.addLoading("Desativando produto...");
        }
        $(`#form-delete-${id}`).submit();
        }
        });
        });

        // Paginação
        $(document).on("click", ".paginacao-produto", function (e) {
            e.preventDefault();
            const pagina = $(this).data("pagina");
            if (pagina) {
                $("#pagina").val(pagina);
                $("#formFiltroProdutos").trigger("submit", [true]);
            }
        });

            // Troca de ícone no colapso do card
            $(".btn-tool").on("click", function () {
                const $icon = $(this).find("i");
                setTimeout(() => {
                    const isCollapsed = $(this).closest(".card").hasClass("collapsed-card");
                    $icon.attr("class", `fas fa-${isCollapsed ? "plus" : "minus"}`);
                }, 300);
            });
        });

        $(document).on('click', '.ordenacao-produto', function () {
            const coluna = $(this).data('coluna');
            const sortColumnAtual = $('#sortColumn').val();
            const sortDirectionAtual = $('#sortDirection').val();

            let novaDirecao = 'asc';

            if (sortColumnAtual === coluna) {
                novaDirecao = sortDirectionAtual === 'asc' ? 'desc' : 'asc';
            }

            $('#sortColumn').val(coluna);
            $('#sortDirection').val(novaDirecao);

            // sempre volta para a primeira página ao trocar ordenação
            $('input[name="pagina"]').val(1);

            $('#formFiltroProdutos').submit();

            $(document).on("change", "#sortColumnMobile, #sortDirectionMobile", function () {
                $("#sortColumn").val($("#sortColumnMobile").val());
                $("#sortDirection").val($("#sortDirectionMobile").val());
                $("#pagina").val(1);

                $("#formFiltroProdutos").trigger("submit", [true]);
            });
        });
    </script>
}