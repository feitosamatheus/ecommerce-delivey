@model Ecommerce.MVC.Models.Admin.AdminProdutoFormViewModel

@{
    ViewData["Title"] = "Editar Produto";
    ViewData["page"] = "Produto";
}

<style>
    :root {
        --primary-soft: #eef2ff;
        --text-muted: #64748b;
        --border-color: #e2e8f0;
    }

    .card-form-clean {
        border: none;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        border-radius: 1rem;
        background-color: #ffffff;
        margin-bottom: 1.5rem;
    }

    .card-header-custom {
        padding: 1.25rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .form-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        color: var(--text-muted);
        letter-spacing: 0.05em;
    }

    .image-upload-zone {
        cursor: pointer;
        width: 100%;
        height: 250px;
        border: 2px dashed var(--border-color);
        border-radius: 1rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .image-upload-zone:hover {
        border-color: #3b82f6;
        background-color: #eff6ff;
    }

    #imgPreview {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: @(string.IsNullOrEmpty(Model.ImagemUrl) ? "none" : "block");
    }

    .upload-placeholder {
        text-align: center;
        color: var(--text-muted);
        display: @(string.IsNullOrEmpty(Model.ImagemUrl) ? "block" : "none");
    }

    .badge-rule {
        font-size: 0.7rem;
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        background: var(--primary-soft);
        color: #1e293b;
        font-weight: 600;
    }

    .input-group-text-clean {
        background: #f8fafc;
        border-right: none;
        color: var(--text-muted);
        font-weight: 600;
    }

    .custom-switch .form-check-input {
        width: 3rem;
        height: 1.5rem;
        cursor: pointer;
    }

    .acompanhamento-opcao {
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        padding: .75rem;
        background: #fff;
    }
    .acompanhamentos-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 0.75rem;
    }

    .acompanhamento-card-option {
        border: 1px solid var(--border-color);
        border-radius: 0.9rem;
        background: #fff;
        padding: 0.9rem 1rem;
        transition: all 0.2s ease;
        position: relative;
        min-height: 96px;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
    }

    .acompanhamento-card-option:hover {
        border-color: #93c5fd;
        background: #f8fbff;
        box-shadow: 0 4px 14px rgba(59, 130, 246, 0.08);
    }

    .acompanhamento-card-option.is-checked {
        border-color: #3b82f6;
        background: #eff6ff;
        box-shadow: 0 0 0 1px rgba(59, 130, 246, 0.15);
    }

    .acompanhamento-check {
        margin-top: 0.2rem;
        flex-shrink: 0;
    }

    .acompanhamento-check .form-check-input {
        width: 1.1rem;
        height: 1.1rem;
        cursor: pointer;
    }

    .acompanhamento-card-content {
        flex: 1;
        min-width: 0;
    }

    .acompanhamento-card-title {
        font-weight: 700;
        color: #0f172a;
        font-size: 0.95rem;
        line-height: 1.2;
        margin-bottom: 0.2rem;
    }

    .acompanhamento-card-description {
        color: #64748b;
        font-size: 0.82rem;
        line-height: 1.35;
        margin-bottom: 0.35rem;
    }

    .acompanhamento-card-meta {
        display: flex;
        gap: 0.4rem;
        flex-wrap: wrap;
    }

    .acompanhamento-meta-badge {
        font-size: 0.72rem;
        font-weight: 600;
        border-radius: 999px;
        padding: 0.25rem 0.55rem;
        background: #f1f5f9;
        color: #334155;
    }

    .acompanhamentos-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 0.75rem;
    }

    .acompanhamentos-header-title {
        font-size: 0.85rem;
        font-weight: 700;
        color: #334155;
        margin: 0;
    }

    .acompanhamentos-header-subtitle {
        font-size: 0.75rem;
        color: #64748b;
        margin: 0;
    }
</style>

<form asp-area="Admin" asp-controller="Produtos" asp-action="Edit" method="post" enctype="multipart/form-data" id="formProdutoEdit">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImagemUrl" />
    <input type="hidden" asp-for="PersonalizacaoJson" id="PersonalizacaoJson" />
    @* Mensagens de Feedback *@
    <div id="feedbackMessages">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
        }
    </div>
    <div class="container-fluid">
        <div class="d-flex justify-content-between align-items-md-center mb-4 gap-3">
            @* Cabeçalho *@
            <div class="d-flex justify-content-start align-items-center ">
                <a asp-action="Index" class="btn btn-light btn-sm border text-muted btn-action" style="border-radius: 0.5rem; padding: 0.6rem 1rem;">
                    <i class="fas fa-arrow-left"></i> Voltar
                </a>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancelar</a>
                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                    <i class="fas fa-save me-2"></i>Salvar Alterações
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-xl-8">
                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark">
                            <i class="fas fa-info-circle me-2 text-primary"></i>Geral
                        </span>
                    </div>

                    <div class="card-body">
                        <div class="row g-3">
    <div class="col-12">
        <label asp-for="Nome" class="form-label"></label>
        <input asp-for="Nome" class="form-control" placeholder="Nome do prato ou bebida" />
        <span asp-validation-for="Nome" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label asp-for="Descricao" class="form-label"></label>
        <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Descrição detalhada..."></textarea>
        <span asp-validation-for="Descricao" class="text-danger small"></span>
    </div>

    <div class="col-md-4">
        <label asp-for="CategoriaId" class="form-label">Categoria do Menu</label>
        <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-select">
            <option value="">Selecione...</option>
        </select>
        <span asp-validation-for="CategoriaId" class="text-danger small"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Preco" class="form-label">Preço de Venda</label>
        <div class="input-group">
            <span class="input-group-text input-group-text-clean">R$</span>
            <input asp-for="Preco" type="text" class="form-control money" placeholder="0,00" />
        </div>
        <span asp-validation-for="Preco" class="text-danger small"></span>
    </div>

    <div class="col-md-3">
        <label asp-for="Ordem" class="form-label">Ordem</label>
        <input asp-for="Ordem" class="form-control" type="number" min="0" />
        <span asp-validation-for="Ordem" class="text-danger small"></span>
    </div>

    <div class="col-12">
        <label class="form-label">Tempo de preparo</label>

        <div class="row g-2">
            <div class="col-md-6">
                <div class="input-group">
                    <input asp-for="TempoPreparoHoras"
                           class="form-control"
                           type="number"
                           min="0"
                           max="999"
                           placeholder="Horas" />
                    <span class="input-group-text">hr</span>
                </div>
                <span asp-validation-for="TempoPreparoHoras" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <div class="input-group">
                    <input asp-for="TempoPreparoMinutosRestantes"
                           class="form-control"
                           type="number"
                           min="0"
                           max="59"
                           placeholder="Minutos" />
                    <span class="input-group-text">min</span>
                </div>
                <span asp-validation-for="TempoPreparoMinutosRestantes" class="text-danger small"></span>
            </div>
        </div>
    </div>
</div>
                    </div>
                </div>

                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark">
                            <i class="fas fa-list-ul me-2 text-primary"></i>Personalização
                        </span>

                        <button type="button" id="btnAdicionarCategoriaAcompanhamento" class="btn btn-sm btn-primary">
                            <i class="fas fa-plus me-1"></i>Novo Grupo
                        </button>
                    </div>

                    <div class="card-body">
                        <div id="categorias-acompanhamento-container"></div>

                        <div id="mensagemSemCategorias" class="text-center py-4 text-muted">
                            <i class="fas fa-layer-group d-block fs-2 mb-2 opacity-25"></i>
                            <p class="small mb-0">Sem grupos de acompanhamento vinculados.</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="card card-form-clean">
                    <div class="card-header-custom">
                        <span class="fw-bold text-dark">Imagem</span>
                    </div>

                    <div class="card-body">
                        <div class="image-upload-zone" onclick="document.getElementById('imagemForm').click()">
                            <div class="upload-placeholder" id="placeholderIcon">
                                <i class="fas fa-cloud-upload-alt fa-3x mb-2"></i>
                                <p class="small mb-0">Clique para alterar</p>
                            </div>

                            <img id="imgPreview" src="https://cdn.gastroflow.cloud/@Model.ImagemUrl" alt="Preview" />
                        </div>

                        <input type="file"
                               name="imagemForm"
                               id="imagemForm"
                               class="d-none"
                               accept="image/*"
                               onchange="previewImage(this)" />

                        <p class="text-center text-muted x-small mt-2">
                            Formatos: JPG, PNG (Máx 3MB)
                        </p>
                    </div>
                </div>

                <div class="card card-form-clean bg-light border-0">
                    <div class="card-body">
                        <div class="form-check form-switch custom-switch d-flex align-items-center gap-2">
                            <input class="form-check-input" type="checkbox" asp-for="Ativo" />
                            <label class="form-check-label fw-bold mb-0" asp-for="Ativo">
                                Disponível para venda
                            </label>
                        </div>

                        <p class="text-muted small mt-2 mb-0">
                            Produtos inativos não aparecem no cardápio do cliente.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<script id="template-categoria-acompanhamento" type="text/template">
    <div class="card shadow-sm mb-4 categoria-acompanhamento-item border-0" data-index="__index__">
        <div class="card-body">
            <input type="hidden"
                   name="CategoriasAcompanhamentoSelecionadas[__index__].ProdutoId"
                   value=""
                   class="input-produto-id" />

            <div class="row g-3 align-items-end mb-4">
                <div class="col-md-7">
                    <label class="form-label fw-semibold text-dark">Categoria de Acompanhamento</label>
                    <select name="CategoriasAcompanhamentoSelecionadas[__index__].AcompanhamentoCategoriaId"
                            class="form-select select-categoria-acompanhamento border-secondary-subtle">
                        <option value="">Selecione uma categoria...</option>
                        @foreach (var item in Model.CategoriasAcompanhamentoDisponiveis)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    </select>
                </div>

                <div class="col-md-5 text-md-end">
                    <button type="button"
                            class="btn btn-link text-danger text-decoration-none btnRemoverCategoriaAcompanhamento p-0 mb-2">
                        <i class="fas fa-trash-alt me-1"></i>Remover Grupo
                    </button>
                </div>
            </div>

            <div class="bg-body-tertiary p-3 rounded-3 mb-3">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label small text-muted d-block">Obrigatório?</label>
                        <div class="form-check form-switch pt-1">
                            <input type="checkbox"
                                   id="check_obrigatorio___index__"
                                   class="form-check-input input-obrigatorio-checkbox"
                                   name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio"
                                   value="true" />
                            <label class="form-check-label small" for="check_obrigatorio___index__">Sim</label>

                            <input type="hidden"
                                   name="CategoriasAcompanhamentoSelecionadas[__index__].Obrigatorio"
                                   value="false" />
                        </div>
                    </div>

                    <div class="col-6 col-md-3">
                        <label class="form-label small text-muted">Mínimo</label>
                        <input type="number"
                               min="0"
                               class="form-control form-control-sm input-min"
                               name="CategoriasAcompanhamentoSelecionadas[__index__].MinSelecionados"
                               value="0" />
                    </div>

                    <div class="col-6 col-md-3">
                        <label class="form-label small text-muted">Máximo</label>
                        <input type="number"
                               min="1"
                               class="form-control form-control-sm input-max"
                               name="CategoriasAcompanhamentoSelecionadas[__index__].MaxSelecionados"
                               value="1" />
                    </div>

                    <div class="col-12 col-md-3">
                        <label class="form-label small text-muted">Ordem</label>
                        <input type="number"
                               min="0"
                               class="form-control form-control-sm input-ordem"
                               name="CategoriasAcompanhamentoSelecionadas[__index__].Ordem"
                               value="0" />
                    </div>
                </div>
            </div>

            <div class="categoria-acompanhamento-regras d-flex flex-wrap gap-2 px-1 mb-3">
                <span class="badge-rule badge-obrigatorio">Obrigatório: Não</span>
                <span class="badge-rule badge-min">Mínimo: 0</span>
                <span class="badge-rule badge-max">Máximo: 1</span>
                <span class="badge-rule badge-ordem">Ordem: 0</span>
            </div>

            <input type="hidden"
                   name="CategoriasAcompanhamentoSelecionadas[__index__].NomeCategoria"
                   value=""
                   class="input-nome-categoria" />

            <div class="acompanhamentos-vinculados mt-3"></div>
        </div>
    </div>
</script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery.mask/1.14.16/jquery.mask.min.js"></script>
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {
            const produtoId = document.getElementById('Id')?.value || null;
            const container = document.getElementById('categorias-acompanhamento-container');
            const btnAdicionar = document.getElementById('btnAdicionarCategoriaAcompanhamento');
            const template = document.getElementById('template-categoria-acompanhamento').innerHTML;
            const mensagemSemCategorias = document.getElementById('mensagemSemCategorias');
            const inputJson = document.getElementById('PersonalizacaoJson');

            const personalizacaoState = {
                produtoId: produtoId,
                produtoAcompanhamentoCategorias: []
            };

            console.log('[INIT] produtoId:', produtoId);
            console.log('[INIT] inputJson encontrado:', !!inputJson);
            console.log('[INIT] container encontrado:', !!container);

            $('.money').mask('#.##0,00', { reverse: true });

             window.previewImage = function (input) {
                const file = input.files && input.files[0];
                if (!file) return;

                const maxSize = 3 * 1024 * 1024; // 3MB

                if (file.size > maxSize) {
                    input.value = '';

                    $('#imgPreview').attr('src', '').hide();
                    $('#placeholderIcon').show();

                    if (typeof uiNotify !== 'undefined' && uiNotify.alert) {
                        uiNotify.alert.error('A imagem deve ter no máximo 2MB.');
                    } else {
                        alert('A imagem deve ter no máximo 2MB.');
                    }

                    return;
                }

                const reader = new FileReader();

                reader.onload = function (e) {
                    $('#imgPreview').attr('src', e.target.result).show();
                    $('#placeholderIcon').hide();
                };

                reader.readAsDataURL(file);
            };

            function escapeHtml(texto) {
                return String(texto ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function atualizarJsonPersonalizacao(origem = 'desconhecida') {
                if (inputJson) {
                    inputJson.value = JSON.stringify(personalizacaoState);
                }

                console.log(`[JSON][${origem}] PersonalizacaoJson atualizado`);
                console.log('[JSON] valor hidden:', inputJson?.value ?? null);
                console.log('[JSON] objeto state:', structuredClone(personalizacaoState));
            }

            function atualizarMensagemVazia() {
                const total = container.querySelectorAll('.categoria-acompanhamento-item').length;
                mensagemSemCategorias.style.display = total > 0 ? 'none' : 'block';
                console.log('[UI] total grupos na tela:', total);
            }

            function atualizarResumoRegras(item) {
                const obrigatorio = item.querySelector('.input-obrigatorio-checkbox')?.checked ?? false;
                const min = item.querySelector('.input-min')?.value ?? '0';
                const max = item.querySelector('.input-max')?.value ?? '1';
                const ordem = item.querySelector('.input-ordem')?.value ?? '0';

                item.querySelector('.badge-obrigatorio').textContent = `Obrigatório: ${obrigatorio ? 'Sim' : 'Não'}`;
                item.querySelector('.badge-min').textContent = `Mínimo: ${min}`;
                item.querySelector('.badge-max').textContent = `Máximo: ${max}`;
                item.querySelector('.badge-ordem').textContent = `Ordem: ${ordem}`;
            }

            function formatarPrecoInput(valor) {
                const numero = Number(String(valor ?? '0').replace(/\./g, '').replace(',', '.')) || 0;
                return numero.toFixed(2).replace('.', ',');
            }

            function obterProximoIndice() {
                return container.querySelectorAll('.categoria-acompanhamento-item').length;
            }

            function reindexar() {
                const itens = container.querySelectorAll('.categoria-acompanhamento-item');

                console.log('[REINDEX] iniciando. Total grupos:', itens.length);

                itens.forEach((item, index) => {
                    item.dataset.index = index;

                    item.querySelectorAll('select, input').forEach(campo => {
                        if (campo.name) {
                            campo.name = campo.name
                                .replace(/CategoriasAcompanhamentoSelecionadas\[\d+\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`)
                                .replace(/CategoriasAcompanhamentoSelecionadas\[__index__\]/g, `CategoriasAcompanhamentoSelecionadas[${index}]`);
                        }

                        if (campo.id && campo.id.startsWith('check_obrigatorio_')) {
                            campo.id = `check_obrigatorio_${index}`;
                        }
                    });

                    const labelObrigatorio = item.querySelector('label[for^="check_obrigatorio_"]');
                    if (labelObrigatorio) {
                        labelObrigatorio.setAttribute('for', `check_obrigatorio_${index}`);
                    }

                    item.querySelectorAll('.acompanhamento-item-row').forEach((linha, itemIndex) => {
                        linha.querySelectorAll('input, select, textarea').forEach(campo => {
                            if (!campo.name) return;

                            campo.name = campo.name.replace(
                                /CategoriasAcompanhamentoSelecionadas\[\d+\]\.Acompanhamentos\[\d+\]/g,
                                `CategoriasAcompanhamentoSelecionadas[${index}].Acompanhamentos[${itemIndex}]`
                            );
                        });

                        const checkbox = linha.querySelector('.input-selecionado-check');
                        const label = linha.querySelector('label[for^="cat_"]');

                        if (checkbox) {
                            checkbox.id = `cat_${index}_acom_${itemIndex}`;
                        }

                        if (label) {
                            label.setAttribute('for', `cat_${index}_acom_${itemIndex}`);
                        }
                    });

                    atualizarResumoRegras(item);
                });

                console.log('[REINDEX] finalizado');
            }

            function syncStateFromDom(origem = 'desconhecida') {
                const grupos = [];

                container.querySelectorAll('.categoria-acompanhamento-item').forEach((item, index) => {
                    const select = item.querySelector('.select-categoria-acompanhamento');
                    const option = select?.options[select.selectedIndex];

                    const grupo = {
                        id: item.dataset.grupoId || crypto.randomUUID(),
                        produtoId: produtoId,
                        acompanhamentoCategoriaId: select?.value || null,
                        nomeCategoria: item.querySelector('.input-nome-categoria')?.value || option?.text || '',
                        descricaoCategoria: '',
                        obrigatorio: item.querySelector('.input-obrigatorio-checkbox')?.checked ?? false,
                        minSelecionados: Number(item.querySelector('.input-min')?.value || 0),
                        maxSelecionados: Number(item.querySelector('.input-max')?.value || 1),
                        ordem: Number(item.querySelector('.input-ordem')?.value || index),
                        produtoAcompanhamentos: []
                    };

                    item.querySelectorAll('.acompanhamento-item-row').forEach((linha) => {
                        grupo.produtoAcompanhamentos.push({
                            id: linha.querySelector('.input-id')?.value || '',
                            produtoId: produtoId,
                            acompanhamentoCategoriaId: grupo.acompanhamentoCategoriaId,
                            acompanhamentoId: linha.querySelector('.input-acompanhamento-id-base')?.value || '',
                            nome: linha.querySelector('.input-nome')?.value || '',
                            descricao: linha.querySelector('.input-descricao')?.value || '',
                            preco: linha.querySelector('.input-preco')?.value || '0,00',
                            ativo: linha.querySelector('.input-ativo')?.checked ?? false,
                            ordem: Number(linha.querySelector('.input-ordem-item')?.value || 0),
                            selecionado: linha.querySelector('.input-selecionado-check')?.checked ?? false
                        });
                    });

                    grupos.push(grupo);
                });

                personalizacaoState.produtoAcompanhamentoCategorias = grupos;

                console.log(`[SYNC][${origem}] grupos coletados da DOM:`, grupos.length);
                console.log(`[SYNC][${origem}] state montado:`, structuredClone(personalizacaoState));

                atualizarJsonPersonalizacao(origem);
            }

            /*function montarHtmlAcompanhamentos(acompanhamentos, grupoIndex) {
                if (!acompanhamentos || acompanhamentos.length === 0) {
                    return `
                        <div class="border rounded-3 p-3 bg-light text-muted small">
