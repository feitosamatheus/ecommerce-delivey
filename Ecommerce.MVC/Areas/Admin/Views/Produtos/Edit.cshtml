            function montarHtmlAcompanhamentos(acompanhamentos, grupoIndex) {
                if (!acompanhamentos || acompanhamentos.length === 0) {
                    return `
                        <div class="border rounded-3 p-3 bg-light text-muted small">
                            Nenhum acompanhamento cadastrado nesta categoria.
                        </div>
                    `;
                }

                let html = `
                    <div class="acompanhamentos-header">
                        <div>
                            <p class="acompanhamentos-header-title">Itens da categoria</p>
                            <p class="acompanhamentos-header-subtitle">
                                Selecione os acompanhamentos disponíveis para este grupo.
                            </p>
                        </div>
                        <span class="badge-rule">${acompanhamentos.length} item(ns)</span>
                    </div>

                    <div class="acompanhamentos-grid">
                `;

                acompanhamentos
                    .sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))
                    .forEach((acomp, itemIndex) => {
                        html += `
                            <div class="acompanhamento-card-option ${acomp.selecionado ? 'is-checked' : ''}" data-acompanhamento-card>
                                <div class="acompanhamento-check">
                                    ${acomp.id ? `
                                        <input type="hidden"
                                            name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Id"
                                            value="${escapeHtml(acomp.id)}"
                                            class="input-id" />
                                    ` : ''}

                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].AcompanhamentoId"
                                        value="${escapeHtml(acomp.acompanhamentoId ?? acomp.id ?? '')}"
                                        class="input-acompanhamento-id-base" />

                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Ativo"
                                        value="${acomp.ativo ? 'true' : 'false'}"
                                        class="input-ativo" />

                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Ordem"
                                        value="${acomp.ordem ?? 0}"
                                        class="input-ordem-item" />

                                    <input type="checkbox"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Selecionado"
                                        value="true"
                                        class="form-check-input input-selecionado-check"
                                        id="cat_${grupoIndex}_acom_${itemIndex}"
                                        ${acomp.selecionado ? 'checked' : ''} />
                                </div>

                                <label class="acompanhamento-card-content mb-0" for="cat_${grupoIndex}_acom_${itemIndex}">
                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Nome"
                                        value="${escapeHtml(acomp.nome ?? '')}"
                                        class="input-nome" />

                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Descricao"
                                        value="${escapeHtml(acomp.descricao ?? '')}"
                                        class="input-descricao" />

                                    <input type="hidden"
                                        name="CategoriasAcompanhamentoSelecionadas[${grupoIndex}].Acompanhamentos[${itemIndex}].Preco"
                                        value="${escapeHtml(formatarPrecoInput(acomp.preco ?? '0,00'))}"
                                        class="input-preco" />

                                    <div class="acompanhamento-card-title">${escapeHtml(acomp.nome ?? '')}</div>
                                    <div class="acompanhamento-card-description">
                                        ${escapeHtml(acomp.descricao ?? '') || 'Sem descrição cadastrada.'}
                                    </div>

                                    <div class="acompanhamento-card-meta">
                                        <span class="acompanhamento-meta-badge">R$ ${escapeHtml(formatarPrecoInput(acomp.preco ?? '0,00'))}</span>
                                    </div>
                                </label>
                            </div>
                        `;
                    });

                html += `</div>`;
                return html;
            }

            function escapeHtml(texto) {
                return String(texto ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function formatarPrecoInput(valor) {
                const numero = Number(String(valor ?? '0').replace(/\./g, '').replace(',', '.')) || 0;
                return numero.toFixed(2).replace('.', ',');
            }

            function atualizarCardSelecionado(checkbox) {
                const card = checkbox.closest('[data-acompanhamento-card]');
                if (!card) return;

                card.classList.toggle('is-checked', checkbox.checked);
            }

            function inicializarEstadoVisualAcompanhamentos(contexto) {
                contexto.querySelectorAll('.input-selecionado-check').forEach(checkbox => {
                    atualizarCardSelecionado(checkbox);
                });
            }

            function aplicarMascaraAcompanhamentos(item) {
                $(item).find('.money-acomp').mask('#.##0,00', { reverse: true });
            }

            async function buscarAcompanhamentosDaCategoria(categoriaId) {
                console.log('[FETCH] buscando acompanhamentos da categoria:', categoriaId);

                const response = await fetch(`@Url.Action("ObterAcompanhamentosPorCategoria", "Produtos", new { area = "Admin" })?categoriaId=${categoriaId}`);

                if (!response.ok) {
                    console.error('[FETCH] erro ao buscar acompanhamentos. Status:', response.status);
                    throw new Error('Não foi possível carregar os acompanhamentos.');
                }

                const json = await response.json();
                console.log('[FETCH] retorno acompanhamentos:', structuredClone(json));
                return json;
            }

            async function carregarAcompanhamentos(item, acompanhamentosExistentes = []) {
                const select = item.querySelector('.select-categoria-acompanhamento');
                const categoriaId = select.value;
                const index = Array.from(container.querySelectorAll('.categoria-acompanhamento-item')).indexOf(item);
                const inputNome = item.querySelector('.input-nome-categoria');
                const acompanhamentosBox = item.querySelector('.acompanhamentos-vinculados');

                if (!categoriaId) {
                    inputNome.value = '';
                    acompanhamentosBox.innerHTML = '';
                    atualizarResumoRegras(item);
                    syncStateFromDom('carregarAcompanhamentos-sem-categoria');
                    return;
                }

                try {
                    const data = await buscarAcompanhamentosDaCategoria(categoriaId);
                    inputNome.value = data.categoria?.nome ?? '';

                    const base = (data.acompanhamentos ?? []).map(ac => {
                        const existente = acompanhamentosExistentes.find(x =>
                            (x.acompanhamentoId || x.id) === ac.id
                        );

                        return {
                            id: existente?.id ?? '',
                            acompanhamentoId: ac.id,
                            nome: existente?.nome ?? ac.nome,
                            descricao: existente?.descricao ?? ac.descricao,
                            preco: existente?.preco ?? ac.preco,
                            ativo: existente?.ativo ?? ac.ativo,
                            ordem: existente?.ordem ?? ac.ordem,
                            selecionado: existente?.selecionado ?? false
                        };
                    });

                    acompanhamentosExistentes.forEach(existente => {
                        const jaExiste = base.some(x => x.acompanhamentoId === existente.acompanhamentoId);
                        if (!jaExiste) {
                            base.push(existente);
                        }
                    });

                    acompanhamentosBox.innerHTML = montarHtmlAcompanhamentos(base, index);
                    inicializarEstadoVisualAcompanhamentos(acompanhamentosBox);
                    reindexar();
                    syncStateFromDom('carregarAcompanhamentos');
                } catch (error) {
                    console.error('[LOAD] erro em carregarAcompanhamentos:', error);
                    acompanhamentosBox.innerHTML = `<div class="alert alert-danger mb-0">Não foi possível carregar os acompanhamentos.</div>`;
                }
            }

            function adicionarGrupoVazio() {
                const index = obterProximoIndice();
                const html = template.replaceAll('__index__', index);
                container.insertAdjacentHTML('beforeend', html);

                const item = container.lastElementChild;
                item.dataset.grupoId = crypto.randomUUID();
                item.querySelector('.input-produto-id').value = produtoId || '';

                console.log('[ADD] novo grupo criado. index:', index, 'grupoId:', item.dataset.grupoId);

                atualizarResumoRegras(item);
                atualizarMensagemVazia();
                reindexar();
                syncStateFromDom('adicionarGrupoVazio');
            }

            async function adicionarGrupoExistente(grupo) {
                const index = obterProximoIndice();
                const html = template.replaceAll('__index__', index);
                container.insertAdjacentHTML('beforeend', html);

                const item = container.lastElementChild;
                item.dataset.grupoId = grupo.id ?? crypto.randomUUID();

                console.log('[INIT] adicionando grupo existente:', structuredClone(grupo));

                item.querySelector('.input-produto-id').value = grupo.produtoId ?? '';
                item.querySelector('.select-categoria-acompanhamento').value = grupo.acompanhamentoCategoriaId ?? '';
                item.querySelector('.input-obrigatorio-checkbox').checked = !!grupo.obrigatorio;
                item.querySelector('.input-min').value = grupo.minSelecionados ?? 0;
                item.querySelector('.input-max').value = grupo.maxSelecionados ?? 1;
                item.querySelector('.input-ordem').value = grupo.ordem ?? 0;
                item.querySelector('.input-nome-categoria').value = grupo.nomeCategoria ?? '';

                atualizarResumoRegras(item);

                const acompanhamentosExistentes = (grupo.produtoAcompanhamentos ?? []).map(x => ({
                    id: x.id ?? '',
                    acompanhamentoId: x.acompanhamentoId,
                    nome: x.nome ?? '',
                    descricao: x.descricao ?? '',
                    preco: x.preco ?? '0,00',
                    ativo: x.ativo ?? true,
                    ordem: x.ordem ?? 0,
                    selecionado: x.selecionado ?? true
                }));

                await carregarAcompanhamentos(item, acompanhamentosExistentes);

                atualizarMensagemVazia();
                reindexar();
                syncStateFromDom('adicionarGrupoExistente');
            }

            async function carregarPersonalizacaoInicial() {
                if (!produtoId) {
                    console.warn('[INIT] produtoId vazio');
                    atualizarMensagemVazia();
                    atualizarJsonPersonalizacao('carregarPersonalizacaoInicial-sem-produto');
                    return;
                }

                try {
                    const url = `@Url.Action("ObterPersonalizacao", "Produtos", new { area = "Admin" })/${produtoId}`;
                    console.log('[INIT] carregando personalização inicial:', url);

                    const response = await fetch(url);

                    if (!response.ok) {
                        console.error('[INIT] erro ao carregar personalização. Status:', response.status);
                        throw new Error('Erro ao carregar personalização.');
                    }

                    const data = await response.json();
                    const grupos = data?.produtoAcompanhamentoCategorias ?? [];

                    console.log('[INIT] JSON inicial recebido:', structuredClone(data));
                    console.log('[INIT] total grupos iniciais:', grupos.length);

                    container.innerHTML = '';

                    for (const grupo of grupos.sort((a, b) => (a.ordem ?? 0) - (b.ordem ?? 0))) {
                        await adicionarGrupoExistente(grupo);
                    }

                    atualizarMensagemVazia();
                    syncStateFromDom('carregarPersonalizacaoInicial');
                } catch (error) {
                    console.error('[INIT] falha ao carregar personalização inicial:', error);
                    container.innerHTML = '';
                    atualizarMensagemVazia();
                    atualizarJsonPersonalizacao('carregarPersonalizacaoInicial-erro');
                }
            }

            btnAdicionar.addEventListener('click', function () {
                console.log('[EVENT] click em Novo Grupo');
                adicionarGrupoVazio();
            });

            container.addEventListener('click', function (e) {
                const btnRemoverGrupo = e.target.closest('.btnRemoverCategoriaAcompanhamento');
                if (btnRemoverGrupo) {
                    const grupo = btnRemoverGrupo.closest('.categoria-acompanhamento-item');
                    console.log('[EVENT] removendo grupo. grupoId:', grupo?.dataset?.grupoId);
                    grupo.remove();
                    reindexar();
                    atualizarMensagemVazia();
                    syncStateFromDom('removerGrupo');
                    return;
                }

                const btnRemoverAcompanhamento = e.target.closest('.btn-remover-acompanhamento');
                if (btnRemoverAcompanhamento) {
                    const linha = btnRemoverAcompanhamento.closest('.acompanhamento-item-row');
                    console.log('[EVENT] removendo acompanhamento da linha:', linha);
                    linha.remove();
                    reindexar();
                    syncStateFromDom('removerAcompanhamento');
                }
            });

            container.addEventListener('change', async function (e) {
                const item = e.target.closest('.categoria-acompanhamento-item');
                if (!item) return;

                console.log('[EVENT][change] classe alvo:', e.target.className, 'valor:', e.target.value);

                if (e.target.classList.contains('select-categoria-acompanhamento')) {
                    await carregarAcompanhamentos(item, []);
                    return;
                }

                if (
                    e.target.classList.contains('input-min') ||
                    e.target.classList.contains('input-max') ||
                    e.target.classList.contains('input-ordem') ||
                    e.target.classList.contains('input-obrigatorio-checkbox') ||
                    e.target.classList.contains('input-selecionado-check') ||
                    e.target.classList.contains('input-ativo') ||
                    e.target.classList.contains('input-ordem-item')
                ) {
                    atualizarResumoRegras(item);
                    syncStateFromDom('change');
                }
            });

            container.addEventListener('input', function (e) {
                if (
                    e.target.classList.contains('input-nome') ||
                    e.target.classList.contains('input-descricao') ||
                    e.target.classList.contains('input-preco') ||
                    e.target.classList.contains('input-min') ||
                    e.target.classList.contains('input-max') ||
                    e.target.classList.contains('input-ordem')
                ) {
                    console.log('[EVENT][input] classe alvo:', e.target.className, 'valor:', e.target.value);
                    syncStateFromDom('input');
                }
            });

            $('#formProdutoEdit').submit(function (e) {
                const inputFile = document.getElementById('imagemForm');
                const file = inputFile?.files && inputFile.files[0];
                const maxSize = 3 * 1024 * 1024; // 3MB

                if (file && file.size > maxSize) {
                    e.preventDefault();

                    if (typeof uiNotify !== 'undefined' && uiNotify.alert) {
                        uiNotify.alert.error('A imagem deve ter no máximo 2MB.');
                    } else {
                        alert('A imagem deve ter no máximo 2MB.');
                    }

                    return false;
                }

                console.log('[SUBMIT] submit iniciado');
                reindexar();
                syncStateFromDom('submit');
                $('#feedbackMessages').remove();

                if ($(this).valid()) {
                    if (typeof window.addLoading === 'function') {
                        window.addLoading('Salvando produto...');
                    }
                }
            });

            carregarPersonalizacaoInicial();
        });
