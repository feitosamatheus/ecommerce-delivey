@using Ecommerce.MVC.Enums
@using static Ecommerce.MVC.Areas.Admin.Controllers.BalcaoController
@model PedidosViewModel
<style>
    .modal-backdrop {
        background-color: rgba(0, 0, 0, 0.5) !important; /* Cor preta com 50% de opacidade */
        transition: background-color 0.3s ease; /* Efeito de transição suave */
    }

</style>

<!-- CARD FILTRO -->
<div class="card shadow-sm border-0 mb-3">
    <div class="card-header bg-white">
        <strong>Filtros</strong>
    </div>
    <div class="card-body">
        <form method="get" id="filtro-data-form">
            <div class="row g-2">
                <div class="col-md-3">
                    <label for="dataInicio" class="form-label">De:</label>
                    <input type="date" id="dataInicio" name="dataInicio" class="form-control"
                           value="@Model.DataInicio?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="dataFim" class="form-label">Até:</label>
                    <input type="date" id="dataFim" name="dataFim" class="form-control"
                           value="@Model.DataFim?.ToString("yyyy-MM-dd")" />
                </div>

                <div class="col-md-3">
                    <label for="nomeCliente" class="form-label">Nome do Cliente:</label>
                    <input type="text" id="nomeCliente" name="nomeCliente"
                           class="form-control" value="@Model.NomeCliente" 
                           placeholder="Digite o nome do cliente" />
                </div>

                <div class="col-md-3">
                    <label for="numeroPedido" class="form-label">Número do Pedido:</label>
                    <input type="text" id="numeroPedido" name="numeroPedido"
                           class="form-control" value="@Model.NumeroPedido" 
                           placeholder="Digite o número do pedido" />
                </div>

                <div class="col-12 d-flex justify-content-end mt-2">
                    <div class="col-xl-3 d-flex  align-items-end gap-2">
                        <a href="@Url.Action("Prontos")" class="btn btn-filter-outline btn-filter-action w-100">
                             <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action w-100">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- CARD RESULTADO -->
<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div class="col-6 d-flex justify-content-start">
            <strong>Pedidos Prontos</strong>
        </div>

        <div class="col-6 d-flex justify-content-end">
            <span class="badge bg-secondary text-end contador-pill">
                @Model.PedidosProntos.Count
            </span>

        </div>
    </div>

    <div class="card-body">

        @if (Model.PedidosProntos.Any())
        {
            <div class="row g-3">
                @foreach (var pedido in Model.PedidosProntos)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="border rounded-3 p-3 h-100 bg-white shadow-sm">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <div class="fw-bold">Pedido @pedido.Codigo</div>
                                    <div class="text-muted small">@pedido.Cliente?.Nome</div>
                                </div>

                                <span class="badge bg-success">Pronto</span>
                            </div>

                            <div class="small text-muted mb-2">
                                <div><strong>Entrega:</strong> @pedido.MetodoEntrega</div>
                                <div><strong>Retirada:</strong> @pedido.HorarioRetirada.ToUniversalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div><strong>Criado em:</strong> @pedido.CriadoEmUtc.ToUniversalTime().ToString("dd/MM/yyyy HH:mm")</div>
                                <div><strong>Pronto em:</strong> @(pedido.ProntoEmUtc.HasValue? pedido.ProntoEmUtc.Value.ToUniversalTime().ToString("dd/MM/yyyy HH:mm") : "-")</div>
                            </div>

                            @if (User.IsInRole("administrador") || User.IsInRole("balcaoN2"))
                            {
                                <div class="d-flex gap-2">
                                    <div class="col-6">
                                        <form asp-action="VoltarParaEmPreparo" method="post">
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                            <input type="hidden" name="id" value="@pedido.Id" />
                                            <button type="submit" class="btn btn-outline-secondary btn-sm w-100">
                                                <i class="bi bi-arrow-left"></i> Voltar
                                            </button>
                                        </form>
                                    </div>
                                    <div class="col-6">
                                        <button type="button"
                                            class="btn btn-dark btn-sm w-100"
                                            data-bs-toggle="modal"
                                            data-bs-target="#modalDetalhes"
                                            data-id="@pedido.Id">
                                            Abrir pedido
                                        </button>
                                    </div>
                                </div>
                            }
                            else{
                                <div class="d-flex gap-2">
                                    <button type="button"
                                        class="btn btn-dark btn-sm w-100"
                                        data-bs-toggle="modal"
                                        data-bs-target="#modalDetalhes"
                                        data-id="@pedido.Id">
                                        Abrir pedido
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-muted">Nenhum pedido pronto no momento.</div>
        }

    </div>
</div>

<!-- Modal de Detalhes -->
<div class="modal fade" id="modalDetalhes" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" id="conteudoModalPedido">
            <div class="modal-body text-center py-5">
                <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
            </div>
        </div>
    </div>
</div>

<!-- Incluindo o jQuery CDN -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<!-- Incluindo o Bootstrap 5 CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">

<!-- Incluindo o Bootstrap 5 JavaScript CDN -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <script>

        // Evento para carregar detalhes do pedido no modal
        $('#modalDetalhes').on('show.bs.modal', function (event) {
            debugger
            var button = $(event.relatedTarget); // Botão que acionou o modal
            var pedidoId = button.data('id'); // Obtém o ID do pedido

            // Fazer a requisição AJAX para pegar os detalhes do pedido
            $.ajax({
                url: '/Admin/Balcao/Detalhes', // URL da action para pegar os detalhes do pedido
                method: 'GET',
                data: { id: pedidoId },
                success: function (data) {
                    // Preencher o conteúdo do modal com os dados recebidos
                    $('#conteudoModalPedido').html(data);

                    // Agora que o conteúdo foi carregado, abrir o modal
                    $('#modalDetalhes').modal('show');
                },
                error: function () {
                    $('#modalDetalhesContent').html('<p>Erro ao carregar os detalhes.</p>');
                }
            });
        });

        let pedidoConcluidoComSucesso = false;

        $(document).on('click', '#btnConcluirPedido', function () {
            var pedidoId = $(this).data('id');

            $.ajax({
                url: '/Admin/Balcao/ConcluirPedido',
                method: 'POST',
                data: { id: pedidoId },
                success: function (response) {

                    pedidoConcluidoComSucesso = true;

                    $('#statusPedidoFeedback').html(
                        '<div class="alert alert-success">Pedido concluído com sucesso!</div>'
                    );
                },
                error: function () {
                    $('#statusPedidoFeedback').html(
                        '<div class="alert alert-danger">Erro ao concluir o pedido.</div>'
                    );
                }
            });
        });
        
         // Evento para o botão "Adicionar Pagamento"
        $(document).on('click', '#btnAdicionarPagamento', function () {
            var pedidoId = $(this).data('id'); // Obtém o ID do pedido

            // Fazer a requisição AJAX para pegar os detalhes do pagamento
            $.ajax({
                url: '/Admin/Balcao/AdicionarPagamento', // URL da action para pegar os detalhes do pagamento
                method: 'GET',
                data: { id: pedidoId },
                success: function (data) {
                    // Preencher o conteúdo de pagamentoContent com os dados recebidos
                    $('#pagamentoContent').html(data);
                    configurarMascaraPagamento();
                },
                error: function () {
                    $('#pagamentoContent').html('<div class="alert alert-danger">Erro ao carregar os detalhes do pagamento.</div>');
                }
            });
        });

        // Evento para o botão "Cancelar Pedido"
        $(document).on('click', '#btnCancelarPedido', function () {
            var pedidoId = $(this).data('id'); // Obtém o ID do pedido

            // Fazer requisição AJAX para cancelar o pedido
            $.ajax({
                url: '/Admin/Balcao/CancelarPedido', // URL da ação para cancelar o pedido
                method: 'POST',
                data: { id: pedidoId },
                success: function (response) {
                    $('#statusPedidoFeedback').html('<div class="alert alert-danger">Pedido cancelado com sucesso!</div>');
                },
                error: function () {
                    $('#statusPedidoFeedback').html('<div class="alert alert-danger">Erro ao cancelar o pedido.</div>');
                }
            });
        });

        $(document).on('submit', '#formAdicionarPagamento', function (e) {
            e.preventDefault();

            var form = $(this);
            var url = form.attr('action');
            var data = form.serialize();
            var pedidoId = form.find('input[name="PedidoId"]').val();

            $.ajax({
                url: url,
                method: 'POST',
                data: data,
                success: function (response) {

                    // opcional: mensagem rápida
                    $('#pagamentoContent').html(
                        '<div class="alert alert-success">Pagamento adicionado com sucesso!</div>'
                    );

                    // recarregar os detalhes do pedido
                    $.ajax({
                        url: '/Admin/Balcao/Detalhes',
                        method: 'GET',
                        data: { id: pedidoId },
                        success: function (data) {
                            $('#conteudoModalPedido').html(data);
                        },
                        error: function () {
                            $('#conteudoModalPedido').html(
                                '<div class="alert alert-danger">Erro ao recarregar pedido.</div>'
                            );
                        }
                    });
                },
                error: function () {
                    $('#pagamentoContent').html(
                        '<div class="alert alert-danger">Erro ao salvar pagamento.</div>'
                    );
                }
            });
        });

        $('#modalDetalhes').on('hidden.bs.modal', function () {

            if (pedidoConcluidoComSucesso) {
                pedidoConcluidoComSucesso = false;

                // submete o filtro atual
                $('#filtro-data-form').submit();
            }

        });

        function aplicarMascaraMoeda(input) {
            let valor = input.value.replace(/\D/g, '');

            if (!valor) {
                input.value = '';
                return;
            }

            valor = (parseInt(valor, 10) / 100).toLocaleString('pt-BR', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });

            input.value = 'R$ ' + valor;
        }

        function configurarMascaraPagamento() {
            const input = document.getElementById('valorPagamento');

            if (!input) return;

            input.oninput = function () {
                aplicarMascaraMoeda(this);
            };

            input.onblur = function () {
                aplicarMascaraMoeda(this);
            };

            if (input.value) {
                aplicarMascaraMoeda(input);
            }
        }
    
        $(document).on('click', '.btnExcluirPagamento, .btnExcluirPagamentoComSenha', function () {
            var pagamentoId = $(this).data('id');
            var pedidoId = $(this).data('pedido-id');
            var modalElement = document.querySelector('.modal.show');

            function reativarModal() {
                if (!modalElement) return;

                modalElement.removeAttribute('inert');

                setTimeout(() => {
                    modalElement.focus();

                    const primeiroElemento =
                        modalElement.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');

                    if (primeiroElemento) {
                        primeiroElemento.focus();
                    }
                }, 150);
            }

            if (modalElement) {
                modalElement.setAttribute('inert', '');
            }

            $.ajax({
                url: '/Admin/Balcao/ListarAdministradores',
                method: 'GET'
            }).done(function (admins) {
                let options = '<option value="">Selecione um administrador</option>';

                admins.forEach(function (admin) {
                    options += `<option value="${admin.id}">${admin.nome}</option>`;
                });

                Swal.fire({
                    title: 'Excluir pagamento?',
                    text: 'Selecione o administrador e digite a senha para confirmar a exclusão.',
                    icon: 'warning',
                    html: `
                        <div class="mb-3 text-start">
                            <label for="swalAdminId" class="form-label fw-bold">Administrador</label>
                            <select id="swalAdminId" class="swal2-select" style="display:flex; width:100%; margin:0;">
                                ${options}
                            </select>
                        </div>
                        <div class="text-start">
                            <label for="swalAdminSenha" class="form-label fw-bold">Senha</label>
                            <input id="swalAdminSenha"
                                type="password"
                                class="swal2-input"
                                placeholder="Senha do administrador"
                                style="display:flex; width:100%; margin:0;" />
                        </div>
                    `,
                    showCancelButton: true,
                    confirmButtonText: 'Sim, excluir',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true,
                    confirmButtonColor: '#dc3545',
                    cancelButtonColor: '#6c757d',
                    heightAuto: false,
                    focusConfirm: false,
                    didOpen: () => {
                        setTimeout(() => {
                            const select = document.getElementById('swalAdminId');
                            if (select) select.focus();
                        }, 100);
                    },
                    didClose: () => {
                        reativarModal();
                    },
                    preConfirm: () => {
                        const adminId = document.getElementById('swalAdminId')?.value;
                        const senha = document.getElementById('swalAdminSenha')?.value;

                        if (!adminId) {
                            Swal.showValidationMessage('Selecione um administrador.');
                            return false;
                        }

                        if (!senha || !senha.trim()) {
                            Swal.showValidationMessage('Digite a senha do administrador.');
                            return false;
                        }

                        return $.ajax({
                            url: '/Admin/Balcao/ExcluirPagamento',
                            method: 'POST',
                            data: {
                                id: pagamentoId,
                                adminId: adminId,
                                senha: senha
                            }
                        }).catch(function (xhr) {
                            let mensagem = 'Não foi possível excluir o pagamento.';

                            if (xhr.responseJSON && xhr.responseJSON.message) {
                                mensagem = xhr.responseJSON.message;
                            }

                            Swal.showValidationMessage(mensagem);
                        });
                    }
                }).then((result) => {
                    if (!result.isConfirmed) return;

                    Swal.fire({
                        title: 'Excluído!',
                        text: 'O pagamento foi excluído com sucesso.',
                        icon: 'success',
                        confirmButtonText: 'OK'
                    }).then(() => {
                        $('#statusPedidoFeedback').html(
                            '<div class="alert alert-success">Pagamento excluído com sucesso!</div>'
                        );

                        $.ajax({
                            url: '/Admin/Balcao/Detalhes',
                            method: 'GET',
                            data: { id: pedidoId },
                            success: function (data) {
                                $('#conteudoModalPedido').html(data);
                                reativarModal();
                            },
                            error: function () {
                                $('#conteudoModalPedido').html(
                                    '<div class="alert alert-danger">Erro ao recarregar pedido.</div>'
                                );
                                reativarModal();
                            }
                        });
                    });
                });
            }).fail(function () {
                reativarModal();

                Swal.fire({
                    title: 'Erro!',
                    text: 'Não foi possível carregar a lista de administradores.',
                    icon: 'error',
                    confirmButtonText: 'OK'
                });
            });
        });
    </script>
}