@model Ecommerce.MVC.Models.Admin.Categorias.CategoriaFormViewModel

@{
    ViewData["Title"] = "Editar Categoria";
    ViewData["Description"] = "Atualize o nome e as configurações de exibição desta categoria.";
}

<style>
    /* Design System Barriga Cheia */
    .card-form-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.6rem 0.75rem;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: none;
        }

    .btn-action {
        border-radius: 0.5rem;
        padding: 0.6rem 1rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
</style>

<div class="container-fluid px-0">
    @* Cabeçalho *@
    <div class="w-100 d-flex justify-content-start align-items-center mb-4">
        <a asp-action="Index" class="btn btn-light btn-sm border text-muted btn-action" style="border-radius: 0.5rem; padding: 0.6rem 1rem;">
            <i class="fas fa-arrow-left"></i> Voltar
        </a>
    </div>

    @* Card do Formulário Integrado *@
    <div class="card card-form-clean">
        <div class="card-body p-4 pb-3">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                
                @* Campo oculto para o GUID *@
                <input asp-for="Id" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 small"></div>

                <div class="row g-4">
                    @* Nome da Categoria *@
                    <div class="col-md-7">
                        <label asp-for="Nome" class="form-label">Nome da Categoria</label>
                        <input asp-for="Nome" class="form-control" placeholder="Ex: Pizzas, Bebidas, Combos..." />
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    @* Tipo de Exibição *@
                    <div class="col-md-5">
                        <label asp-for="TipoExibicao" class="form-label">Tipo de Exibição no App</label>
                        <select asp-for="TipoExibicao" asp-items="Model.TiposExibicao" class="form-select">
                            <option value="">Selecione o modo de exibição...</option>
                        </select>
                        <span asp-validation-for="TipoExibicao" class="text-danger small"></span>
                    </div>

                    @* Rodapé de Ações *@
                    <div class="col-12 mt-5 d-flex justify-content-end gap-2 border-top pt-3">
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-bold px-4">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary shadow-sm btn-action">
                            <i class="fas fa-save"></i> Salvar Alterações
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}