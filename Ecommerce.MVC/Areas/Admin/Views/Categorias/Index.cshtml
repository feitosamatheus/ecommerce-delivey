@model Ecommerce.MVC.Models.Admin.Categorias.CategoriasIndexViewModel

@{
    ViewData["Title"] = "Categorias";
    ViewData["Description"] = "Gerencie as categorias principais de produtos da loja.";
}

<style>
    /* Design System Barriga Cheia */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .card-filter-clean .form-control,
    .card-filter-clean .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
    }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        text-decoration: none;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
    }

    .mobile-order-item {
        padding: 1rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .img-product-thumb {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 0.5rem;
        border: 1px solid #e2e8f0;
        background-color: #f8f9fa;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-white {
        background: #fff;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
    }
    .btn-white:hover { background: #f8fafc; }

    @@media (max-width: 767.98px) {
        .d-none-mobile { display: none !important; }
    }
</style>

<div class="container-fluid px-0">
    @* Cabeçalho *@
    <div class="w-100 d-flex justify-content-between align-items-center mb-3">
        <h2 class="fs-4 fw-bold mb-0 text-dark"></h2>
        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm btn-filter-action">
                <i class="fas fa-plus"></i> Nova Categoria
            </a>
        </div>
    </div>

    @* Mensagens de Feedback *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
    }

    @* Filtros *@
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center py-2">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i> Filtros de Pesquisa
            </h3>
            <div class="card-tools ms-auto">
                <button type="button" class="btn btn-link btn-sm text-muted" data-lte-toggle="card-collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-xl-9">
                        <label class="form-label">Buscar por Nome</label>
                        <input type="text" name="busca" class="form-control"
                               placeholder="Ex: Pizzas, Bebidas, Sobremesas..." value="@Model.Busca">
                    </div>
                    <div class="col-xl-3 d-flex align-items-end justify-content-start gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-filter-outline btn-filter-action w-100">
                            <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action w-100">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* Tabela/Lista *@
    <div class="card card-table-clean overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center row">
            <h3 class="card-title fs-6 fw-bold mb-0 col-6">
                <i class="fas fa-list me-2 text-primary"></i> Listagem de Categorias
            </h3>
            <div class="col-6 d-flex justify-content-end">
                <span class="badge bg-primary-subtle text-primary rounded-pill">@Model.Categorias.Count() categorias</span>
            </div>
        </div>

        <div class="card-body p-0">
            @if (Model.Categorias.Any())
            {
                @* Versão Desktop *@
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover align-middle mb-0 table-clean">
                        <thead>
                            <tr>
                                <th class="ps-4">Nome</th>
                                <th>Tipo de Exibição</th>
                                <th class="text-center">Qtd. Produtos</th>
                                <th class="text-end pe-4" style="width: 120px;">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Categorias)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <span class="fw-bold text-dark">@item.Nome</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-muted border">@item.TipoExibicao</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="text-muted">@item.Produtos.Count itens</span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary">
                                                <i class="fas fa-pen"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-categoria" data-id="@item.Id">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                        <form id="form-delete-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                            @Html.AntiForgeryToken()
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Versão Mobile *@
                <div class="d-md-none">
                    @foreach (var item in Model.Categorias)
                    {
                        <div class="mobile-order-item">
                            <div class="img-product-thumb">
                                <i class="fas fa-folder text-primary"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-bold text-dark">@item.Nome</div>
                                        <small class="text-muted">Exibição: @item.TipoExibicao</small>
                                        <div class="small text-muted">@item.Produtos.Count produtos vinculados</div>
                                    </div>
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-categoria" data-id="@item.Id">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-folder-open fa-3x text-light mb-3"></i>
                    <p class="text-muted">Nenhuma categoria encontrada.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            $(".btn-excluir-categoria").on("click", function () {
                const id = $(this).data("id");
                
                Swal.fire({
                    title: 'Remover Categoria?',
                    text: "Isso pode afetar os produtos vinculados a ela. Deseja continuar?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#2c180d',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sim, remover!',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (typeof window.addLoading === "function") {
                            window.addLoading("Removendo...");
                        }
                        $(`#form-delete-${id}`).submit();
                    }
                });
            });
        });
    </script>
}