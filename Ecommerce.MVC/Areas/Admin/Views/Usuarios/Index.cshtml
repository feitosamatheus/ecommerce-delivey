@using static UsuariosController
@model UsuariosIndexViewModel
@{
    ViewData["Title"] = "Usuários e Permissões";
    ViewData["Description"] = "Gerencie os acessos de clientes, administradores e equipe da cozinha.";
}

<style>
    /* Design System Barriga Cheia */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .card-filter-clean .form-control,
    .card-filter-clean .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
    }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        text-decoration: none;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .badge-status {
        font-weight: 600;
        padding: 0.35em 0.65em;
        border-radius: 0.375rem;
    }

    .btn-white {
        background: #fff;
        border: 1px solid #e2e8f0;
        transition: all 0.2s ease;
    }
    .btn-white:hover { background: #f8fafc; }

    /* Paginação Customizada */
    .pagination .page-link {
        border-radius: 0.5rem !important;
        margin: 0 2px;
        border: 1px solid #e2e8f0;
        min-width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        color: #64748b;
    }

    .pagination .page-item.active .page-link {
        background-color: #2c180d; /* Cor do seu tema */
        border-color: #2c180d;
        color: #fff;
    }

    /* Layout Mobile */
    .mobile-user-item {
        padding: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .user-avatar-circle {
        width: 45px; height: 45px;
        background-color: #f1f5f9;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #64748b; font-weight: bold;
    }

    @@media (max-width: 767.98px) {
        .d-none-mobile { display: none !important; }
    }
</style>

<div class="container-fluid px-0">
    <div class="w-100 d-flex justify-content-between align-items-center mb-3">
        <h2 class="fs-4 fw-bold mb-0 text-dark">Gestão de Usuários</h2>
        <a asp-action="Create" class="btn btn-primary btn-sm shadow-sm btn-filter-action">
            <i class="fas fa-user-plus"></i> Novo Usuário
        </a>
    </div>
    <div id="feedbackMessages">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
        }
    </div>
    @* Filtros *@
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center py-2">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i> Filtros de Pesquisa
            </h3>
        </div>
        <div class="card-body">
            <form method="get">
                <div class="row g-3">
                    <div class="col-xl-5">
                        <label class="form-label">Nome, E-mail ou CPF</label>
                        <input type="text" name="busca" class="form-control" placeholder="Pesquisar..." value="@Model.Busca">
                    </div>
                    <div class="col-xl-4">
                        <label class="form-label">Nível de Acesso (Role)</label>
                        <select name="role" class="form-select">
                            <option value="">Todos os níveis</option>
                            <option value="Cliente" selected="@(Model.Role == "Cliente")">Cliente</option>
                            <option value="administrador" selected="@(Model.Role == "administrador")">Administrador</option>
                            <option value="gerente" selected="@(Model.Role == "gerente")">Gerente</option>
                            <option value="atendente" selected="@(Model.Role == "atendente")">Atendente</option>
                            <option value="cozinha" selected="@(Model.Role == "cozinha")">Cozinha</option>
                        </select>
                    </div>
                    <div class="col-xl-3 d-flex align-items-end gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-filter-outline btn-filter-action w-100">
                             <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action w-100">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @* Tabela *@
    <div class="card card-table-clean">
        <div class="card-header bg-white py-3 border-bottom-0 d-flex justify-content-between align-items-center row">
            <h3 class="card-title fs-6 fw-bold mb-0 col-6">
                <i class="fas fa-users me-2 text-primary"></i> Usuários Cadastrados
            </h3>
            <div class="col-6 d-flex justify-content-end">
                <span class="badge bg-primary-subtle text-primary rounded-pill">@Model.Itens.Count() registros</span>
            </div>
        </div>

        <div class="card-body p-0">
            @if (Model.Itens.Any())
            {
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-hover align-middle mb-0 table-clean">
                        <thead>
                            <tr class="text-muted small text-uppercase">
                                <th class="ps-4">Nome / E-mail</th>
                                <th>CPF</th>
                                <th>Nível</th>
                                <th class="text-center">Status</th>
                                <th class="text-end pe-4">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Itens)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark">@item.Nome</div>
                                        <small class="text-muted">@item.Email</small>
                                    </td>
                                    <td><code class="text-secondary">@item.CPF</code></td>
                                    <td>
                                        <span class="badge bg-info-subtle text-info text-uppercase" style="font-size: 0.7rem;">
                                            <i class="fas fa-shield-alt me-1"></i> @item.Role
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @(item.Ativo ? "bg-success-subtle text-success" : "bg-light text-muted") badge-status">
                                            @(item.Ativo ? "Ativo" : "Inativo")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary"><i class="fas fa-pen"></i></a>
                                            <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-usuario" data-id="@item.Id"><i class="fas fa-trash"></i></button>
                                        </div>
                                        <form id="form-delete-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">@Html.AntiForgeryToken()</form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @* Mobile *@
                <div class="d-md-none">
                    @foreach (var item in Model.Itens)
                    {
                        <div class="mobile-user-item">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <div class="user-avatar-circle">@item.Nome.Substring(0, 1).ToUpper()</div>
                                <div class="flex-grow-1">
                                    <div class="fw-bold text-dark">@item.Nome</div>
                                    <div class="small text-muted">@item.Email</div>
                                </div>
                                <span class="badge @(item.Ativo ? "bg-success-subtle text-success" : "bg-light text-muted") badge-status">@(item.Ativo ? "Ativo" : "Inativo")</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="badge bg-info-subtle text-info text-uppercase" style="font-size: 0.65rem;">@item.Role</span>
                                <div class="btn-group shadow-sm">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-primary"><i class="fas fa-pen"></i></a>
                                    <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-usuario" data-id="@item.Id"><i class="fas fa-trash"></i></button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="fas fa-user-slash fa-3x text-light mb-3"></i>
                    <p class="text-muted">Nenhum usuário encontrado.</p>
                </div>
            }
        </div>

        @* Paginação *@
        @if (Model.TotalPaginas > 1)
        {
            <div class="card-footer bg-white border-top-0 py-4">
                <nav>
                    <ul class="pagination pagination-sm justify-content-center justify-content-md-end mb-0 gap-1">
                        
                        <li class="page-item @(Model.PaginaAtual == 1 ? "disabled" : "")">
                            <a class="page-link shadow-sm btn-white" 
                               href="@Url.Action("Index", new { pagina = Model.PaginaAtual - 1, busca = Model.Busca, role = Model.Role })">
                                <i class="fas fa-chevron-left"></i>
                            </a>
                        </li>

                        @for (int i = 1; i <= Model.TotalPaginas; i++)
                        {
                            <li class="page-item @(i == Model.PaginaAtual ? "active" : "")">
                                <a class="page-link shadow-sm @(i == Model.PaginaAtual ? "" : "btn-white")" 
                                   href="@Url.Action("Index", new { pagina = i, busca = Model.Busca, role = Model.Role })">
                                    @i
                                </a>
                            </li>
                        }

                        <li class="page-item @(Model.PaginaAtual == Model.TotalPaginas ? "disabled" : "")">
                            <a class="page-link shadow-sm btn-white" 
                               href="@Url.Action("Index", new { pagina = Model.PaginaAtual + 1, busca = Model.Busca, role = Model.Role })">
                                <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            $(".btn-excluir-usuario").on("click", function () {
                const id = $(this).data("id");
                Swal.fire({
                    title: 'Remover Usuário?',
                    text: "O acesso será revogado imediatamente.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#2c180d',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sim, remover!',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (typeof window.addLoading === "function") window.addLoading("Removendo...");
                        $(`#form-delete-${id}`).submit();
                    }
                });
            });
        });
    </script>
}