@model IEnumerable<Ecommerce.MVC.Entities.Pedido>

@{
    ViewData["Title"] = "Pedidos - Admin";
}

<div class="container my-4">
    <h2 class="h4 mb-3">Pedidos recentes</h2>

    <div class="table-responsive bg-white rounded-3 shadow-sm">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Código</th>
                    <th>Cliente</th>
                    <th>Data</th>
                    <th class="text-end">Total</th>
                    <th>Status</th>
                    <th style="width:1%;"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in Model)
                {
                    <tr>
                        <td>@p.Codigo</td>
                        <td>@p.Cliente?.Nome</td>
                        <td>@p.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">@p.Total.ToString("C")</td>
                        <td>@p.Status</td>
                        <td class="text-end">
                            <a asp-area="Admin" asp-controller="Pedidos" asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-secondary">
                                Detalhes
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

