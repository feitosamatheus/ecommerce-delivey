@model Ecommerce.MVC.Models.Admin.Pedidos.PedidosIndexViewModel

@{
    ViewData["Title"] = "Gerenciar Pedidos";
    ViewData["Description"] = "Gerencie e monitore os dados de Pedidos com facilidade.";
}
<style>
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .card-filter-clean .form-control,
    .card-filter-clean .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        color: #334155;
        transition: all 0.2s ease;
    }

    .card-filter-clean .form-control:focus,
    .card-filter-clean .form-select:focus {
        border-color: #94a3b8;
        box-shadow: 0 0 0 3px rgba(148, 163, 184, 0.1);
        outline: 0;
    }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
    }

    .btn-filter-outline:hover {
        background: #f8fafc;
        color: #334155;
        border-color: #cbd5e1;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .card-table-clean .card-header {
        background-color: #fff;
        border-bottom: 1px solid #f0f0f0;
        padding: 1.25rem;
    }

    .card-table-clean .card-title {
        font-weight: 600;
        color: #334155;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-top: none;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-clean tbody tr:hover {
        background-color: #f8fafc;
        transition: background-color 0.2s ease;
    }

    .badge-pill-custom {
        padding: 0.4em 0.8em;
        border-radius: 50rem;
        font-weight: 500;
        font-size: 0.85em;
    }

    .btn-action {
        border-radius: 0.5rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    @@media (max-width: 767.98px) {
        .d-mobile-block { display: block !important; }
        .d-desktop-none { display: none !important; }

        .card-body-mobile {
            padding: 0 !important;
        }
    }

    .mobile-order-item {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mobile-order-item:last-child {
        border-bottom: none;
    }

    .mobile-order-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
</style>

<div class="container-fluid my- px-0">
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i>
                Filtros de Pesquisa
            </h3>

            <div class="card-tools ms-auto">
                <button type="button"
                        class="btn btn-tool btn-collapse-filtro"
                        data-lte-toggle="card-collapse"
                        title="Recolher">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">@TempData["Error"]</div>
        }

        <div class="card-body">
            <form class="py-2" id="formFiltroPedidos" method="get" action="@Url.Action("Index", "Pedidos", new { area = "Admin" })">
                <input type="hidden" id="pagina" name="pagina" value="@Model.PaginaAtual" />
                <input type="hidden" id="sortColumn" name="sortColumn" value="@Model.SortColumn" />
                <input type="hidden" id="sortDirection" name="sortDirection" value="@Model.SortDirection" />

                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="dataInicio" class="form-label">Data inicial</label>
                        <input type="date"
                               class="form-control"
                               id="dataInicio"
                               name="dataInicio"
                               value="@((Model.DataInicio ?? DateTime.Today).ToString("yyyy-MM-dd"))">
                    </div>

                    <div class="col-md-3">
                        <label for="dataFim" class="form-label">Data final</label>
                        <input type="date"
                               class="form-control"
                               id="dataFim"
                               name="dataFim"
                               value="@((Model.DataFim ?? DateTime.Today).ToString("yyyy-MM-dd"))">
                    </div>

                    <div class="col-md-3">
                        <label for="tipoData" class="form-label">Filtrar por</label>
                        <select class="form-select" id="tipoData" name="tipoData">
                            <option value="CriadoEmUtc" selected="@(Model.TipoData == "CriadoEmUtc" || string.IsNullOrEmpty(Model.TipoData))">
                                Data do pedido
                            </option>
                            <option value="HorarioRetirada" selected="@(Model.TipoData == "HorarioRetirada")">
                                Data de retirada
                            </option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="status" class="form-label">Status do Pedido</label>
                        <select class="form-select" id="status" name="status">
                            <option value="">Todos os status</option>
                            <option value="Rascunho" selected="@(Model.Status == "Rascunho")">Rascunho</option>
                            <option value="AguardandoPagamento" selected="@(Model.Status == "AguardandoPagamento")">Aguardando pagamento</option>
                            <option value="Confirmado" selected="@(Model.Status == "Confirmado")">Confirmado</option>
                            <option value="EmPreparo" selected="@(Model.Status == "EmPreparo")">Em preparo</option>
                            <option value="Pronto" selected="@(Model.Status == "Pronto")">Pronto</option>
                            <option value="Concluido" selected="@(Model.Status == "Concluido")">Concluído</option>
                            <option value="Cancelado" selected="@(Model.Status == "Cancelado")">Cancelado</option>
                        </select>
                    </div>

                    <div class="col-md-3">
                        <label for="numeroPedido" class="form-label">Número do pedido</label>
                        <input type="text"
                               class="form-control"
                               id="numeroPedido"
                               name="numeroPedido"
                               value="@Model.NumeroPedido"
                               placeholder="Ex.: BC-2026-000123">
                    </div>

                    <div class="col-md-4">
                        <label for="cliente" class="form-label">Cliente / CPF</label>
                        <input type="text"
                            class="form-control"
                            id="cliente"
                            name="cliente"
                            value="@Model.Cliente"
                            placeholder="Digite nome ou CPF do cliente">
                    </div>
                </div>

                <hr class="my-3" style="border-top: 1px solid #f1f5f9;">

                <div class="d-flex justify-content-end align-items-center">
                    <a href="@Url.Action("Index", "Pedidos", new { area = "Admin" })"
                       id="btnLimparFiltros"
                       class="btn btn-filter-action btn-filter-outline me-2">
                        <i class="fas fa-eraser opacity-50"></i>
                        Limpar
                    </a>

                    <button type="submit" id="btnPesquisarPedidos" class="btn btn-filter-action btn-secondary shadow-sm">
                        <i class="fas fa-search"></i>
                        Aplicar Filtros
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div id="resultadoPedidos">
        @await Html.PartialAsync("_PedidosLista", Model)
    </div>
</div>

<div class="modal fade" id="modalDetalhesPedido" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" id="conteudoModalPedido">
            <div class="modal-body text-center py-5">
                <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
            </div>
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>
        $(function () {
            function aplicarMascaraCpf(valor) {
                valor = (valor || '').replace(/\D/g, '').slice(0, 11);

                if (valor.length <= 3) {
                    return valor;
                }
                if (valor.length <= 6) {
                    return valor.replace(/(\d{3})(\d+)/, '$1.$2');
                }
                if (valor.length <= 9) {
                    return valor.replace(/(\d{3})(\d{3})(\d+)/, '$1.$2.$3');
                }

                return valor.replace(/(\d{3})(\d{3})(\d{3})(\d{2}).*/, '$1.$2.$3-$4');
            }

            function configurarMascaraCpfCliente() {
                const input = document.getElementById('cliente');
                if (!input) return;

                input.addEventListener('input', function () {
                    const digits = this.value.replace(/\D/g, '');

                    // Só aplica a máscara se estiver digitando números
                    if (digits.length > 0 && /^[\d.\-]+$/.test(this.value)) {
                        this.value = aplicarMascaraCpf(this.value);
                    }
                });

                // Caso já venha preenchido com CPF ao carregar a tela
                const digitsInicial = input.value.replace(/\D/g, '');
                if (digitsInicial.length > 0 && digitsInicial.length <= 11) {
                    input.value = aplicarMascaraCpf(input.value);
                }
            }

            configurarMascaraCpfCliente();

            $("#formFiltroPedidos").on("submit", function (e, manterPagina) {
                e.preventDefault();

                const $form = $(this);
                const $btn = $form.find("#btnPesquisarPedidos");

                if (!manterPagina) {
                    $form.find("#pagina").val(1);
                }

                let url = $form.attr("action") + "?" + $form.serialize();
                url += "&tamanhoPagina=" + ($("#tamanhoPagina").val() || 5);

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Pesquisando');
                window.addLoading("Buscando pedidos...");

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (html) {
                        $("#resultadoPedidos").html(html);
                        window.history.replaceState({}, "", url);
                    },
                    error: function () {
                        alert("Não foi possível carregar os pedidos.");
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-search"></i> Aplicar Filtros');
                        window.removeLoading();
                    }
                });
            });

            $("#formFiltroPedidos").on("click", "#btnLimparFiltros", function (e) {
                e.preventDefault();

                const $form = $("#formFiltroPedidos");
                const $btn = $form.find("#btnPesquisarPedidos");
                const urlBase = $(this).attr("href");

                $form[0].reset();
                $form.find("#pagina").val(1);
                $form.find("#sortColumn").val("CriadoEmUtc");
                $form.find("#sortDirection").val("desc");

                $("#dataInicio").val('@DateTime.Today.ToString("yyyy-MM-dd")');
                $("#dataFim").val('@DateTime.Today.ToString("yyyy-MM-dd")');
                $("#tipoData").val("CriadoEmUtc");
                $("#status").val("");
                $("#numeroPedido").val("");
                $("#cliente").val("");
                $("#tamanhoPagina").val(5);

                const url = urlBase + "?" + $form.serialize() + "&tamanhoPagina=" + ($("#tamanhoPagina").val() || 5);

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Pesquisando');
                addLoading("Buscando pedidos...");

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (html) {
                        $("#resultadoPedidos").html(html);
                        window.history.replaceState({}, "", url);
                    },
                    error: function () {
                        alert("Não foi possível carregar os pedidos.");
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-search"></i> Aplicar Filtros');
                        removeLoading();
                    }
                });
            });

            $(".btn-collapse-filtro").on("click", function () {
                const $card = $(this).closest(".card");
                const $icon = $(this).find("i");
                const vaiFechar = !$card.hasClass("collapsed-card");

                $icon.attr("class", `fas fa-${vaiFechar ? "plus" : "minus"}`);
            });

            $(document).on("click", ".btn-ver-pedido", function (e) {
                e.preventDefault();

                const url = $(this).data("url");
                const modalEl = document.getElementById("modalDetalhesPedido");
                const $conteudo = $("#conteudoModalPedido");

                $conteudo.html(`
                    <div class="modal-body text-center py-5">
                        <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
                    </div>
                `);

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest" },
                    success: function (html) {
                        $conteudo.html(html);
                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    },
                    error: function () {
                        $conteudo.html(`
                            <div class="modal-header">
                                <h5 class="modal-title">Erro</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-danger mb-0">
                                    Não foi possível carregar os detalhes do pedido.
                                </div>
                            </div>
                        `);

                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    }
                });
            });

            $(document).on("click", "#btnSalvarStatus", function () {
                const $btn = $(this);
                const id = $btn.data("id");
                const status = $("#novoStatus").val();
                const $feedback = $("#statusPedidoFeedback").last();

                if (!status) {
                    $feedback.html('<div class="alert alert-warning mb-0">Selecione um status.</div>');
                    return;
                }

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-1"></i> Salvando');

                $.ajax({
                    url: '@Url.Action("AtualizarStatus", "Pedidos", new { area = "Admin" })',
                    type: "POST",
                    data: {
                        id: id,
                        status: status
                    },
                    success: function (response) {
                        if (!response.sucesso) {
                            $feedback.html('<div class="alert alert-danger mb-0">' + response.mensagem + '</div>');
                            return;
                        }

                        $feedback.html('<div class="alert alert-success mb-0">' + response.mensagem + '</div>');

                        $.ajax({
                            url: '@Url.Action("DetailsModal", "Pedidos", new { area = "Admin" })',
                            type: "GET",
                            data: { id: id },
                            success: function (html) {
                                $("#conteudoModalPedido").html(html);

                                const $novoFeedback = $("#conteudoModalPedido").find("#statusPedidoFeedback").last();
                                $novoFeedback.html('<div class="alert alert-success mb-0">' + response.mensagem + '</div>');
                            },
                            error: function () {
                                $feedback.html('<div class="alert alert-warning mb-0">Status atualizado, mas não foi possível recarregar os detalhes.</div>');
                            }
                        });
                    },
                    error: function () {
                        $feedback.html('<div class="alert alert-danger mb-0">Não foi possível atualizar o status.</div>');
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-save me-1"></i> Salvar status');
                    }
                });
            });

            $(document).on("click", ".paginacao-pedido", function (e) {
                e.preventDefault();

                const pagina = $(this).data("pagina");

                if (!pagina || $(this).closest(".page-item").hasClass("disabled") || $(this).closest(".page-item").hasClass("active"))
                    return;

                $("#pagina").val(pagina);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });

            $(document).on("change", "#tamanhoPagina", function () {
                $("#pagina").val(1);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });

            $(document).on("click", ".ordenacao-pedido", function (e) {
                e.preventDefault();

                const coluna = $(this).data("coluna");
                const $sortColumn = $("#sortColumn");
                const $sortDirection = $("#sortDirection");

                if ($sortColumn.val() === coluna) {
                    $sortDirection.val($sortDirection.val() === "asc" ? "desc" : "asc");
                } else {
                    $sortColumn.val(coluna);
                    $sortDirection.val("asc");
                }

                $("#pagina").val(1);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });

            $(document).on('click', '.btnExcluirPagamento, .btnExcluirPagamentoComSenha', function () {
                var pagamentoId = $(this).data('id');
                var pedidoId = $(this).data('pedido-id');
                var modalElement = document.querySelector('.modal.show');

                function reativarModal() {
                    if (!modalElement) return;

                    modalElement.removeAttribute('inert');

                    setTimeout(() => {
                        modalElement.focus();

                        const primeiroElemento =
                            modalElement.querySelector('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');

                        if (primeiroElemento) {
                            primeiroElemento.focus();
                        }
                    }, 150);
                }

                if (modalElement) {
                    modalElement.setAttribute('inert', '');
                }

                $.ajax({
                    url: '/Admin/Pedidos/ListarAdministradores',
                    method: 'GET'
                }).done(function (admins) {
                    let options = '<option value="">Selecione um administrador</option>';

                    admins.forEach(function (admin) {
                        options += `<option value="${admin.id}">${admin.nome}</option>`;
                    });

                    Swal.fire({
                        title: 'Excluir pagamento?',
                        text: 'Selecione o administrador e digite a senha para confirmar a exclusão.',
                        icon: 'warning',
                        html: `
                            <div class="mb-3 text-start">
                                <label for="swalAdminId" class="form-label fw-bold">Administrador</label>
                                <select id="swalAdminId" class="swal2-select" style="display:flex; width:100%; margin:0;">
                                    ${options}
                                </select>
                            </div>
                            <div class="text-start">
                                <label for="swalAdminSenha" class="form-label fw-bold">Senha</label>
                                <input id="swalAdminSenha"
                                    type="password"
                                    class="swal2-input"
                                    placeholder="Senha do administrador"
                                    style="display:flex; width:100%; margin:0;" />
                            </div>
                        `,
                        showCancelButton: true,
                        confirmButtonText: 'Sim, excluir',
                        cancelButtonText: 'Cancelar',
                        reverseButtons: true,
                        confirmButtonColor: '#dc3545',
                        cancelButtonColor: '#6c757d',
                        heightAuto: false,
                        focusConfirm: false,
                        didOpen: () => {
                            setTimeout(() => {
                                const select = document.getElementById('swalAdminId');
                                if (select) select.focus();
                            }, 100);
                        },
                        didClose: () => {
                            reativarModal();
                        },
                        preConfirm: () => {
                            const adminId = document.getElementById('swalAdminId')?.value;
                            const senha = document.getElementById('swalAdminSenha')?.value;

                            if (!adminId) {
                                Swal.showValidationMessage('Selecione um administrador.');
                                return false;
                            }

                            if (!senha || !senha.trim()) {
                                Swal.showValidationMessage('Digite a senha do administrador.');
                                return false;
                            }

                            return $.ajax({
                                url: '/Admin/Pedidos/ExcluirPagamento',
                                method: 'POST',
                                data: {
                                    id: pagamentoId,
                                    adminId: adminId,
                                    senha: senha
                                }
                            }).catch(function (xhr) {
                                let mensagem = 'Não foi possível excluir o pagamento.';

                                if (xhr.responseJSON && xhr.responseJSON.message) {
                                    mensagem = xhr.responseJSON.message;
                                }

                                Swal.showValidationMessage(mensagem);
                            });
                        }
                    }).then((result) => {
                        if (!result.isConfirmed) return;

                        Swal.fire({
                            title: 'Excluído!',
                            text: 'O pagamento foi excluído com sucesso.',
                            icon: 'success',
                            confirmButtonText: 'OK'
                        }).then(() => {
                            $('#statusPedidoFeedback').html(
                                '<div class="alert alert-success">Pagamento excluído com sucesso!</div>'
                            );

                            $.ajax({
                                url: '/Admin/Pedidos/DetailsModal',
                                method: 'GET',
                                data: { id: pedidoId },
                                success: function (data) {
                                    $('#conteudoModalPedido').html(data);
                                    reativarModal();
                                },
                                error: function () {
                                    $('#conteudoModalPedido').html(
                                        '<div class="alert alert-danger">Erro ao recarregar pedido.</div>'
                                    );
                                    reativarModal();
                                }
                            });
                        });
                    });
                }).fail(function () {
                    reativarModal();

                    Swal.fire({
                        title: 'Erro!',
                        text: 'Não foi possível carregar a lista de administradores.',
                        icon: 'error',
                        confirmButtonText: 'OK'
                    });
                });
            });

            $(document).on('click', '#btnAdicionarPagamento', function () {
                var pedidoId = $(this).data('id');

                $.ajax({
                    url: '/Admin/Balcao/AdicionarPagamento',
                    method: 'GET',
                    data: { id: pedidoId },
                    success: function (data) {
                        $('#pagamentoContent').html(data);
                        configurarMascaraPagamento();
                    },
                    error: function () {
                        $('#pagamentoContent').html('<div class="alert alert-danger">Erro ao carregar os detalhes do pagamento.</div>');
                    }
                });
            });

            $(document).on('submit', '#formAdicionarPagamento', function (e) {
                e.preventDefault();

                var form = $(this);
                var url = form.attr('action');
                var data = form.serialize();
                var pedidoId = form.find('input[name="PedidoId"]').val();

                $.ajax({
                    url: url,
                    method: 'POST',
                    data: data,
                    success: function (response) {
                        $('#pagamentoContent').html(
                            '<div class="alert alert-success">Pagamento adicionado com sucesso!</div>'
                        );

                        $.ajax({
                            url: '/Admin/Pedidos/DetailsModal',
                            method: 'GET',
                            data: { id: pedidoId },
                            success: function (data) {
                                $('#conteudoModalPedido').html(data);
                            },
                            error: function () {
                                $('#conteudoModalPedido').html(
                                    '<div class="alert alert-danger">Erro ao recarregar pedido.</div>'
                                );
                            }
                        });
                    },
                    error: function () {
                        $('#pagamentoContent').html(
                            '<div class="alert alert-danger">Erro ao salvar pagamento.</div>'
                        );
                    }
                });
            });

            $(document).on('click', '#btnCancelarPagamento', function () {
                $('#pagamentoContent').empty();
            });

            function aplicarMascaraMoeda(input) {
                let valor = input.value.replace(/\D/g, '');

                if (!valor) {
                    input.value = '';
                    return;
                }

                valor = (parseInt(valor, 10) / 100).toLocaleString('pt-BR', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });

                input.value = 'R$ ' + valor;
            }

            function configurarMascaraPagamento() {
                const input = document.getElementById('valorPagamento');

                if (!input) return;

                input.oninput = function () {
                    aplicarMascaraMoeda(this);
                };

                input.onblur = function () {
                    aplicarMascaraMoeda(this);
                };

                if (input.value) {
                    aplicarMascaraMoeda(input);
                }
            }
        });
    </script>
}