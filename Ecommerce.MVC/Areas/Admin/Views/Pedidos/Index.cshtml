@model Ecommerce.MVC.Models.Admin.Pedidos.PedidosIndexViewModel

@{
    ViewData["Title"] = "Pedidos";
    ViewData["Description"] = "Gerencie e monitore os dados de Pedidos com facilidade.";
}
<style>
    /* Estilo Clean para o Card de Filtros */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    /* Labels menores e levemente acinzentadas (estilo moderno) */
    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b; /* Slate 500 */
        margin-bottom: 0.5rem;
    }

    /* Inputs mais suaves */
    .card-filter-clean .form-control, 
    .card-filter-clean .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        color: #334155;
        transition: all 0.2s ease;
    }

    .card-filter-clean .form-control:focus, 
    .card-filter-clean .form-select:focus {
        border-color: #94a3b8;
        box-shadow: 0 0 0 3px rgba(148, 163, 184, 0.1);
        outline: 0;
    }

    /* Botões com cantos arredondados */
    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
    }

    .btn-filter-outline:hover {
        background: #f8fafc;
        color: #334155;
        border-color: #cbd5e1;
    }
    /* Customização Clean para o Card de Tabela */
    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .card-table-clean .card-header {
        background-color: #fff;
        border-bottom: 1px solid #f0f0f0;
        padding: 1.25rem;
    }

    .card-table-clean .card-title {
        font-weight: 600;
        color: #334155; /* Slate 700 */
    }

    /* Estilização da Tabela */
    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b; /* Slate 500 */
        border-top: none;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
        border-bottom: 1px solid #f1f5f9;
    }

    .table-clean tbody tr:hover {
        background-color: #f8fafc;
        transition: background-color 0.2s ease;
    }

    /* Badges mais modernas (Pills) */
    .badge-pill-custom {
        padding: 0.4em 0.8em;
        border-radius: 50rem;
        font-weight: 500;
        font-size: 0.85em;
    }

    /* Botão de ação minimalista */
    .btn-action {
        border-radius: 0.5rem;
        font-weight: 500;
        transition: all 0.2s;
    }

    /* Esconde a versão Desktop no Mobile e vice-versa */
    @@media (max-width: 767.98px) {
        .d-mobile-block { display: block !important; }
        .d-desktop-none { display: none !important; }
        
        .card-body-mobile {
            padding: 0 !important;
        }
    }

    /* Estilo do Card Mobile Individual */
    .mobile-order-item {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .mobile-order-item:last-child {
        border-bottom: none;
    }

    .mobile-order-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
</style>
<div class="container-fluid my- px-0">
    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i>
                Filtros de Pesquisa
            </h3>

            <div class="card-tools ms-auto">
                <button type="button"
                        class="btn btn-tool btn-collapse-filtro"
                        data-lte-toggle="card-collapse"
                        title="Recolher">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="card-body">
            <form class="py-2" id="formFiltroPedidos" method="get" action="@Url.Action("Index", "Pedidos", new { area = "Admin" })">
                <input type="hidden" id="pagina" name="pagina" value="@Model.PaginaAtual" />
                <input type="hidden" id="sortColumn" name="sortColumn" value="@Model.SortColumn" />
                <input type="hidden" id="sortDirection" name="sortDirection" value="@Model.SortDirection" />

                <div class="row g-3">
                    <div class="col-md-3">
                        <div>
                            <label for="dataInicio" class="form-label">Data inicial</label>
                            <input type="date"
                                class="form-control"
                                id="dataInicio"
                                name="dataInicio"
                                value="@(string.IsNullOrEmpty(Context.Request.Query["dataInicio"]) ? DateTime.Today.ToString("yyyy-MM-dd") : Context.Request.Query["dataInicio"].ToString())">
                        </div>
                    </div>
                    
                    <div class="col-md-3">
                        <div>
                            <label for="dataFim" class="form-label">Data final</label>
                            <input type="date"
                                class="form-control"
                                id="dataFim"
                                name="dataFim"
                                value="@(string.IsNullOrEmpty(Context.Request.Query["dataFim"]) ? DateTime.Today.ToString("yyyy-MM-dd") : Context.Request.Query["dataFim"].ToString())">
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div>
                            <label for="tipoData" class="form-label">Filtrar por</label>
                            <select class="form-select" id="tipoData" name="tipoData">
                                <option value="CriadoEmUtc" selected="@(Context.Request.Query["tipoData"] == "CriadoEmUtc" || string.IsNullOrEmpty(Context.Request.Query["tipoData"]))">
                                    Data do pedido
                                </option>
                                <option value="HorarioRetirada" selected="@(Context.Request.Query["tipoData"] == "HorarioRetirada")">
                                    Data de retirada
                                </option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div>
                            <label for="status" class="form-label">Status do Pedido</label>
                            <select class="form-select" id="status" name="status">
                                <option value="">Todos os status</option>
                                <option value="Rascunho" selected="@(Context.Request.Query["status"] == "Rascunho")">Rascunho</option>
                                <option value="AguardandoPagamento" selected="@(Context.Request.Query["status"] == "AguardandoPagamento")">Aguardando pagamento</option>
                                <option value="Confirmado" selected="@(Context.Request.Query["status"] == "Confirmado")">Confirmado</option>
                                <option value="EmPreparo" selected="@(Context.Request.Query["status"] == "EmPreparo")">Em preparo</option>
                                <option value="Pronto" selected="@(Context.Request.Query["status"] == "Pronto")">Pronto</option>
                                <option value="Concluido" selected="@(Context.Request.Query["status"] == "Concluido")">Concluído</option>
                                <option value="Cancelado" selected="@(Context.Request.Query["status"] == "Cancelado")">Cancelado</option>
                            </select>
                        </div>
                    </div>
                </div>

                <hr class="my-3" style="border-top: 1px solid #f1f5f9;">

                <div class="d-flex justify-content-end align-items-center">
                    <a href="@Url.Action("Index", "Pedidos", new { area = "Admin" })"
                    id="btnLimparFiltros"
                    class="btn btn-filter-action btn-filter-outline me-2">
                        <i class="fas fa-eraser opacity-50"></i>
                        Limpar
                    </a>

                    <button type="submit" id="btnPesquisarPedidos" class="btn btn-filter-action btn-secondary shadow-sm">
                        <i class="fas fa-search"></i>
                        Aplicar Filtros
                    </button>
                </div>
            </form>
        </div>
    </div>
    <div id="resultadoPedidos">
        @await Html.PartialAsync("_PedidosLista", Model)
    </div>
</div>
<div class="modal fade" id="modalDetalhesPedido" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" id="conteudoModalPedido">
            <div class="modal-body text-center py-5">
                <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
            </div>
        </div>
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

@section Scripts {
    <script>
        $(function () {
            $("#formFiltroPedidos").on("submit", function (e, manterPagina) {
                e.preventDefault();

                const $form = $(this);
                const $btn = $form.find("#btnPesquisarPedidos");

                if (!manterPagina) {
                    $form.find("#pagina").val(1);
                }

                let url = $form.attr("action") + "?" + $form.serialize();
                url += "&tamanhoPagina=" + ($("#tamanhoPagina").val() || 5);

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Pesquisando');
                window.addLoading("Buscando pedidos...");

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (html) {
                        $("#resultadoPedidos").html(html);
                        window.history.replaceState({}, "", url);
                    },
                    error: function () {
                        alert("Não foi possível carregar os pedidos.");
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-search"></i> Aplicar Filtros');
                        window.removeLoading();
                    }
                });
            });

            $("#formFiltroPedidos").on("click", "#btnLimparFiltros", function (e) {
                e.preventDefault();

                const $form = $("#formFiltroPedidos");
                const $btn = $form.find("#btnPesquisarPedidos");
                const urlBase = $(this).attr("href");

                $form[0].reset();
                $form.find("#pagina").val(1);
                $("#tamanhoPagina").val(10);
                debugger
                const url = urlBase + "?" + $form.serialize() + "&tamanhoPagina=" + $("#tamanhoPagina").val();

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin"></i> Pesquisando');
                addLoading("Buscando pedidos...");

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (html) {
                        $("#resultadoPedidos").html(html);
                        window.history.replaceState({}, "", url);
                    },
                    error: function () {
                        alert("Não foi possível carregar os pedidos.");
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-search"></i> Aplicar Filtros');
                        removeLoading();
                    }
                });
            });

            $(".btn-collapse-filtro").on("click", function () {
                const $card = $(this).closest(".card");
                const $icon = $(this).find("i");
                const vaiFechar = !$card.hasClass("collapsed-card");

                $icon.attr("class", `fas fa-${vaiFechar ? "plus" : "minus"}`);
            });
        
            $(document).on("click", ".btn-ver-pedido", function (e) {
                e.preventDefault();

                const url = $(this).data("url");
                const modalEl = document.getElementById("modalDetalhesPedido");
                const $conteudo = $("#conteudoModalPedido");

                $conteudo.html(`
                    <div class="modal-body text-center py-5">
                        <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
                    </div>
                `);

                $.ajax({
                    url: url,
                    type: "GET",
                    headers: { "X-Requested-With": "XMLHttpRequest" },
                    success: function (html) {
                        $conteudo.html(html);
                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    },
                    error: function () {
                        $conteudo.html(`
                            <div class="modal-header">
                                <h5 class="modal-title">Erro</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
                            </div>
                            <div class="modal-body">
                                <div class="alert alert-danger mb-0">
                                    Não foi possível carregar os detalhes do pedido.
                                </div>
                            </div>
                        `);

                        bootstrap.Modal.getOrCreateInstance(modalEl).show();
                    }
                });
            });

            $(document).on("click", "#btnSalvarStatus", function () {
                const $btn = $(this);
                const id = $btn.data("id");
                const status = $("#novoStatus").val();
                const $feedback = $("#statusPedidoFeedback");
                const modalEl = document.getElementById("modalDetalhesPedido");

                if (!status) {
                    $feedback.html('<div class="alert alert-warning mb-0">Selecione um status.</div>');
                    return;
                }

                $btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin me-1"></i> Salvando');

                $.ajax({
                    url: '@Url.Action("AtualizarStatus", "Pedidos", new { area = "Admin" })',
                    type: "POST",
                    data: {
                        id: id,
                        status: status
                    },
                    success: function (response) {
                        if (!response.sucesso) {
                            $feedback.html('<div class="alert alert-danger mb-0">' + response.mensagem + '</div>');
                            return;
                        }

                        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);

                        $(modalEl).one("hidden.bs.modal", function () {
                            $("#conteudoModalPedido").html(`
                                <div class="modal-body text-center py-5">
                                    <i class="fas fa-spinner fa-spin me-2"></i> Carregando...
                                </div>
                            `);

                            $(".modal-backdrop").remove();
                            $("body").removeClass("modal-open").css("padding-right", "");

                            if (typeof Swal !== "undefined") {
                                Swal.fire({
                                    icon: "success",
                                    title: "Status atualizado",
                                    text: response.mensagem,
                                    confirmButtonText: "OK"
                                }).then(() => {
                                    $("#formFiltroPedidos").trigger("submit");
                                });
                            } else {
                                alert(response.mensagem);
                                $("#formFiltroPedidos").trigger("submit");
                            }
                        });

                        modal.hide();
                    },
                    error: function () {
                        $feedback.html('<div class="alert alert-danger mb-0">Não foi possível atualizar o status.</div>');
                    },
                    complete: function () {
                        $btn.prop("disabled", false).html('<i class="fas fa-save me-1"></i> Salvar status');
                    }
                });
            });
          
            $(document).on("click", ".paginacao-pedido", function (e) {
                e.preventDefault();

                const pagina = $(this).data("pagina");

                if (!pagina || $(this).closest(".page-item").hasClass("disabled") || $(this).closest(".page-item").hasClass("active"))
                    return;

                $("#pagina").val(pagina);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });
            
            $(document).on("change", "#tamanhoPagina", function () {
                $("#pagina").val(1);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });

            $(document).on("click", ".ordenacao-pedido", function (e) {
                e.preventDefault();

                const coluna = $(this).data("coluna");
                const $sortColumn = $("#sortColumn");
                const $sortDirection = $("#sortDirection");

                if ($sortColumn.val() === coluna) {
                    $sortDirection.val($sortDirection.val() === "asc" ? "desc" : "asc");
                } else {
                    $sortColumn.val(coluna);
                    $sortDirection.val("asc");
                }

                $("#pagina").val(1);
                $("#formFiltroPedidos").trigger("submit", [true]);
            });
        });
    </script>
}

