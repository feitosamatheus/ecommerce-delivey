@using Ecommerce.MVC.Enums
@model Ecommerce.MVC.Entities.Pedido

<style>
    .modal-content-clean {
        border: none !important;
        border-radius: 1rem !important;
        overflow: hidden;
    }

    .modal-header-clean {
        background-color: #fff;
        border-bottom: 1px solid #f1f5f9;
        padding: 1.25rem;
    }

    .modal-title-clean {
        font-weight: 700;
        color: #334155;
        font-size: 1.1rem;
    }

    .modal-body-clean {
        background-color: #f8fafc;
        padding: 1.5rem;
    }
</style>

<div class="modal-content modal-content-clean">
    <div class="modal-header modal-header-clean">
        <h5 class="modal-title modal-title-clean">
            <i class="fas fa-shopping-bag me-2 text-primary opacity-75"></i>
            Pedido #@Model.Codigo
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
    </div>

    <div class="modal-body modal-body-clean">
        <div class="card card-filter-clean mb-4">
            <div class="card-header">
                <h6 class="card-title fs-6 mb-0 text-uppercase" style="font-size: 0.75rem !important; letter-spacing: 0.05em; color: #64748b;">
                    Atualização de Status
                </h6>
            </div>
            <div class="card-body">
                <div class="row g-3 align-items-end">
                    <div class="col-lg-8">
                        <label for="novoStatus" class="form-label">Novo status</label>
                        <select class="form-select" id="novoStatus">
                            <option value="Rascunho" selected="@(Model.Status == EPedidoStatus.Rascunho)">Rascunho</option>
                            <option value="AguardandoPagamento" selected="@(Model.Status == EPedidoStatus.AguardandoPagamento)">Aguardando pagamento</option>
                            <option value="Confirmado" selected="@(Model.Status == EPedidoStatus.Confirmado)">Confirmado</option>
                            <option value="EmPreparo" selected="@(Model.Status == EPedidoStatus.EmPreparo)">Em preparo</option>
                            <option value="Pronto" selected="@(Model.Status == EPedidoStatus.Pronto)">Pronto</option>
                            <option value="Concluido" selected="@(Model.Status == EPedidoStatus.Concluido)">Concluído</option>
                            <option value="Cancelado" selected="@(Model.Status == EPedidoStatus.Cancelado)">Cancelado</option>
                        </select>
                    </div>

                    <div class="col-lg-4">
                        <button type="button"
                                class="btn btn-filter-action btn-primary shadow-sm w-100"
                                id="btnSalvarStatus"
                                data-id="@Model.Id">
                            <i class="fas fa-save me-1"></i>
                            Salvar status
                        </button>
                    </div>
                </div>

                <div id="statusPedidoFeedback" class="mt-3"></div>
            </div>
        </div>

        <div class="card card-filter-clean mb-4">
            <div class="card-header">
                <h6 class="card-title fs-6 mb-0 text-uppercase" style="font-size: 0.75rem !important; letter-spacing: 0.05em; color: #64748b;">
                    Detalhes do Cliente e Entrega
                </h6>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 form-label">Cliente</dt>
                    <dd class="col-sm-8 text-dark fw-medium">@Model.Cliente?.Nome</dd>

                    <dt class="col-sm-4 form-label">Data do pedido</dt>
                    <dd class="col-sm-8">@Model.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 form-label">Horário retirada</dt>
                    <dd class="col-sm-8">@Model.HorarioRetirada.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                    <dt class="col-sm-4 form-label">Método entrega</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-light text-dark border">@Model.MetodoEntrega</span>
                    </dd>

                    <dt class="col-sm-4 form-label">Pagamento</dt>
                    <dd class="col-sm-8">@Model.Pagamento</dd>

                    <dt class="col-sm-4 form-label">Status</dt>
                    <dd class="col-sm-8">
                        <span class="badge badge-pill-custom bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10">
                            @Model.Status
                        </span>
                    </dd>

                    <dt class="col-sm-4 form-label">Observação</dt>
                    <dd class="col-sm-8 text-muted small">@(string.IsNullOrWhiteSpace(Model.Observacao) ? "-" : Model.Observacao)</dd>
                </dl>
            </div>
        </div>

        <div class="card card-table-clean">
            <div class="card-header">
                <h6 class="card-title fs-6 mb-0 text-uppercase" style="font-size: 0.75rem !important; letter-spacing: 0.05em; color: #64748b;">
                    Itens do Pedido
                </h6>
            </div>

            <div class="card-body p-0">
                @if (Model.Itens == null || !Model.Itens.Any())
                {
                    <div class="p-4 text-center">
                        <p class="text-muted mb-0 small">Nenhum item encontrado.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-clean align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Produto</th>
                                    <th class="text-center">Qtd</th>
                                    <th class="text-end">Valor linha</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Itens)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold text-dark">@item.ProdutoNomeSnapshot</div>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-light text-secondary border">@item.Quantidade</span>
                                        </td>
                                        <td class="text-end fw-medium">@item.TotalLinha.ToString("C")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="p-4 bg-light border-top">
                        <div class="row justify-content-end">
                            <div class="col-md-5">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="form-label mb-0">Subtotal</span>
                                    <span class="fw-medium">@Model.Subtotal.ToString("C")</span>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="form-label mb-0">Taxa entrega</span>
                                    <span class="fw-medium text-success">+ @Model.TaxaEntrega.ToString("C")</span>
                                </div>
                                <div class="d-flex justify-content-between pt-2 border-top">
                                    <span class="fw-bold text-dark">TOTAL</span>
                                    <span class="fw-bold text-primary fs-5">@Model.Total.ToString("C")</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="modal-footer bg-white border-top-0 pb-4">
        <button type="button" class="btn btn-filter-action btn-filter-outline" data-bs-dismiss="modal">Fechar</button>
        <button type="button" class="btn btn-filter-action btn-primary shadow-sm" onclick="window.print();">
            <i class="fas fa-print"></i> Imprimir
        </button>
    </div>
</div>