@model IEnumerable<Ecommerce.MVC.Entities.Pedido>

<div class="card card-table-clean mt-4">
    <div class="card-header d-flex align-items-center justify-content-between row">
        <h3 class="card-title mb-0 col-6">
            <i class="fas fa-shopping-cart me-2 text-primary"></i>
            Lista de Pedidos
        </h3>
        <div class="d-flex justify-content-end col-6">
            <div class="card-tools">
                @if (Model != null && Model.Any())
                {
                    <span class="badge rounded-pill bg-light text-primary border">
                        @Model.Count() <span class="d-none d-sm-inline">Pedidos</span>
                    </span>
                }
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive d-none d-md-block">
            <table class="table table-clean mb-0">
                <thead>
                    <tr>
                        <th class="ps-4">Código</th>
                        <th>Cliente</th>
                        <th>Data</th>
                        <th class="text-end">Total</th>
                        <th class="text-center">Status</th>
                        <th class="text-end pe-4">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var p in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@p.Codigo</td>
                                <td>
                                    <div class="d-flex flex-column">
                                        <span>@(p.Cliente?.Nome ?? "-")</span>
                                        <small class="text-muted" style="font-size: 0.75rem;">Consumidor Final</small>
                                    </div>
                                </td>
                                <td>@p.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy")</td>
                                <td class="text-end fw-bold text-primary">@p.Total.ToString("C")</td>
                                <td class="text-center">
                                    @{
                                        var statusClass = p.Status.ToString() switch
                                        {
                                            "Pendente" => "bg-warning-subtle text-warning-emphasis border-warning-subtle",
                                            "Concluido" => "bg-success-subtle text-success-emphasis border-success-subtle",
                                            "Cancelado" => "bg-danger-subtle text-danger-emphasis border-danger-subtle",
                                            _ => "bg-primary-subtle text-primary-emphasis border-primary-subtle"
                                        };
                                    }
                                    <span class="badge border badge-pill-custom @statusClass">
                                        @p.Status
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="javascript:void(0);"
                                        class="btn btn-sm btn-light border btn-action btn-ver-pedido"
                                        data-url="@Url.Action("DetailsModal", "Pedidos", new { area = "Admin", id = p.Id })">
                                            <i class="fas fa-eye text-muted me-1"></i> Abrir
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="d-md-none">
            @if (Model != null && Model.Any())
            {
                @foreach (var p in Model)
                {
                    <div class="mobile-order-item">
                        <div class="mobile-order-header">
                            <div>
                                <span class="fw-bold text-dark d-block">#@p.Codigo</span>
                                <small class="text-muted">@p.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                            </div>
                            @{
                                var statusClassMob = p.Status.ToString() switch
                                {
                                    "Pendente" => "bg-warning-subtle text-warning-emphasis border-warning-subtle",
                                    "Concluido" => "bg-success-subtle text-success-emphasis border-success-subtle",
                                    "Cancelado" => "bg-danger-subtle text-danger-emphasis border-danger-subtle",
                                    _ => "bg-primary-subtle text-primary-emphasis border-primary-subtle"
                                };
                            }
                            <span class="badge border badge-pill-custom @statusClassMob" style="font-size: 0.7rem;">
                                @p.Status
                            </span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <div>
                                <span class="d-block text-secondary" style="font-size: 0.9rem;">@(p.Cliente?.Nome ?? "-")</span>
                                <span class="fw-bold text-primary">@p.Total.ToString("C")</span>
                            </div>
                            <a href="javascript:void(0);"
                                class="btn btn-sm btn-light border px-3 btn-ver-pedido"
                                data-url="@Url.Action("DetailsModal", "Pedidos", new { area = "Admin", id = p.Id })">
                                    <i class="fas fa-chevron-right"></i>
                            </a>
                        </div>
                    </div>
                }
            }
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="fas fa-inbox d-block mb-2 fa-2x opacity-25"></i>
                Nenhum pedido encontrado.
            </div>
        }
    </div>
</div>