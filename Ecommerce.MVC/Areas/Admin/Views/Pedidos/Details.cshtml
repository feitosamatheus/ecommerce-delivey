@model Ecommerce.MVC.Entities.Pedido

@{
    ViewData["Title"] = $"Pedido {Model.Codigo} - Admin";
}

<div class="container my-4">
    <a asp-area="Admin" asp-controller="Pedidos" asp-action="Index" class="btn btn-link btn-sm text-decoration-none mb-2">
        &larr; Voltar para lista
    </a>

    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <h2 class="h5 mb-3">Pedido @Model.Codigo</h2>
            <dl class="row mb-0">
                <dt class="col-sm-3">Cliente</dt>
                <dd class="col-sm-9">@Model.Cliente?.Nome</dd>

                <dt class="col-sm-3">Data</dt>
                <dd class="col-sm-9">@Model.CriadoEmUtc.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>

                <dt class="col-sm-3">Método entrega</dt>
                <dd class="col-sm-9">@Model.MetodoEntrega</dd>

                <dt class="col-sm-3">Pagamento</dt>
                <dd class="col-sm-9">@Model.Pagamento</dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">@Model.Status</dd>

                <dt class="col-sm-3">Observação</dt>
                <dd class="col-sm-9">@Model.Observacao</dd>
            </dl>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="h6 mb-3">Itens</h3>

            @if (Model.Itens == null || !Model.Itens.Any())
            {
                <p class="text-muted mb-0">Nenhum item.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Produto</th>
                                <th class="text-center">Qtd</th>
                                <th class="text-end">Valor linha</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Itens)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.ProdutoNomeSnapshot</div>
                                    </td>
                                    <td class="text-center">@item.Quantidade</td>
                                    <td class="text-end">@item.TotalLinha.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-2">
                    <div class="text-end">
                        <div class="small text-muted">Subtotal</div>
                        <div class="fw-semibold">@Model.Subtotal.ToString("C")</div>
                        <div class="small text-muted mt-1">Taxa entrega</div>
                        <div class="fw-semibold">@Model.TaxaEntrega.ToString("C")</div>
                        <div class="small text-muted mt-1">Total</div>
                        <div class="fw-bold fs-5">@Model.Total.ToString("C")</div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

