@model Ecommerce.MVC.Models.Admin.Acompanhamentos.AcompanhamentosIndexViewModel
@using System.Globalization

@{
    ViewData["Title"] = "Acompanhamentos";
    ViewData["Description"] = "Gerencie os itens adicionais vinculados às categorias.";
    var pt = new CultureInfo("pt-BR");
}

<style>
    /* Reaproveitando o design system do Barriga Cheia */
    .card-filter-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .card-filter-clean .card-header {
        background-color: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 1rem 1.25rem;
    }

    .card-filter-clean .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .card-filter-clean .form-control,
    .card-filter-clean .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
        transition: all 0.2s ease;
    }

    .btn-filter-action {
        border-radius: 0.5rem;
        padding: 0.5rem 1.25rem;
        font-weight: 600;
        font-size: 0.875rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-filter-outline {
        background: #fff;
        border: 1px solid #e2e8f0;
        color: #64748b;
        text-decoration: none;
    }

    .card-table-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
        border-radius: 0.75rem !important;
        overflow: hidden;
    }

    .table-clean thead th {
        background-color: #f8fafc !important;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.025em;
        font-weight: 700;
        color: #64748b;
        border-bottom: 1px solid #e2e8f0;
        padding: 1rem 0.75rem !important;
    }

    .table-clean tbody td {
        padding: 1rem 0.75rem !important;
        vertical-align: middle;
        color: #475569;
    }

    .badge-status {
        font-weight: 600;
        padding: 0.35em 0.65em;
        border-radius: 0.375rem;
    }
</style>

<div class="container-fluid px-0">
    <div class="w-100 d-flex justify-content-end mb-3">
        <a asp-area="Admin" asp-controller="Acompanhamentos" asp-action="Create"
           class="btn btn-primary btn-sm shadow-sm btn-filter-action">
            <i class="fas fa-plus"></i> Novo Acompanhamento
        </a>
    </div>

    <div class="card card-filter-clean mb-4">
        <div class="card-header d-flex align-items-center py-2">
            <h3 class="card-title fs-6 mb-0">
                <i class="fas fa-filter me-2 text-muted"></i> Filtros de Pesquisa
            </h3>
            <div class="card-tools ms-auto">
                <button type="button" class="btn btn-link btn-sm text-muted" data-lte-toggle="card-collapse">
                    <i class="fas fa-minus"></i>
                </button>
            </div>
        </div>

        <div class="card-body">
            <form method="get" id="formFiltroAcompanhamentos">
                <div class="row g-3">
                    <div class="col-xl-5">
                        <label class="form-label">Nome do Acompanhamento</label>
                        <input type="text" name="busca" class="form-control" 
                               placeholder="Ex: Queijo, Bacon..." value="@Model.Busca">
                    </div>

                    <div class="col-xl-4">
                        <label class="form-label">Categoria</label>
                        <select name="categoriaId" class="form-select">
                            <option value="">Todas as categorias</option>
                            @foreach (var cat in Model.Categorias)
                            {
                                <option value="@cat.Value" selected="@(Model.CategoriaId?.ToString() == cat.Value)">
                                    @cat.Text
                                </option>
                            }
                        </select>
                    </div>

                    <div class="col-xl-3 d-flex align-items-end justify-content-end gap-2">
                        <a href="@Url.Action("Index")" class="btn btn-filter-outline btn-filter-action">
                            <i class="fas fa-eraser opacity-50"></i> Limpar
                        </a>
                        <button type="submit" class="btn btn-secondary shadow-sm btn-filter-action">
                            <i class="fas fa-search"></i> Filtrar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card card-table-clean">
        <div class="card-body table-responsive p-0">
            <table class="table table-hover table-clean align-middle mb-0">
                <thead>
                    <tr>
                        <th style="width: 30%">Nome</th>
                        <th>Categoria</th>
                        <th>Preço</th>
                        <th class="text-center">Ordem</th>
                        <th class="text-center">Status</th>
                        <th class="text-end" style="width: 150px">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Itens.Any())
                    {
                        foreach (var item in Model.Itens)
                        {
                            <tr>
                                <td class="fw-bold text-dark">@item.Nome</td>
                                <td>
                                    <span class="text-muted"><i class="fas fa-tag me-1 small"></i> @item.CategoriaNome</span>
                                </td>
                                <td>@item.Preco.ToString("C", pt)</td>
                                <td class="text-center">
                                    <span class="badge bg-light text-dark border">@item.Ordem</span>
                                </td>
                                <td class="text-center">
                                    @if (item.Ativo)
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle badge-status">Ativo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle badge-status">Inativo</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Edit" asp-route-id="@item.Id" 
                                           class="btn btn-sm btn-white text-primary" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-white text-danger btn-excluir-acompanhamento" 
                                                data-id="@item.Id" title="Excluir">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>

                                    <form id="form-delete-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:none;">
                                        @Html.AntiForgeryToken()
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <img src="/img/placeholder-vazio.png" alt="Vazio" style="width: 80px; opacity: 0.3" class="mb-3 d-block mx-auto">
                                <p class="text-muted mb-0">Nenhum acompanhamento encontrado para os filtros aplicados.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(function () {
            // Lógica de exclusão com SweetAlert2
            $(".btn-excluir-acompanhamento").on("click", function () {
                const id = $(this).data("id");
                
                Swal.fire({
                    title: 'Remover Acompanhamento?',
                    text: "Esta ação não pode ser desfeita.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#2c180d',
                    cancelButtonColor: '#6c757d',
                    confirmButtonText: 'Sim, remover!',
                    cancelButtonText: 'Cancelar',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        if (typeof window.addLoading === "function") {
                            window.addLoading("Removendo...");
                        }
                        $(`#form-delete-${id}`).submit();
                    }
                });
            });
        });
    </script>
}