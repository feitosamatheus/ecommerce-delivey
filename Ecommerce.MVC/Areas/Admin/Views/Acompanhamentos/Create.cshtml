@model Ecommerce.MVC.Models.Admin.Acompanhamentos.AcompanhamentoFormViewModel

<style>
    /* Design System Barriga Cheia - Form Extension */
    .card-form-clean {
        border: none !important;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05) !important;
        border-radius: 0.75rem !important;
        background-color: #ffffff;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.025em;
        color: #64748b;
        margin-bottom: 0.5rem;
    }

    .form-control, .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 0.5rem;
        padding: 0.6rem 0.75rem;
        font-size: 0.95rem;
        transition: border-color 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #94a3b8;
            box-shadow: none;
        }

    .btn-action {
        border-radius: 0.5rem;
        padding: 0.6rem 1rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .form-check-input:checked {
        background-color: #2c180d;
        border-color: #2c180d;
    }
</style>

<div class="w-100 d-flex justify-content-start align-items-center mb-4">
    <a asp-action="Index" class="btn btn-light btn-sm border text-muted btn-action">
        <i class="fas fa-arrow-left"></i> Voltar
    </a>
</div>

<div class="card card-form-clean">
    <div class="card-body p-4 pb-3">
        <form method="post" id="form-acompanhamento">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm mb-4 small"></div>

            <div class="row g-4">
                @* Nome *@
                <div class="col-md-6">
                    <label asp-for="Nome" class="form-label">Nome do Item</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Bacon, Molho Barbecue..." />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                @* Preço *@
                <div class="col-md-3">
                    <label asp-for="Preco" class="form-label">Preço Adicional</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted">R$</span>
                        <input asp-for="Preco"
                               id="Preco"
                               name="Preco"
                               class="form-control border-start-0"
                               type="text"
                               inputmode="decimal"
                               placeholder="0,00" />
                    </div>
                    <span asp-validation-for="Preco" class="text-danger small"></span>
                </div>

                @* Ordem *@
                <div class="col-md-3">
                    <label asp-for="Ordem" class="form-label">Ordem de Exibição</label>
                    <input asp-for="Ordem" class="form-control" type="number" />
                    <span asp-validation-for="Ordem" class="text-danger small"></span>
                </div>

                @* Categoria *@
                <div class="col-md-6">
                    <label asp-for="AcompanhamentoCategoriaId" class="form-label">Categoria de Acompanhamento</label>
                    <select asp-for="AcompanhamentoCategoriaId"
                            asp-items="Model.Categorias"
                            class="form-select">
                        <option value="">Selecione a categoria...</option>
                    </select>
                    <span asp-validation-for="AcompanhamentoCategoriaId" class="text-danger small"></span>
                </div>

                @* Switch Ativo *@
                <div class="col-md-6 d-flex align-items-end pb-2">
                    <div class="form-check form-switch">
                        <input asp-for="Ativo" class="form-check-input" type="checkbox" role="switch">
                            <label asp-for="Ativo" class="form-check-label fw-bold text-dark ms-2">Disponível para venda</label>
                        </div>
                    </div>

                    @* Descrição *@
                    <div class="col-md-12">
                        <label asp-for="Descricao" class="form-label">Descrição / Observações</label>
                        <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Detalhes sobre o item..."></textarea>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>

                    @* Rodapé de Ações *@
                    <div class="col-12 mt-5 d-flex justify-content-end gap-2 border-top pt-3">
                        <a asp-action="Index" class="btn btn-link text-muted text-decoration-none fw-bold px-4">
                            Cancelar
                        </a>
                        <button type="submit" class="btn btn-primary shadow-sm btn-action">
                            <i class="fas fa-save"></i> Cadastrar Item
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const precoInput = document.getElementById('Preco');
            const form = document.getElementById('form-acompanhamento');

            function aplicarMascaraMoeda(valor) {
                valor = valor.replace(/\D/g, '');

                if (!valor) {
                    return '';
                }

                valor = (parseInt(valor, 10) / 100).toFixed(2) + '';
                valor = valor.replace('.', ',');
                valor = valor.replace(/\B(?=(\d{3})+(?!\d))/g, '.');

                return valor;
            }

            function normalizarParaBanco(valor) {
                if (!valor) return '';

                return valor
                        .toString()
                        .trim()
                        .replace(/\./g, '');
            }

            if (precoInput) {
                precoInput.addEventListener('input', function (e) {
                    const cursorFim = e.target.selectionStart === e.target.value.length;
                    e.target.value = aplicarMascaraMoeda(e.target.value);

                    if (cursorFim) {
                        e.target.setSelectionRange(e.target.value.length, e.target.value.length);
                    }
                });

                precoInput.addEventListener('blur', function (e) {
                    if (e.target.value && !e.target.value.includes(',')) {
                        e.target.value = aplicarMascaraMoeda(e.target.value);
                    }
                });

                if (precoInput.value) {
                    precoInput.value = aplicarMascaraMoeda(precoInput.value);
                }
            }

            if (form) {
                form.addEventListener('submit', function () {
                    if (precoInput) {
                        precoInput.value = normalizarParaBanco(precoInput.value);
                    }
                });
            }
        });
    </script>