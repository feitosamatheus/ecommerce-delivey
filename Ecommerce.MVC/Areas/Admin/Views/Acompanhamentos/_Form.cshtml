@model Ecommerce.MVC.Models.Admin.Acompanhamentos.AcompanhamentoFormViewModel

<div class="card card-table-clean">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Nome" class="form-label"></label>
                    <input asp-for="Nome" class="form-control" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Preco" class="form-label"></label>
                    <input asp-for="Preco" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Preco" class="text-danger"></span>
                </div>

                <div class="col-md-3">
                    <label asp-for="Ordem" class="form-label"></label>
                    <input asp-for="Ordem" class="form-control" type="number" />
                    <span asp-validation-for="Ordem" class="text-danger"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="AcompanhamentoCategoriaId" class="form-label">Categoria</label>
                    <select asp-for="AcompanhamentoCategoriaId"
                            asp-items="Model.Categorias"
                            class="form-select">
                        <option value="">Selecione</option>
                    </select>
                    <span asp-validation-for="AcompanhamentoCategoriaId" class="text-danger"></span>
                </div>

                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check">
                        <input asp-for="Ativo" class="form-check-input" />
                        <label asp-for="Ativo" class="form-check-label"></label>
                    </div>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descricao" class="form-label"></label>
                    <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Descricao" class="text-danger"></span>
                </div>

                <div class="col-12 d-flex justify-content-end gap-2">
                    <a asp-area="Admin"
                       asp-controller="Acompanhamentos"
                       asp-action="Index"
                       class="btn btn-outline-secondary">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Salvar
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>